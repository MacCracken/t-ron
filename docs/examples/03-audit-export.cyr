#  docs/examples/03-audit-export.cyr
#
#  Log a few audit events, export them as an encrypted envelope
#  (ChaCha20 + Ed25519 AEAD), then decrypt + verify with the matching
#  keys and assert the round trip holds.

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/vec.cyr"
include "lib/str.cyr"
include "lib/syscalls.cyr"
include "lib/io.cyr"
include "lib/tagged.cyr"
include "lib/assert.cyr"
include "lib/fnptr.cyr"
include "lib/hashmap.cyr"
include "lib/regex.cyr"
include "lib/chrono.cyr"
include "lib/freelist.cyr"
include "lib/sakshi.cyr"
include "lib/bigint.cyr"
include "lib/json.cyr"
include "lib/base64.cyr"
include "lib/sigil.cyr"

include "lib/libro_error.cyr"
include "lib/libro_hasher.cyr"
include "lib/libro_entry.cyr"
include "lib/libro_verify.cyr"
include "lib/libro_chain.cyr"
include "lib/libro_query.cyr"
include "lib/libro_retention.cyr"
include "lib/libro_review.cyr"

include "src/error.cyr"
include "src/gate.cyr"
include "src/audit.cyr"
include "src/crypto_chacha20.cyr"

fn main() {
    alloc_init();

    var a = audit_logger_new();
    var call = tool_call_new("agent-1", "tarang_probe", "{}", 0);
    audit_log(a, call, verdict_allow());
    audit_log(a, call, verdict_deny("rate limit exceeded", DENY_RATE_LIMITED));
    audit_log(a, call, verdict_flag("anomalous pattern"));

    #  Envelope keys: ChaCha20 symmetric + Ed25519 signing pair.
    var sk = alloc(64); var pk = alloc(32);
    ed25519_generate_keypair(sk, pk);

    var key = alloc(32);
    var i = 0;
    while (i < 32) { store8(key + i, 0x20 + i); i = i + 1; }

    var nonce = alloc(12);
    var j = 0;
    while (j < 12) { store8(nonce + j, 0x80 + j); j = j + 1; }

    var out_len_slot = alloc(8);
    var cipher = audit_export_encrypted(a, nonce, key, sk, out_len_slot);
    var clen = load64(out_len_slot);

    #  Round-trip: decrypt + verify with the matching public key.
    var plain = audit_decrypt_export(cipher, clen, key, pk);
    if (plain == 0) {
        println("FAIL: decrypt_export returned 0");
        return 1;
    }

    var expected = audit_export_json(a);
    if (streq(plain, expected) == 0) {
        println("FAIL: plaintext did not match audit_export_json");
        return 1;
    }

    print_num(clen); println(" bytes in encrypted envelope");
    println("ex03 passed: encrypted audit export round-trip OK.");
    return 0;
}

var r = main();
syscall(60, r);
