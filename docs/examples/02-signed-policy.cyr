#  docs/examples/02-signed-policy.cyr
#
#  End-to-end Ed25519-signed policy: generate a keypair, sign a policy
#  TOML, write the .toml + .toml.sig, then verify + load with
#  tron_verify_and_load_policy.

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/vec.cyr"
include "lib/str.cyr"
include "lib/syscalls.cyr"
include "lib/io.cyr"
include "lib/tagged.cyr"
include "lib/assert.cyr"
include "lib/fnptr.cyr"
include "lib/hashmap.cyr"
include "lib/regex.cyr"
include "lib/chrono.cyr"
include "lib/freelist.cyr"
include "lib/sakshi.cyr"
include "lib/bigint.cyr"
include "lib/json.cyr"
include "lib/base64.cyr"
include "lib/sigil.cyr"

include "lib/libro_error.cyr"
include "lib/libro_hasher.cyr"
include "lib/libro_entry.cyr"
include "lib/libro_verify.cyr"
include "lib/libro_chain.cyr"
include "lib/libro_query.cyr"
include "lib/libro_retention.cyr"
include "lib/libro_review.cyr"

include "src/error.cyr"
include "src/gate.cyr"
include "src/policy.cyr"
include "src/rate.cyr"
include "src/scanner.cyr"
include "src/pattern.cyr"
include "src/audit.cyr"
include "src/score.cyr"
include "src/query.cyr"
include "src/correlation.cyr"
include "src/tron.cyr"
include "src/signing.cyr"

fn main() {
    alloc_init();

    #  Generate an Ed25519 keypair and sign a policy TOML.
    var content = "[agent.\"trusted\"]\nallow = [\"tarang_*\"]\n";
    var clen = strlen(content);

    var sk = alloc(64);
    var pk = alloc(32);
    ed25519_generate_keypair(sk, pk);

    var sig = alloc(64);
    ed25519_sign(sk, content, clen, sig);

    file_write_all("/tmp/ex02_policy.toml",     content, clen);
    file_write_all("/tmp/ex02_policy.toml.sig", sig,     64);

    #  Build a verifier with our public key and load the signed policy.
    var verifier = policy_verifier_new();
    policy_verifier_add_key(verifier, pk);

    var tron = tron_new(tron_config_default());
    var rc = tron_verify_and_load_policy(tron, verifier, "/tmp/ex02_policy.toml");
    if (rc != TRON_ERR_NONE) {
        println("FAIL: verify_and_load returned an error");
        return 1;
    }

    #  Confirm the policy is active.
    var v = tron_check(tron, tool_call_new(
        "trusted", "tarang_probe", "{}", clock_epoch_ns()));
    if (verdict_is_allowed(v) == 0) {
        println("FAIL: expected allow for trusted agent");
        return 1;
    }

    println("ex02 passed: signed policy loaded and enforced.");
    return 0;
}

var r = main();
syscall(60, r);
