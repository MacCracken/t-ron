    assert_eq(audit_chain_len(a),     2, "chain has 2 entries");
    assert_eq(audit_verify_chain(a),  0, "chain verifies");
    return 0;
}

fn test_chain_integrity_many_writes() {
    test_group("audit chain: 50 writes verify");
    var a = audit_logger_new();
    var c = _mk_audit_call("agent-1", "tool");
