fn test_chain_review_counts() {
    test_group("audit chain review");
    var a = audit_logger_new();
    var c = _mk_audit_call("web-agent", "tarang_probe");
    audit_log(a, c, verdict_allow());
    audit_log(a, c, _mk_deny());
