[package]
name = "t-ron"
version = "${file:VERSION}"
description = "MCP security monitor — tool call auditing, rate limiting, injection detection, anomaly analysis"
license = "GPL-3.0-only"
language = "cyrius"
cyrius = "6.1.24"
repository = "https://github.com/MacCracken/t-ron"

[build]
entry = "src/main.cyr"
output = "build/t-ron"

# Library distribution. Order mirrors the include order in src/main.cyr —
# critical for Cyrius's single-pass forward-reference resolution.
# `cyrius distlib` reads this section to produce dist/t-ron.cyr for
# downstream consumers (daimon, bote middleware, phylax). Kept under
# [lib] (not [build]) so tests/benches do not pull every module into
# their compilation unit via the manifest — they include only what
# they need.
#
# 2.1.3: dropped src/_libro_compat.cyr — libro 2.6.3's dist bundle
# now calls ct_eq_bytes_lens directly, so the ct_eq shim has no
# remaining caller.
[lib]
modules = [
    "src/error.cyr",
    "src/gate.cyr",
    "src/policy.cyr",
    "src/rate.cyr",
    "src/scanner.cyr",
    "src/pattern.cyr",
    "src/audit.cyr",
    "src/score.cyr",
    "src/query.cyr",
    "src/correlation.cyr",
    "src/tron.cyr",
    "src/tools.cyr",
    "src/middleware.cyr",
    "src/llm_scan.cyr",
    "src/signing.cyr",
    "src/signal.cyr",
    "src/crypto_chacha20.cyr",
    "src/safety.cyr",
]

# ── Dependencies ─────────────────────────────────────────────────
# Cyrius-stdlib modules. `cyrius deps` copies these from the
# version-pinned snapshot into ./lib/ (gitignored). The list mirrors
# the include order at the top of src/main.cyr so the manifest stays
# load-bearing.
[deps]
# Pure cyrius-stdlib modules. `sigil` and `sakshi` are intentionally
# NOT listed here even though src/main.cyr includes them — libro
# 2.7.2 pulls both transitively via [deps.sigil] (tag 3.7.8) and
# its own stdlib reference, so listing them here as well makes
# `cyrius deps` attempt two writes to lib/sigil.cyr / lib/sakshi.cyr.
# Locally the writes are byte-identical and silently succeed; in CI
# the second write errors with "cannot write lib/sigil.cyr". Mirrors
# the dep-chain bote/libro use.
#
# 2.1.3: added `slice` (libro 2.6.3 → agnosys 1.2.6 uses slice
# subscript syntax) and `keccak` / `random` (sigil 3.1.1 ML-DSA +
# AES-GCM surfaces reference `_keccak_*`, `shake256`, `random_bytes`).
# `ct` / `keccak` / `random` must precede the `sigil` include in
# src/main.cyr — single-pass forward-reference resolution. Mirrors
# bote 2.7.3's stdlib comment.
stdlib = [
    "string",
    "fmt",
    "alloc",
    "vec",
    "str",
    "slice",
    "syscalls",
    "io",
    "args",
    "tagged",
    "assert",
    "fnptr",
    "hashmap",
    "regex",
    "chrono",
    "freelist",
    "bigint",
    "json",
    "base64",
    "net",
    # atomic / thread / thread_local must precede sigil — sigil 3.7.8's
    # crypto path self-installs a per-thread TLS scratch bank
    # (`cbank()` → `thread_local_get`, cyrius ≥ 6.0.52) on the *serial*
    # hash path, and its parallel `sv_verify_batch` spawns
    # `thread_create`/`thread_join` workers. `thread` pulls `atomic`
    # (lock-free queue); without these the SHA-256 in libro's
    # `chain_append` traps with SIGILL. Mirrors bote 2.7.3's `thread`
    # addition. (2.1.5)
    "atomic",
    "thread",
    "thread_local",
    # ct / keccak / random must precede sigil — see comment above.
    "ct",
    "keccak",
    "random",
]

# libro audit chain — single-file dist bundle. libro 2.x uses
# `#derive(accessors)` to emit per-field getters (entry_hash,
# entry_prev_hash, …) that are referenced cross-module within
# libro itself; cyrius only resolves the derive macro when the
# full module set is preprocessed in dist-build order, so a
# per-module pull leaves the getters undefined at link time
# (silent — surfaces as a SIGILL inside `chain_verify`). The
# dist bundle bakes the accessor bodies in.
[deps.libro]
git = "https://github.com/MacCracken/libro"
path = "../libro"
tag = "2.7.2"
modules = ["dist/libro.cyr"]

# bote MCP core — opt-in `dist/bote-core.cyr` profile (bote 2.7.3).
# The nine transport-free modules (`error`, `protocol`, `jsonx`,
# `codec`, `registry`, `events`, `audit`, `dispatch`, `schema`)
# packaged as a single bundle via bote's `cyrius distlib core`
# profile. Excludes `transport_*` / `bridge` / `auth` / `session` /
# `discovery` / `content` / `host` / `audit_libro` / `events_majra`
# — the surface t-ron does not consume, and the surface that
# previously pushed our expanded source past cyrius's 2 MB
# compile-source cap when paired with libro's dist bundle.
#
# t-ron is the trigger consumer for the opt-in profile — see bote
# 2.7.2 CHANGELOG. Retires the nine-module cherry-pick that shipped
# at 2.1.0; replaces it with one bundle entry.
#
# Future: when cyrius lands the compile-source-size cap raise
# (proposal 2026-05-10), this block may flip to
# `modules = ["dist/bote.cyr"]` for consumers that want the full
# transport surface. bote-core remains the recommended pull for
# t-ron because t-ron itself never wires bote transports.
[deps.bote]
git = "https://github.com/MacCracken/bote"
path = "../bote"
tag = "2.7.3"
modules = ["dist/bote-core.cyr"]
