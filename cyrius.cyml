[package]
name = "t-ron"
version = "${file:VERSION}"
description = "MCP security monitor — tool call auditing, rate limiting, injection detection, anomaly analysis"
license = "GPL-3.0-only"
language = "cyrius"
cyrius = "5.10.34"
repository = "https://github.com/MacCracken/t-ron"

[build]
entry = "src/main.cyr"
output = "build/t-ron"

# Library distribution. Order mirrors the include order in src/main.cyr —
# critical for Cyrius's single-pass forward-reference resolution.
# `cyrius distlib` reads this section to produce dist/t-ron.cyr for
# downstream consumers (daimon, bote middleware, phylax) once 2.1.2
# ships the bundle. Kept under [lib] (not [build]) so tests/benches
# do not pull every module into their compilation unit via the
# manifest — they include only what they need.
[lib]
modules = [
    "src/_libro_compat.cyr",
    "src/error.cyr",
    "src/gate.cyr",
    "src/policy.cyr",
    "src/rate.cyr",
    "src/scanner.cyr",
    "src/pattern.cyr",
    "src/audit.cyr",
    "src/score.cyr",
    "src/query.cyr",
    "src/correlation.cyr",
    "src/tron.cyr",
    "src/tools.cyr",
    "src/middleware.cyr",
    "src/llm_scan.cyr",
    "src/signing.cyr",
    "src/signal.cyr",
    "src/crypto_chacha20.cyr",
    "src/safety.cyr",
]

# ── Dependencies ─────────────────────────────────────────────────
# Cyrius-stdlib modules. `cyrius deps` copies these from the
# version-pinned snapshot into ./lib/ (gitignored). The list mirrors
# the include order at the top of src/main.cyr so the manifest stays
# load-bearing.
[deps]
stdlib = [
    "string",
    "fmt",
    "alloc",
    "vec",
    "str",
    "syscalls",
    "io",
    "args",
    "tagged",
    "assert",
    "fnptr",
    "hashmap",
    "regex",
    "chrono",
    "freelist",
    "sakshi",
    "bigint",
    "json",
    "base64",
    "sigil",
    "net",
    # `ct` is required by lib/libro.cyr — libro 2.6.2's
    # constant_time_eq_str delegates to cyrius stdlib's
    # ct_eq_bytes_lens via the t-ron-side compat shim
    # (src/_libro_compat.cyr).
    "ct",
]

# libro audit chain — single-file dist bundle. libro 2.x uses
# `#derive(accessors)` to emit per-field getters (entry_hash,
# entry_prev_hash, …) that are referenced cross-module within
# libro itself; cyrius only resolves the derive macro when the
# full module set is preprocessed in dist-build order, so a
# per-module pull leaves the getters undefined at link time
# (silent — surfaces as a SIGILL inside `chain_verify`). The
# dist bundle bakes the accessor bodies in.
[deps.libro]
git = "https://github.com/MacCracken/libro"
path = "../libro"
tag = "2.6.2"
modules = ["dist/libro.cyr"]

# bote MCP core — per-module pull. bote's single dist bundle drags
# the full transport stack (sandhi 11k lines, tls, ws_server)
# which pushes t-ron's expanded source past cyrius's 2 MB compile
# cap when paired with libro's dist bundle. t-ron only uses bote's
# Dispatcher + tool-registry surface, so the nine-module cherry-pick
# stays under the cap. Handler ABI changed in bote 2.0
# (fn h(args, claims)); 2.1.0 lands that observance — see
# src/tools.cyr and src/middleware.cyr. Dist-bundle adoption is
# parked as a later 2.1.x candidate gated on either a cyrius cap
# raise or a bote opt-in profile that excludes transports.
[deps.bote]
git = "https://github.com/MacCracken/bote"
path = "../bote"
tag = "2.7.1"
modules = [
    "src/error.cyr",
    "src/protocol.cyr",
    "src/jsonx.cyr",
    "src/codec.cyr",
    "src/registry.cyr",
    "src/events.cyr",
    "src/audit.cyr",
    "src/dispatch.cyr",
    "src/schema.cyr",
]
