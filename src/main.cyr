# t-ron — MCP security monitor (Cyrius port)
#
# 2.1.x — modernization arc. 2.1.3 picks up cyrius 5.10.44 +
# libro 2.6.3 + bote 2.7.2 and flips [deps.bote] to the opt-in
# dist/bote-core.cyr bundle (the consumer-side fix for the
# 2 MB compile-source cap that previously blocked the dist
# adoption). The src/_libro_compat.cyr shim retires here —
# libro 2.6.3's dist bundle calls ct_eq_bytes_lens directly.
# See docs/development/roadmap.md.

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/vec.cyr"
include "lib/str.cyr"
include "lib/slice.cyr"
include "lib/syscalls.cyr"
include "lib/io.cyr"
include "lib/args.cyr"
include "lib/tagged.cyr"
include "lib/assert.cyr"
include "lib/fnptr.cyr"
include "lib/hashmap.cyr"
include "lib/regex.cyr"
include "lib/chrono.cyr"
include "lib/freelist.cyr"
include "lib/sakshi.cyr"
include "lib/bigint.cyr"
include "lib/json.cyr"
include "lib/base64.cyr"
include "lib/net.cyr"
# ct / keccak / random must precede sigil — sigil 3.1.1's
# ML-DSA + AES-GCM surfaces reference ct_eq_bytes_lens /
# ct_select / _keccak_* / shake256 / random_bytes, and cyrius
# is single-pass.
include "lib/ct.cyr"
include "lib/keccak.cyr"
include "lib/random.cyr"
include "lib/sigil.cyr"

include "lib/libro.cyr"

# bote opt-in core bundle — 9 transport-free modules. Replaces the
# per-module cherry-pick shipped at 2.1.0–2.1.2 with a single
# include. See cyrius.cyml [deps.bote] for the rationale.
include "lib/bote-core.cyr"

include "src/error.cyr"
include "src/gate.cyr"
include "src/policy.cyr"
include "src/rate.cyr"
include "src/scanner.cyr"
include "src/pattern.cyr"
include "src/audit.cyr"
include "src/score.cyr"
include "src/query.cyr"
include "src/correlation.cyr"
include "src/tron.cyr"
include "src/tools.cyr"
include "src/middleware.cyr"
include "src/llm_scan.cyr"
include "src/signing.cyr"
include "src/signal.cyr"
include "src/crypto_chacha20.cyr"
include "src/safety.cyr"

fn main() {
    alloc_init();
    println("t-ron ready");
    return 0;
}

var r = main();
syscall(60, r);
