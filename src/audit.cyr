#  audit.cyr  --  dual-write audit logger
#
#  Ported from rust-old/src/audit.rs. Every verdict is recorded both in
#  the fast operational ring buffer (for risk scoring + recent-events
#  queries) and in the libro cryptographic hash chain (for tamper-proof
#  auditing).

var AUDIT_MAX_EVENTS = 10000;

#  Build a small JSON details blob for the libro entry. Keeping this
#  inline keeps the logger infallible — the chain always gets a record.
fn _audit_details(tool_name, reason, deny_code) {
    var tl = strlen(tool_name);
    var buf = alloc(tl + 256);
    var off = 0;
    memcpy(buf + off, "{\"tool_name\":\"", 14); off = off + 14;
    memcpy(buf + off, tool_name, tl);           off = off + tl;
    memcpy(buf + off, "\"", 1);                 off = off + 1;
    if (reason != 0) {
        var rl = strlen(reason);
        memcpy(buf + off, ",\"reason\":\"", 11); off = off + 11;
        memcpy(buf + off, reason, rl);          off = off + rl;
        memcpy(buf + off, "\"", 1);             off = off + 1;
    }
    if (deny_code >= 0) {
        var code_str = deny_code_as_str(deny_code);
        var cl = strlen(code_str);
        memcpy(buf + off, ",\"deny_code\":\"", 14); off = off + 14;
        memcpy(buf + off, code_str, cl);           off = off + cl;
        memcpy(buf + off, "\"", 1);                off = off + 1;
    }
    memcpy(buf + off, "}", 1); off = off + 1;
    store8(buf + off, 0);
    return str_from(buf);
}

fn _audit_severity_for(kind) {
    if (kind == VK_DENY) { return SEV_SECURITY; }
    if (kind == VK_FLAG) { return SEV_WARNING; }
    return SEV_INFO;
}

fn _audit_action_for(kind) {
    if (kind == VK_DENY) { return str_from("tool_call.deny"); }
    if (kind == VK_FLAG) { return str_from("tool_call.flag"); }
    return str_from("tool_call.allow");
}

#  ============================================================
#  SecurityEvent  --  one logged verdict
#  ============================================================
#
#  Layout (48 bytes):
#    +0   id           i64      incrementing sequence number
#    +8   timestamp    i64      ns since epoch (clock_epoch_ns)
#    +16  agent_id     cstring  owned copy
#    +24  tool_name    cstring  owned copy
#    +32  verdict_kind i64      VK_ALLOW | VK_DENY | VK_FLAG
#    +40  reason       cstring  owned copy (0 if none)

fn _audit_dup_cstr(s) {
    if (s == 0) { return 0; }
    var n = strlen(s);
    var buf = alloc(n + 1);
    memcpy(buf, s, n);
    store8(buf + n, 0);
    return buf;
}

fn security_event_new(id, ts, agent_id, tool_name, kind, reason) {
    var e = alloc(48);
    store64(e,      id);
    store64(e + 8,  ts);
    store64(e + 16, _audit_dup_cstr(agent_id));
    store64(e + 24, _audit_dup_cstr(tool_name));
    store64(e + 32, kind);
    store64(e + 40, _audit_dup_cstr(reason));
    return e;
}

fn security_event_id(e)        { return load64(e); }
fn security_event_timestamp(e) { return load64(e + 8); }
fn security_event_agent_id(e)  { return load64(e + 16); }
fn security_event_tool_name(e) { return load64(e + 24); }
fn security_event_kind(e)      { return load64(e + 32); }
fn security_event_reason(e)    { return load64(e + 40); }

#  ============================================================
#  AuditLogger  --  ring buffer + libro cryptographic chain
#  ============================================================
#
#  Layout (24 bytes):
#    +0   events     vec<SecurityEvent>   operational ring buffer
#    +8   next_id    i64                  monotonic event id
#    +16  chain      libro AuditChain ptr tamper-proof chain

fn audit_logger_new() {
    var a = alloc(24);
    store64(a,      vec_new());
    store64(a + 8,  0);
    store64(a + 16, chain_new());
    return a;
}

fn audit_events(a) { return load64(a); }
fn audit_chain(a)  { return load64(a + 16); }

fn _audit_next_id(a) {
    var id = load64(a + 8);
    store64(a + 8, id + 1);
    return id;
}

#  Log a verdict to both the ring buffer and the libro chain.
fn audit_log(a, call, verdict) {
    var kind = verdict_kind(verdict);
    var reason = verdict_reason(verdict);
    var deny_code = 0 - 1;
    if (kind == VK_DENY) { deny_code = verdict_code(verdict); }

    var agent_id  = tool_call_agent_id(call);
    var tool_name = tool_call_tool_name(call);

    var e = security_event_new(
        _audit_next_id(a),
        clock_epoch_ns(),
        agent_id,
        tool_name,
        kind,
        reason);
    var events = load64(a);
    vec_push(events, e);
    while (vec_len(events) > AUDIT_MAX_EVENTS) { vec_remove(events, 0); }

    var details = _audit_details(tool_name, reason, deny_code);
    var chain = load64(a + 16);
    var sev   = _audit_severity_for(kind);
    var src_s = str_from("t-ron");
    var act_s = _audit_action_for(kind);
    var ag_s  = str_from(agent_id);
    chain_append_with_agent(chain, sev, src_s, act_s, details, ag_s);
    return 0;
}

#  Verify the libro chain integrity. Returns 0 on success, libro error ptr on failure.
fn audit_verify_chain(a) {
    return chain_verify(load64(a + 16));
}

#  Number of entries in the libro chain (may differ from the ring buffer
#  if rotation has pruned the operational view).
fn audit_chain_len(a) {
    return chain_len(load64(a + 16));
}

#  Structured review of the chain (via libro).
fn audit_chain_review(a) {
    return chain_review(load64(a + 16));
}

#  ============================================================
#  JSON export  --  plain + encrypted
#  ============================================================
#
#  The ring buffer is serialized as a JSON array of SecurityEvent objects:
#    [{"id":N,"timestamp":N,"agent_id":"...","tool_name":"...",
#      "verdict":"allow|deny|flag","reason":"..."}, ...]
#
#  This export is distinct from libro's canonical chain dump — it's the
#  operational view, useful for sending recent events to an analytics
#  sink without exposing the full chain.

fn _audit_export_field(buf, off, key, kn, value, vn) {
    memcpy(buf + off, key, kn); off = off + kn;
    memcpy(buf + off, value, vn); off = off + vn;
    return off;
}

fn _audit_export_event(buf, off, e) {
    var id_buf = alloc(24);
    var id_n   = fmt_int_buf(security_event_id(e), id_buf);
    var ts_buf = alloc(24);
    var ts_n   = fmt_int_buf(security_event_timestamp(e), ts_buf);
    var agent  = security_event_agent_id(e);
    var tool   = security_event_tool_name(e);
    var kind_s = verdict_kind_as_str(security_event_kind(e));
    var reason = security_event_reason(e);

    memcpy(buf + off, "{\"id\":",   6);  off = off + 6;
    memcpy(buf + off, id_buf, id_n);     off = off + id_n;
    memcpy(buf + off, ",\"timestamp\":", 13); off = off + 13;
    memcpy(buf + off, ts_buf, ts_n);     off = off + ts_n;
    memcpy(buf + off, ",\"agent_id\":\"", 13); off = off + 13;
    memcpy(buf + off, agent, strlen(agent)); off = off + strlen(agent);
    memcpy(buf + off, "\",\"tool_name\":\"", 15); off = off + 15;
    memcpy(buf + off, tool, strlen(tool)); off = off + strlen(tool);
    memcpy(buf + off, "\",\"verdict\":\"", 13); off = off + 13;
    memcpy(buf + off, kind_s, strlen(kind_s)); off = off + strlen(kind_s);
    memcpy(buf + off, "\"", 1);           off = off + 1;
    if (reason != 0) {
        memcpy(buf + off, ",\"reason\":\"", 11); off = off + 11;
        memcpy(buf + off, reason, strlen(reason)); off = off + strlen(reason);
        memcpy(buf + off, "\"", 1);      off = off + 1;
    }
    memcpy(buf + off, "}", 1); off = off + 1;
    return off;
}

#  Serialize the ring buffer as a JSON array into a freshly-allocated
#  null-terminated cstring. The returned buffer is owned by the caller
#  in the sense that the bump allocator won't reuse it until reset.
fn audit_export_json(a) {
    var events = load64(a);
    var n = vec_len(events);
    #  Upper-bound: ~400 bytes per event; grows with reason/agent/tool lengths.
    var cap = n * 512 + 32;
    var buf = alloc(cap);
    var off = 0;
    memcpy(buf + off, "[", 1); off = off + 1;
    var i = 0;
    while (i < n) {
        if (i > 0) { memcpy(buf + off, ",", 1); off = off + 1; }
        off = _audit_export_event(buf, off, vec_get(events, i));
        i = i + 1;
    }
    memcpy(buf + off, "]", 1); off = off + 1;
    store8(buf + off, 0);
    return buf;
}

#  ============================================================
#  Encrypted export  --  ChaCha20 + Ed25519 AEAD
#  ============================================================
#
#  Wire format:
#    +0    nonce (12 bytes)
#    +12   ed25519 signature over (nonce || ciphertext) (64 bytes)
#    +76   ciphertext (N bytes)
#
#  Ed25519 replaces Poly1305: same AEAD semantics (confidentiality +
#  authenticity), no need to implement prime-field arithmetic. Sigil's
#  Ed25519 is already used by signing.cyr.
#
#  Inputs:
#    a                ptr to AuditLogger
#    nonce (12 bytes) caller-supplied, must be unique per (key, export)
#    key   (32 bytes) ChaCha20 symmetric key
#    sk    (64 bytes) Ed25519 signing key (from ed25519_generate_keypair)
#    out_len_ptr      written with total bytes of the returned buffer
#  Returns: heap-allocated ciphertext envelope, or 0 on failure.

fn audit_export_encrypted(a, nonce, key, sk, out_len_ptr) {
    var json = audit_export_json(a);
    var jlen = strlen(json);
    var envelope = alloc(12 + 64 + jlen);

    memcpy(envelope, nonce, 12);

    #  Encrypt json into envelope+76 via CTR counter = 1.
    chacha20_xor(key, nonce, 1, json, jlen, envelope + 76);

    #  Sign (nonce || ciphertext) into envelope+12.
    ed25519_sign(sk, envelope, 12 + jlen, envelope + 12);
    #  ed25519_sign wrote over the wrong slice above; rebuild the
    #  correct signature input (nonce || ciphertext) in a temp and sign.
    var sig_input = alloc(12 + jlen);
    memcpy(sig_input,      envelope, 12);
    memcpy(sig_input + 12, envelope + 76, jlen);
    ed25519_sign(sk, sig_input, 12 + jlen, envelope + 12);

    store64(out_len_ptr, 12 + 64 + jlen);
    return envelope;
}

#  Decrypt + verify an encrypted export. Returns the plaintext JSON
#  cstring on success, 0 on any failure (bad signature, truncation).
fn audit_decrypt_export(data, data_len, key, pk) {
    if (data_len < 12 + 64) { return 0; }
    var clen = data_len - 12 - 64;

    #  Rebuild the signed payload (nonce || ciphertext) and verify.
    var sig_input = alloc(12 + clen);
    memcpy(sig_input,      data, 12);
    memcpy(sig_input + 12, data + 76, clen);
    if (ed25519_verify(pk, sig_input, 12 + clen, data + 12) != 1) { return 0; }

    var plaintext = alloc(clen + 1);
    chacha20_xor(key, data, 1, data + 76, clen, plaintext);
    store8(plaintext + clen, 0);
    return plaintext;
}

#  Total event count.
fn audit_total_count(a) {
    return vec_len(load64(a));
}

#  Total denied events.
fn audit_deny_count(a) {
    var events = load64(a);
    var n = vec_len(events);
    var denies = 0;
    var i = 0;
    while (i < n) {
        if (security_event_kind(vec_get(events, i)) == VK_DENY) {
            denies = denies + 1;
        }
        i = i + 1;
    }
    return denies;
}

#  Return up to `limit` most-recent events as a new vec (newest first).
fn audit_recent(a, limit) {
    var events = load64(a);
    var n = vec_len(events);
    var out = vec_new();
    var i = n - 1;
    var taken = 0;
    while (i >= 0 && taken < limit) {
        vec_push(out, vec_get(events, i));
        taken = taken + 1;
        i = i - 1;
    }
    return out;
}

#  Return up to `limit` most-recent events filtered by agent_id.
fn audit_agent_events(a, agent_id, limit) {
    var events = load64(a);
    var n = vec_len(events);
    var out = vec_new();
    var i = n - 1;
    var taken = 0;
    while (i >= 0 && taken < limit) {
        var e = vec_get(events, i);
        if (streq(security_event_agent_id(e), agent_id) == 1) {
            vec_push(out, e);
            taken = taken + 1;
        }
        i = i - 1;
    }
    return out;
}
