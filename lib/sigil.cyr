# sigil.cyr — system-wide trust verification for AGNOS
# Bundled distribution of sigil v2.1.2
# Source: https://github.com/MacCracken/sigil
# License: GPL-3.0-only
#
# Usage: include "lib/sigil.cyr"
# Init:  alloc_init(); ed25519_init();


# --- types.cyr ---

# types.cyr — sigil type system
# Enums, structs, constructors, accessors for the trust verification module.

# ================================================================
# SignatureAlgorithm
# ================================================================

enum SignatureAlgorithm {
    SIG_ALG_ED25519 = 0;
    SIG_ALG_ML_DSA_65 = 1;
    SIG_ALG_HYBRID = 2;
}

fn sig_alg_name(alg) {
    if (alg == SIG_ALG_ED25519) { return "Ed25519"; }
    if (alg == SIG_ALG_ML_DSA_65) { return "ML-DSA-65"; }
    if (alg == SIG_ALG_HYBRID) { return "Hybrid(Ed25519+ML-DSA-65)"; }
    return "unknown";
}

# ================================================================
# HashAlgorithm
# ================================================================

enum HashAlgorithm {
    HASH_ALG_SHA256 = 0;
    HASH_ALG_SHA512 = 1;
}

fn hash_alg_name(alg) {
    if (alg == HASH_ALG_SHA256) { return "SHA-256"; }
    if (alg == HASH_ALG_SHA512) { return "SHA-512"; }
    return "unknown";
}

# ================================================================
# TrustLevel
# ================================================================
# Ordered from highest trust to lowest conceptually.
# Rank: SystemCore(4) > Verified(3) > Community(2) > Unverified(1) > Revoked(0)

enum TrustLevel {
    TRUST_SYSTEM_CORE = 0;
    TRUST_VERIFIED = 1;
    TRUST_COMMUNITY = 2;
    TRUST_UNVERIFIED = 3;
    TRUST_REVOKED = 4;
}

fn trust_level_rank(level) {
    if (level == TRUST_SYSTEM_CORE) { return 4; }
    if (level == TRUST_VERIFIED) { return 3; }
    if (level == TRUST_COMMUNITY) { return 2; }
    if (level == TRUST_UNVERIFIED) { return 1; }
    if (level == TRUST_REVOKED) { return 0; }
    return 0;
}

fn trust_level_ge(a, b) {
    if (trust_level_rank(a) >= trust_level_rank(b)) { return 1; }
    return 0;
}

fn trust_level_gt(a, b) {
    if (trust_level_rank(a) > trust_level_rank(b)) { return 1; }
    return 0;
}

fn trust_level_name(level) {
    if (level == TRUST_SYSTEM_CORE) { return "SystemCore"; }
    if (level == TRUST_VERIFIED) { return "Verified"; }
    if (level == TRUST_COMMUNITY) { return "Community"; }
    if (level == TRUST_UNVERIFIED) { return "Unverified"; }
    if (level == TRUST_REVOKED) { return "Revoked"; }
    return "unknown";
}

# ================================================================
# TrustEnforcement
# ================================================================

enum TrustEnforcement {
    ENFORCE_STRICT = 0;
    ENFORCE_PERMISSIVE = 1;
    ENFORCE_AUDIT_ONLY = 2;
}

fn enforcement_name(mode) {
    if (mode == ENFORCE_STRICT) { return "Strict"; }
    if (mode == ENFORCE_PERMISSIVE) { return "Permissive"; }
    if (mode == ENFORCE_AUDIT_ONLY) { return "AuditOnly"; }
    return "unknown";
}

# ================================================================
# ArtifactType
# ================================================================

enum ArtifactType {
    ARTIFACT_AGENT_BINARY = 0;
    ARTIFACT_SYSTEM_BINARY = 1;
    ARTIFACT_CONFIG = 2;
    ARTIFACT_PACKAGE = 3;
    ARTIFACT_BOOT_COMPONENT = 4;
}

fn artifact_type_name(t) {
    if (t == ARTIFACT_AGENT_BINARY) { return "AgentBinary"; }
    if (t == ARTIFACT_SYSTEM_BINARY) { return "SystemBinary"; }
    if (t == ARTIFACT_CONFIG) { return "Config"; }
    if (t == ARTIFACT_PACKAGE) { return "Package"; }
    if (t == ARTIFACT_BOOT_COMPONENT) { return "BootComponent"; }
    return "unknown";
}

# ================================================================
# TrustPolicy (64 bytes)
# ================================================================
# Layout:
#   +0   enforcement        (i64)
#   +8   minimum_trust_level (i64)
#   +16  allow_unsigned     (i64, 0=false 1=true)
#   +24  verify_on_boot     (i64)
#   +32  verify_on_install  (i64)
#   +40  verify_on_execute  (i64)
#   +48  revocation_check   (i64)
#   +56  hash_algorithm     (i64)

fn trust_policy_new() {
    var p = fl_alloc(64);
    store64(p, ENFORCE_STRICT);
    store64(p + 8, TRUST_VERIFIED);
    store64(p + 16, 0);
    store64(p + 24, 1);
    store64(p + 32, 1);
    store64(p + 40, 1);
    store64(p + 48, 1);
    store64(p + 56, HASH_ALG_SHA256);
    return p;
}

fn policy_enforcement(p) { return load64(p); }
fn policy_min_trust(p) { return load64(p + 8); }
fn policy_allow_unsigned(p) { return load64(p + 16); }
fn policy_verify_on_boot(p) { return load64(p + 24); }
fn policy_verify_on_install(p) { return load64(p + 32); }
fn policy_verify_on_execute(p) { return load64(p + 40); }
fn policy_revocation_check(p) { return load64(p + 48); }
fn policy_hash_alg(p) { return load64(p + 56); }

fn policy_set_enforcement(p, v) { store64(p, v); return p; }
fn policy_set_min_trust(p, v) { store64(p + 8, v); return p; }
fn policy_set_allow_unsigned(p, v) { store64(p + 16, v); return p; }
fn policy_set_verify_on_boot(p, v) { store64(p + 24, v); return p; }
fn policy_set_verify_on_install(p, v) { store64(p + 32, v); return p; }
fn policy_set_verify_on_execute(p, v) { store64(p + 40, v); return p; }
fn policy_set_revocation_check(p, v) { store64(p + 48, v); return p; }
fn policy_set_hash_alg(p, v) { store64(p + 56, v); return p; }

fn trust_policy_free(p) { fl_free(p); return 0; }

# ================================================================
# TrustCheck (24 bytes)
# ================================================================
# Layout:
#   +0   name     (C-string pointer)
#   +8   passed   (i64, 0 or 1)
#   +16  detail   (C-string pointer)

fn trust_check_new(name, passed, detail) {
    var tc = fl_alloc(24);
    store64(tc, name);
    store64(tc + 8, passed);
    store64(tc + 16, detail);
    return tc;
}

fn check_name(tc) { return load64(tc); }
fn check_passed(tc) { return load64(tc + 8); }
fn check_detail(tc) { return load64(tc + 16); }
fn trust_check_free(tc) { fl_free(tc); return 0; }

# ================================================================
# Cosignature (16 bytes)
# ================================================================
# Layout:
#   +0   key_id      (C-string pointer)
#   +8   signature   (pointer to raw bytes)

fn cosignature_new(key_id, sig_ptr) {
    var cs = fl_alloc(16);
    store64(cs, key_id);
    store64(cs + 8, sig_ptr);
    return cs;
}

fn cosig_key_id(cs) { return load64(cs); }
fn cosig_signature(cs) { return load64(cs + 8); }

# ================================================================
# TrustedArtifact (96 bytes)
# ================================================================
# Layout:
#   +0   path              (C-string pointer)
#   +8   artifact_type     (i64)
#   +16  content_hash      (C-string pointer, hex)
#   +24  signature         (pointer to raw bytes, 0 = none)
#   +32  signature_len     (i64)
#   +40  signature_algorithm (i64)
#   +48  signer_key_id     (C-string pointer, 0 = none)
#   +56  trust_level       (i64)
#   +64  verified_at       (i64, epoch seconds, 0 = never)
#   +72  metadata          (hashmap pointer, 0 = none)
#   +80  cosigners         (vec pointer, 0 = none)
#   +88  cosigner_count    (i64)

fn trusted_artifact_new(path, artifact_type, content_hash) {
    var a = fl_alloc(96);
    store64(a, path);
    store64(a + 8, artifact_type);
    store64(a + 16, content_hash);
    store64(a + 24, 0);
    store64(a + 32, 0);
    store64(a + 40, SIG_ALG_ED25519);
    store64(a + 48, 0);
    store64(a + 56, TRUST_UNVERIFIED);
    store64(a + 64, 0);
    store64(a + 72, 0);
    store64(a + 80, 0);
    store64(a + 88, 0);
    return a;
}

fn artifact_path(a) { return load64(a); }
fn artifact_type(a) { return load64(a + 8); }
fn artifact_content_hash(a) { return load64(a + 16); }
fn artifact_signature(a) { return load64(a + 24); }
fn artifact_signature_len(a) { return load64(a + 32); }
fn artifact_sig_alg(a) { return load64(a + 40); }
fn artifact_signer_key_id(a) { return load64(a + 48); }
fn artifact_trust_level(a) { return load64(a + 56); }
fn artifact_verified_at(a) { return load64(a + 64); }
fn artifact_metadata(a) { return load64(a + 72); }
fn artifact_cosigners(a) { return load64(a + 80); }
fn artifact_cosigner_count(a) { return load64(a + 88); }

fn artifact_set_signature(a, sig, sig_len) {
    store64(a + 24, sig);
    store64(a + 32, sig_len);
    return a;
}
fn artifact_set_sig_alg(a, alg) { store64(a + 40, alg); return a; }
fn artifact_set_signer(a, key_id) { store64(a + 48, key_id); return a; }
fn artifact_set_trust_level(a, level) { store64(a + 56, level); return a; }
fn artifact_set_verified_at(a, epoch) { store64(a + 64, epoch); return a; }
fn artifact_set_metadata(a, m) { store64(a + 72, m); return a; }

fn artifact_add_cosigner(a, cs) {
    var cosigners = load64(a + 80);
    if (cosigners == 0) {
        cosigners = vec_new();
        store64(a + 80, cosigners);
    }
    vec_push(cosigners, cs);
    store64(a + 88, load64(a + 88) + 1);
    return a;
}

# ================================================================
# VerificationResult (32 bytes)
# ================================================================
# Layout:
#   +0   artifact     (TrustedArtifact pointer)
#   +8   passed       (i64)
#   +16  checks       (vec of TrustCheck pointers)
#   +24  verified_at  (i64, epoch seconds)

fn verification_result_new(artifact, passed, verified_at) {
    var vr = fl_alloc(32);
    store64(vr, artifact);
    store64(vr + 8, passed);
    store64(vr + 16, vec_new());
    store64(vr + 24, verified_at);
    return vr;
}

fn vresult_artifact(vr) { return load64(vr); }
fn vresult_passed(vr) { return load64(vr + 8); }
fn vresult_checks(vr) { return load64(vr + 16); }
fn vresult_verified_at(vr) { return load64(vr + 24); }

fn vresult_add_check(vr, tc) {
    vec_push(load64(vr + 16), tc);
    return vr;
}

fn vresult_set_passed(vr, passed) {
    store64(vr + 8, passed);
    return vr;
}

# ================================================================
# SigilStats (40 bytes)
# ================================================================
# Layout:
#   +0   total_artifacts   (i64)
#   +8   verified_count    (i64)
#   +16  revoked_count     (i64)
#   +24  trust_level_counts (hashmap pointer)

fn sigil_stats_new() {
    var s = fl_alloc(32);
    store64(s, 0);
    store64(s + 8, 0);
    store64(s + 16, 0);
    store64(s + 24, 0);
    return s;
}

fn stats_total(s) { return load64(s); }
fn stats_verified(s) { return load64(s + 8); }
fn stats_revoked(s) { return load64(s + 16); }
fn stats_counts(s) { return load64(s + 24); }

# --- error.cyr ---

# error.cyr — sigil error codes and error construction
# Follows packed-struct pattern (like sakshi) for error objects.

# ================================================================
# Error codes
# ================================================================

enum SigilError {
    ERR_NONE = 0;
    ERR_KEY_NOT_FOUND = 1;
    ERR_SIGNATURE_INVALID = 2;
    ERR_REVOCATION = 3;
    ERR_INTEGRITY_MISMATCH = 4;
    ERR_INVALID_INPUT = 5;
    ERR_IO = 6;
    ERR_SERIALIZATION = 7;
    ERR_CRYPTO = 8;
}

# ================================================================
# Error predicates
# ================================================================

fn sigil_is_ok(code) {
    if (code == ERR_NONE) { return 1; }
    return 0;
}

fn sigil_is_err(code) {
    if (code != ERR_NONE) { return 1; }
    return 0;
}

# ================================================================
# Error object (16 bytes)
# ================================================================
# Layout:
#   +0   code   (i64, ERR_* constant)
#   +8   msg    (C-string pointer)

fn sigil_err(code, msg) {
    var e = fl_alloc(16);
    store64(e, code);
    store64(e + 8, msg);
    return e;
}

fn sigil_err_code(e) { return load64(e); }
fn sigil_err_msg(e) { return load64(e + 8); }
fn sigil_err_free(e) { fl_free(e); return 0; }

# ================================================================
# Named error constructors
# ================================================================

fn err_key_not_found(key_id) {
    return sigil_err(ERR_KEY_NOT_FOUND, key_id);
}

fn err_sig_invalid(detail) {
    return sigil_err(ERR_SIGNATURE_INVALID, detail);
}

fn err_revocation(subject, reason) {
    # Store both pointers in a larger error struct
    var e = fl_alloc(24);
    store64(e, ERR_REVOCATION);
    store64(e + 8, subject);
    store64(e + 16, reason);
    return e;
}

fn err_integrity(path, expected, actual) {
    var e = fl_alloc(32);
    store64(e, ERR_INTEGRITY_MISMATCH);
    store64(e + 8, path);
    store64(e + 16, expected);
    store64(e + 24, actual);
    return e;
}

fn err_invalid_input(detail) {
    return sigil_err(ERR_INVALID_INPUT, detail);
}

fn err_io(detail) {
    return sigil_err(ERR_IO, detail);
}

fn err_serialization(detail) {
    return sigil_err(ERR_SERIALIZATION, detail);
}

fn err_crypto(detail) {
    return sigil_err(ERR_CRYPTO, detail);
}

# ================================================================
# Error name for display
# ================================================================

fn sigil_err_name(code) {
    if (code == ERR_NONE) { return "ok"; }
    if (code == ERR_KEY_NOT_FOUND) { return "key_not_found"; }
    if (code == ERR_SIGNATURE_INVALID) { return "signature_invalid"; }
    if (code == ERR_REVOCATION) { return "revocation_violation"; }
    if (code == ERR_INTEGRITY_MISMATCH) { return "integrity_mismatch"; }
    if (code == ERR_INVALID_INPUT) { return "invalid_input"; }
    if (code == ERR_IO) { return "io_error"; }
    if (code == ERR_SERIALIZATION) { return "serialization_error"; }
    if (code == ERR_CRYPTO) { return "crypto_error"; }
    return "unknown";
}

# --- sha256.cyr ---

# sha256.cyr — FIPS 180-4 SHA-256 implementation
# All arithmetic masked to 32 bits. Working state in globals
# to survive nested function calls (Cyrius compiler constraint).

var MASK32 = 0xFFFFFFFF;

# ================================================================
# Bitwise helpers (32-bit)
# ================================================================

fn rotr32(x, n) {
    return ((x >> n) | ((x << (32 - n)) & MASK32)) & MASK32;
}

fn shr32(x, n) {
    return (x >> n) & MASK32;
}

# ================================================================
# SHA-256 sub-functions
# ================================================================

fn sha256_ch(x, y, z) {
    return ((x & y) ^ ((x ^ MASK32) & z)) & MASK32;
}

fn sha256_maj(x, y, z) {
    return ((x & y) ^ (x & z) ^ (y & z)) & MASK32;
}

fn sha256_bsig0(x) {
    return (rotr32(x, 2) ^ rotr32(x, 13) ^ rotr32(x, 22)) & MASK32;
}

fn sha256_bsig1(x) {
    return (rotr32(x, 6) ^ rotr32(x, 11) ^ rotr32(x, 25)) & MASK32;
}

fn sha256_ssig0(x) {
    return (rotr32(x, 7) ^ rotr32(x, 18) ^ shr32(x, 3)) & MASK32;
}

fn sha256_ssig1(x) {
    return (rotr32(x, 17) ^ rotr32(x, 19) ^ shr32(x, 10)) & MASK32;
}

# ================================================================
# Round constants K[0..63] and initialization
# ================================================================

var _sha256_K = 0;
var _sha256_W = 0;
var _sha256_inited = 0;

fn sha256_global_init() {
    if (_sha256_inited == 1) { return 0; }

    _sha256_K = alloc(512);
    store64(_sha256_K + 0, 0x428a2f98);
    store64(_sha256_K + 8, 0x71374491);
    store64(_sha256_K + 16, 0xb5c0fbcf);
    store64(_sha256_K + 24, 0xe9b5dba5);
    store64(_sha256_K + 32, 0x3956c25b);
    store64(_sha256_K + 40, 0x59f111f1);
    store64(_sha256_K + 48, 0x923f82a4);
    store64(_sha256_K + 56, 0xab1c5ed5);
    store64(_sha256_K + 64, 0xd807aa98);
    store64(_sha256_K + 72, 0x12835b01);
    store64(_sha256_K + 80, 0x243185be);
    store64(_sha256_K + 88, 0x550c7dc3);
    store64(_sha256_K + 96, 0x72be5d74);
    store64(_sha256_K + 104, 0x80deb1fe);
    store64(_sha256_K + 112, 0x9bdc06a7);
    store64(_sha256_K + 120, 0xc19bf174);
    store64(_sha256_K + 128, 0xe49b69c1);
    store64(_sha256_K + 136, 0xefbe4786);
    store64(_sha256_K + 144, 0x0fc19dc6);
    store64(_sha256_K + 152, 0x240ca1cc);
    store64(_sha256_K + 160, 0x2de92c6f);
    store64(_sha256_K + 168, 0x4a7484aa);
    store64(_sha256_K + 176, 0x5cb0a9dc);
    store64(_sha256_K + 184, 0x76f988da);
    store64(_sha256_K + 192, 0x983e5152);
    store64(_sha256_K + 200, 0xa831c66d);
    store64(_sha256_K + 208, 0xb00327c8);
    store64(_sha256_K + 216, 0xbf597fc7);
    store64(_sha256_K + 224, 0xc6e00bf3);
    store64(_sha256_K + 232, 0xd5a79147);
    store64(_sha256_K + 240, 0x06ca6351);
    store64(_sha256_K + 248, 0x14292967);
    store64(_sha256_K + 256, 0x27b70a85);
    store64(_sha256_K + 264, 0x2e1b2138);
    store64(_sha256_K + 272, 0x4d2c6dfc);
    store64(_sha256_K + 280, 0x53380d13);
    store64(_sha256_K + 288, 0x650a7354);
    store64(_sha256_K + 296, 0x766a0abb);
    store64(_sha256_K + 304, 0x81c2c92e);
    store64(_sha256_K + 312, 0x92722c85);
    store64(_sha256_K + 320, 0xa2bfe8a1);
    store64(_sha256_K + 328, 0xa81a664b);
    store64(_sha256_K + 336, 0xc24b8b70);
    store64(_sha256_K + 344, 0xc76c51a3);
    store64(_sha256_K + 352, 0xd192e819);
    store64(_sha256_K + 360, 0xd6990624);
    store64(_sha256_K + 368, 0xf40e3585);
    store64(_sha256_K + 376, 0x106aa070);
    store64(_sha256_K + 384, 0x19a4c116);
    store64(_sha256_K + 392, 0x1e376c08);
    store64(_sha256_K + 400, 0x2748774c);
    store64(_sha256_K + 408, 0x34b0bcb5);
    store64(_sha256_K + 416, 0x391c0cb3);
    store64(_sha256_K + 424, 0x4ed8aa4a);
    store64(_sha256_K + 432, 0x5b9cca4f);
    store64(_sha256_K + 440, 0x682e6ff3);
    store64(_sha256_K + 448, 0x748f82ee);
    store64(_sha256_K + 456, 0x78a5636f);
    store64(_sha256_K + 464, 0x84c87814);
    store64(_sha256_K + 472, 0x8cc70208);
    store64(_sha256_K + 480, 0x90befffa);
    store64(_sha256_K + 488, 0xa4506ceb);
    store64(_sha256_K + 496, 0xbef9a3f7);
    store64(_sha256_K + 504, 0xc67178f2);

    _sha256_W = alloc(512);
    _sha256_inited = 1;
    return 0;
}

# ================================================================
# SHA-256 context
# ================================================================
# Layout (144 bytes):
#   +0   h0..h7   (8 x 8 = 64 bytes) hash state words
#   +64  buf      (64 bytes) partial block buffer
#   +128 buf_len  (8 bytes)
#   +136 total_len (8 bytes)

fn sha256_init() {
    sha256_global_init();
    var ctx = fl_alloc(144);
    store64(ctx, 0x6a09e667);
    store64(ctx + 8, 0xbb67ae85);
    store64(ctx + 16, 0x3c6ef372);
    store64(ctx + 24, 0xa54ff53a);
    store64(ctx + 32, 0x510e527f);
    store64(ctx + 40, 0x9b05688c);
    store64(ctx + 48, 0x1f83d9ab);
    store64(ctx + 56, 0x5be0cd19);
    memset(ctx + 64, 0, 64);
    store64(ctx + 128, 0);
    store64(ctx + 136, 0);
    return ctx;
}

# ================================================================
# Compression function — globals for working state
# ================================================================

var _sha_a = 0;
var _sha_b = 0;
var _sha_c = 0;
var _sha_d = 0;
var _sha_e = 0;
var _sha_f = 0;
var _sha_g = 0;
var _sha_hv = 0;
var _sha_t1 = 0;
var _sha_t2 = 0;
var _sha_ctx = 0;
var _sha_i = 0;

fn sha256_transform(ctx) {
    _sha_ctx = ctx;
    var buf = ctx + 64;

    # Prepare message schedule W[0..15] from block (big-endian)
    _sha_i = 0;
    while (_sha_i < 16) {
        var off = _sha_i * 4;
        var w = ((load8(buf + off) & 0xFF) << 24)
        | ((load8(buf + off + 1) & 0xFF) << 16)
        | ((load8(buf + off + 2) & 0xFF) << 8)
        | (load8(buf + off + 3) & 0xFF);
        store64(_sha256_W + _sha_i * 8, w & MASK32);
        _sha_i = _sha_i + 1;
    }

    # Extend W[16..63]
    _sha_i = 16;
    while (_sha_i < 64) {
        var w16 = load64(_sha256_W + (_sha_i - 16) * 8);
        var w15 = load64(_sha256_W + (_sha_i - 15) * 8);
        var w7 = load64(_sha256_W + (_sha_i - 7) * 8);
        var w2 = load64(_sha256_W + (_sha_i - 2) * 8);
        var s0 = sha256_ssig0(w15);
        # _sha_i may be clobbered — reload from W offsets computed before calls
        var s1 = sha256_ssig1(w2);
        store64(_sha256_W + _sha_i * 8, (w16 + s0 + w7 + s1) & MASK32);
        _sha_i = _sha_i + 1;
    }

    # Initialize working variables
    _sha_a = load64(_sha_ctx);
    _sha_b = load64(_sha_ctx + 8);
    _sha_c = load64(_sha_ctx + 16);
    _sha_d = load64(_sha_ctx + 24);
    _sha_e = load64(_sha_ctx + 32);
    _sha_f = load64(_sha_ctx + 40);
    _sha_g = load64(_sha_ctx + 48);
    _sha_hv = load64(_sha_ctx + 56);

    # 64 rounds — accumulate into globals between function calls
    _sha_i = 0;
    while (_sha_i < 64) {
        _sha_t1 = _sha_hv;
        _sha_t1 = (_sha_t1 + sha256_bsig1(_sha_e)) & MASK32;
        _sha_t1 = (_sha_t1 + sha256_ch(_sha_e, _sha_f, _sha_g)) & MASK32;
        _sha_t1 = (_sha_t1 + load64(_sha256_K + _sha_i * 8)) & MASK32;
        _sha_t1 = (_sha_t1 + load64(_sha256_W + _sha_i * 8)) & MASK32;

        _sha_t2 = sha256_bsig0(_sha_a);
        _sha_t2 = (_sha_t2 + sha256_maj(_sha_a, _sha_b, _sha_c)) & MASK32;

        _sha_hv = _sha_g;
        _sha_g = _sha_f;
        _sha_f = _sha_e;
        _sha_e = (_sha_d + _sha_t1) & MASK32;
        _sha_d = _sha_c;
        _sha_c = _sha_b;
        _sha_b = _sha_a;
        _sha_a = (_sha_t1 + _sha_t2) & MASK32;
        _sha_i = _sha_i + 1;
    }

    # Add compressed chunk to current hash value
    store64(_sha_ctx, (load64(_sha_ctx) + _sha_a) & MASK32);
    store64(_sha_ctx + 8, (load64(_sha_ctx + 8) + _sha_b) & MASK32);
    store64(_sha_ctx + 16, (load64(_sha_ctx + 16) + _sha_c) & MASK32);
    store64(_sha_ctx + 24, (load64(_sha_ctx + 24) + _sha_d) & MASK32);
    store64(_sha_ctx + 32, (load64(_sha_ctx + 32) + _sha_e) & MASK32);
    store64(_sha_ctx + 40, (load64(_sha_ctx + 40) + _sha_f) & MASK32);
    store64(_sha_ctx + 48, (load64(_sha_ctx + 48) + _sha_g) & MASK32);
    store64(_sha_ctx + 56, (load64(_sha_ctx + 56) + _sha_hv) & MASK32);
    return 0;
}

# ================================================================
# Update — feed data into the hash context
# ================================================================

fn sha256_update(ctx, data, len) {
    var buf_len = load64(ctx + 128);
    var total = load64(ctx + 136);
    total = total + len;
    store64(ctx + 136, total);

    var pos = 0;

    # Fill partial buffer first
    if (buf_len > 0) {
        var need = 64 - buf_len;
        if (len < need) {
            memcpy(ctx + 64 + buf_len, data, len);
            store64(ctx + 128, buf_len + len);
            return 0;
        }
        memcpy(ctx + 64 + buf_len, data, need);
        sha256_transform(ctx);
        pos = need;
        buf_len = 0;
    }

    # Process full 64-byte blocks
    while (pos + 64 <= len) {
        memcpy(ctx + 64, data + pos, 64);
        sha256_transform(ctx);
        pos = pos + 64;
    }

    # Buffer remaining bytes
    var remaining = len - pos;
    if (remaining > 0) {
        memcpy(ctx + 64, data + pos, remaining);
    }
    store64(ctx + 128, remaining);
    return 0;
}

# ================================================================
# Finalize — pad and produce 32-byte digest
# ================================================================

fn sha256_finalize(ctx, out) {
    var buf_len = load64(ctx + 128);
    var total_bits = load64(ctx + 136) * 8;

    # Append 0x80 byte
    store8(ctx + 64 + buf_len, 0x80);
    buf_len = buf_len + 1;

    # If buffer > 56 bytes, pad and process extra block
    if (buf_len > 56) {
        memset(ctx + 64 + buf_len, 0, 64 - buf_len);
        sha256_transform(ctx);
        buf_len = 0;
    }
    memset(ctx + 64 + buf_len, 0, 56 - buf_len);

    # Append total length as 64-bit big-endian at bytes 56-63
    store8(ctx + 64 + 56, (total_bits >> 56) & 0xFF);
    store8(ctx + 64 + 57, (total_bits >> 48) & 0xFF);
    store8(ctx + 64 + 58, (total_bits >> 40) & 0xFF);
    store8(ctx + 64 + 59, (total_bits >> 32) & 0xFF);
    store8(ctx + 64 + 60, (total_bits >> 24) & 0xFF);
    store8(ctx + 64 + 61, (total_bits >> 16) & 0xFF);
    store8(ctx + 64 + 62, (total_bits >> 8) & 0xFF);
    store8(ctx + 64 + 63, total_bits & 0xFF);

    sha256_transform(ctx);

    # Write 32-byte digest in big-endian from h0-h7
    var di = 0;
    while (di < 8) {
        var word = load64(ctx + di * 8);
        store8(out + di * 4, (word >> 24) & 0xFF);
        store8(out + di * 4 + 1, (word >> 16) & 0xFF);
        store8(out + di * 4 + 2, (word >> 8) & 0xFF);
        store8(out + di * 4 + 3, word & 0xFF);
        di = di + 1;
    }
    return 0;
}

# ================================================================
# Convenience — hash data in one shot
# ================================================================

fn sha256(data, len, out) {
    var ctx = sha256_init();
    sha256_update(ctx, data, len);
    sha256_finalize(ctx, out);
    fl_free(ctx);
    return 0;
}

# --- hex.cyr ---

# hex.cyr — hex encoding and decoding

# ================================================================
# Hex encode: bytes -> lowercase hex C-string
# ================================================================

fn hex_encode(bytes, len) {
    var out = alloc(len * 2 + 1);
    var i = 0;
    while (i < len) {
        var b = load8(bytes + i) & 0xFF;
        var hi = (b >> 4) & 0xF;
        var lo = b & 0xF;
        if (hi < 10) { store8(out + i * 2, 48 + hi); }
        else { store8(out + i * 2, 87 + hi); }
        if (lo < 10) { store8(out + i * 2 + 1, 48 + lo); }
        else { store8(out + i * 2 + 1, 87 + lo); }
        i = i + 1;
    }
    store8(out + len * 2, 0);
    return out;
}

# ================================================================
# Hex decode: hex C-string + length -> raw bytes
# ================================================================

fn _hex_nibble(c) {
    if (c >= 48) { if (c <= 57) { return c - 48; } }
    if (c >= 97) { if (c <= 102) { return c - 87; } }
    if (c >= 65) { if (c <= 70) { return c - 55; } }
    return (0 - 1);
}

fn _hex_is_valid_char(c) {
    if (c >= 48) { if (c <= 57) { return 1; } }
    if (c >= 97) { if (c <= 102) { return 1; } }
    if (c >= 65) { if (c <= 70) { return 1; } }
    return 0;
}

# Returns 1 if hex_str is a valid even-length hex C-string of hex_len chars.
fn hex_is_valid(hex_str, hex_len) {
    if (hex_len == 0) { return 0; }
    if ((hex_len & 1) == 1) { return 0; }
    var i = 0;
    while (i < hex_len) {
        if (_hex_is_valid_char(load8(hex_str + i) & 0xFF) == 0) { return 0; }
        i = i + 1;
    }
    return 1;
}

# Decode hex to bytes. Returns 0 (null) on invalid input
# (odd length, non-hex char). Caller MUST null-check.
fn hex_decode(hex_str, hex_len) {
    if ((hex_len & 1) == 1) { return 0; }
    var blen = hex_len / 2;
    if (blen == 0) { return 0; }
    var out = alloc(blen);
    var i = 0;
    while (i < blen) {
        var hi = _hex_nibble(load8(hex_str + i * 2) & 0xFF);
        var lo = _hex_nibble(load8(hex_str + i * 2 + 1) & 0xFF);
        if (hi < 0) { return 0; }
        if (lo < 0) { return 0; }
        store8(out + i, (hi << 4) | lo);
        i = i + 1;
    }
    return out;
}

# ================================================================
# Convenience: hash bytes to hex string
# ================================================================

fn sha256_hex(data, len) {
    var digest[32];
    sha256(data, len, &digest);
    return hex_encode(&digest, 32);
}

# --- ct.cyr ---

# ct.cyr — constant-time comparison utilities
# No early exit on data mismatch — prevents timing side-channels.

# ================================================================
# Constant-time byte comparison
# ================================================================
# Returns 1 if equal, 0 if different.
# Length mismatch returns 0 immediately (length is not secret).

fn ct_eq(a, a_len, b, b_len) {
    if (a_len != b_len) { return 0; }
    var diff = 0;
    var i = 0;
    while (i < a_len) {
        diff = diff | (load8(a + i) ^ load8(b + i));
        i = i + 1;
    }
    if (diff == 0) { return 1; }
    return 0;
}

# ================================================================
# Constant-time comparison for fixed 32-byte buffers (SHA-256 digests)
# ================================================================

fn ct_eq_32(a, b) {
    return ct_eq(a, 32, b, 32);
}

# ================================================================
# Constant-time comparison for fixed 64-byte buffers (Ed25519 signatures)
# ================================================================

fn ct_eq_64(a, b) {
    return ct_eq(a, 64, b, 64);
}

# --- hmac.cyr ---

# hmac.cyr — HMAC-SHA256 (RFC 2104)
# Proper ipad/opad construction, not simplified SHA-256(key||msg).

# HMAC(K, m) = H((K' xor opad) || H((K' xor ipad) || m))
# where:
#   K' = H(K) if len(K) > 64, else K padded to 64 bytes
#   ipad = 0x36 repeated 64 times
#   opad = 0x5c repeated 64 times

# ================================================================
# HMAC-SHA256
# ================================================================

fn hmac_sha256(key, key_len, msg, msg_len, out) {
    # Step 1: Derive K' (64 bytes)
    var kprime[64];
    memset(&kprime, 0, 64);

    if (key_len > 64) {
        # Key too long — hash it
        sha256(key, key_len, &kprime);
        # kprime is now 32 bytes of hash + 32 bytes of zeros
    } else {
        memcpy(&kprime, key, key_len);
        # Rest already zeroed
    }

    # Step 2: inner = SHA-256((K' xor ipad) || message)
    var ipad[64];
    var i = 0;
    while (i < 64) {
        store8(&ipad + i, (load8(&kprime + i) & 0xFF) ^ 0x36);
        i = i + 1;
    }

    var inner_ctx = sha256_init();
    sha256_update(inner_ctx, &ipad, 64);
    sha256_update(inner_ctx, msg, msg_len);
    var inner_hash[32];
    sha256_finalize(inner_ctx, &inner_hash);
    fl_free(inner_ctx);

    # Step 3: outer = SHA-256((K' xor opad) || inner)
    var opad[64];
    i = 0;
    while (i < 64) {
        store8(&opad + i, (load8(&kprime + i) & 0xFF) ^ 0x5c);
        i = i + 1;
    }

    var outer_ctx = sha256_init();
    sha256_update(outer_ctx, &opad, 64);
    sha256_update(outer_ctx, &inner_hash, 32);
    sha256_finalize(outer_ctx, out);
    fl_free(outer_ctx);

    # Zeroize key-derived material on stack before return.
    # kprime holds K', ipad/opad hold K' XOR 0x36/0x5c. inner_hash
    # is a plain digest (public) but zero it too for consistency.
    memset(&kprime, 0, 64);
    memset(&ipad, 0, 64);
    memset(&opad, 0, 64);
    memset(&inner_hash, 0, 32);
    return 0;
}

# ================================================================
# HMAC-SHA256 sign/verify convenience
# ================================================================

fn hmac_sign(key, key_len, data, data_len) {
    var sig = alloc(32);
    hmac_sha256(key, key_len, data, data_len, sig);
    return sig;
}

fn hmac_verify(key, key_len, data, data_len, expected_sig) {
    var computed[32];
    hmac_sha256(key, key_len, data, data_len, &computed);
    return ct_eq_32(&computed, expected_sig);
}

# --- sha512.cyr ---

# sha512.cyr — FIPS 180-4 SHA-512 implementation
# Required by Ed25519 (RFC 8032) for key expansion and signing.
# All arithmetic uses 64-bit words (native Cyrius i64).

# ================================================================
# SHA-512 round constants K[0..79]
# ================================================================

var _sha512_K = 0;
var _sha512_W = 0;
var _sha512_inited = 0;

fn _sha512_rotr(x, n) {
    return (x >> n) | (x << (64 - n));
}

fn sha512_ch(x, y, z) {
    return (x & y) ^ ((x ^ 0xFFFFFFFFFFFFFFFF) & z);
}

fn sha512_maj(x, y, z) {
    return (x & y) ^ (x & z) ^ (y & z);
}

fn sha512_bsig0(x) {
    return _sha512_rotr(x, 28) ^ _sha512_rotr(x, 34) ^ _sha512_rotr(x, 39);
}

fn sha512_bsig1(x) {
    return _sha512_rotr(x, 14) ^ _sha512_rotr(x, 18) ^ _sha512_rotr(x, 41);
}

fn sha512_ssig0(x) {
    return _sha512_rotr(x, 1) ^ _sha512_rotr(x, 8) ^ (x >> 7);
}

fn sha512_ssig1(x) {
    return _sha512_rotr(x, 19) ^ _sha512_rotr(x, 61) ^ (x >> 6);
}

fn sha512_global_init() {
    if (_sha512_inited == 1) { return 0; }

    _sha512_K = alloc(640);
    store64(_sha512_K + 0, 0x428a2f98d728ae22);
    store64(_sha512_K + 8, 0x7137449123ef65cd);
    store64(_sha512_K + 16, 0xb5c0fbcfec4d3b2f);
    store64(_sha512_K + 24, 0xe9b5dba58189dbbc);
    store64(_sha512_K + 32, 0x3956c25bf348b538);
    store64(_sha512_K + 40, 0x59f111f1b605d019);
    store64(_sha512_K + 48, 0x923f82a4af194f9b);
    store64(_sha512_K + 56, 0xab1c5ed5da6d8118);
    store64(_sha512_K + 64, 0xd807aa98a3030242);
    store64(_sha512_K + 72, 0x12835b0145706fbe);
    store64(_sha512_K + 80, 0x243185be4ee4b28c);
    store64(_sha512_K + 88, 0x550c7dc3d5ffb4e2);
    store64(_sha512_K + 96, 0x72be5d74f27b896f);
    store64(_sha512_K + 104, 0x80deb1fe3b1696b1);
    store64(_sha512_K + 112, 0x9bdc06a725c71235);
    store64(_sha512_K + 120, 0xc19bf174cf692694);
    store64(_sha512_K + 128, 0xe49b69c19ef14ad2);
    store64(_sha512_K + 136, 0xefbe4786384f25e3);
    store64(_sha512_K + 144, 0x0fc19dc68b8cd5b5);
    store64(_sha512_K + 152, 0x240ca1cc77ac9c65);
    store64(_sha512_K + 160, 0x2de92c6f592b0275);
    store64(_sha512_K + 168, 0x4a7484aa6ea6e483);
    store64(_sha512_K + 176, 0x5cb0a9dcbd41fbd4);
    store64(_sha512_K + 184, 0x76f988da831153b5);
    store64(_sha512_K + 192, 0x983e5152ee66dfab);
    store64(_sha512_K + 200, 0xa831c66d2db43210);
    store64(_sha512_K + 208, 0xb00327c898fb213f);
    store64(_sha512_K + 216, 0xbf597fc7beef0ee4);
    store64(_sha512_K + 224, 0xc6e00bf33da88fc2);
    store64(_sha512_K + 232, 0xd5a79147930aa725);
    store64(_sha512_K + 240, 0x06ca6351e003826f);
    store64(_sha512_K + 248, 0x142929670a0e6e70);
    store64(_sha512_K + 256, 0x27b70a8546d22ffc);
    store64(_sha512_K + 264, 0x2e1b21385c26c926);
    store64(_sha512_K + 272, 0x4d2c6dfc5ac42aed);
    store64(_sha512_K + 280, 0x53380d139d95b3df);
    store64(_sha512_K + 288, 0x650a73548baf63de);
    store64(_sha512_K + 296, 0x766a0abb3c77b2a8);
    store64(_sha512_K + 304, 0x81c2c92e47edaee6);
    store64(_sha512_K + 312, 0x92722c851482353b);
    store64(_sha512_K + 320, 0xa2bfe8a14cf10364);
    store64(_sha512_K + 328, 0xa81a664bbc423001);
    store64(_sha512_K + 336, 0xc24b8b70d0f89791);
    store64(_sha512_K + 344, 0xc76c51a30654be30);
    store64(_sha512_K + 352, 0xd192e819d6ef5218);
    store64(_sha512_K + 360, 0xd69906245565a910);
    store64(_sha512_K + 368, 0xf40e35855771202a);
    store64(_sha512_K + 376, 0x106aa07032bbd1b8);
    store64(_sha512_K + 384, 0x19a4c116b8d2d0c8);
    store64(_sha512_K + 392, 0x1e376c085141ab53);
    store64(_sha512_K + 400, 0x2748774cdf8eeb99);
    store64(_sha512_K + 408, 0x34b0bcb5e19b48a8);
    store64(_sha512_K + 416, 0x391c0cb3c5c95a63);
    store64(_sha512_K + 424, 0x4ed8aa4ae3418acb);
    store64(_sha512_K + 432, 0x5b9cca4f7763e373);
    store64(_sha512_K + 440, 0x682e6ff3d6b2b8a3);
    store64(_sha512_K + 448, 0x748f82ee5defb2fc);
    store64(_sha512_K + 456, 0x78a5636f43172f60);
    store64(_sha512_K + 464, 0x84c87814a1f0ab72);
    store64(_sha512_K + 472, 0x8cc702081a6439ec);
    store64(_sha512_K + 480, 0x90befffa23631e28);
    store64(_sha512_K + 488, 0xa4506cebde82bde9);
    store64(_sha512_K + 496, 0xbef9a3f7b2c67915);
    store64(_sha512_K + 504, 0xc67178f2e372532b);
    store64(_sha512_K + 512, 0xca273eceea26619c);
    store64(_sha512_K + 520, 0xd186b8c721c0c207);
    store64(_sha512_K + 528, 0xeada7dd6cde0eb1e);
    store64(_sha512_K + 536, 0xf57d4f7fee6ed178);
    store64(_sha512_K + 544, 0x06f067aa72176fba);
    store64(_sha512_K + 552, 0x0a637dc5a2c898a6);
    store64(_sha512_K + 560, 0x113f9804bef90dae);
    store64(_sha512_K + 568, 0x1b710b35131c471b);
    store64(_sha512_K + 576, 0x28db77f523047d84);
    store64(_sha512_K + 584, 0x32caab7b40c72493);
    store64(_sha512_K + 592, 0x3c9ebe0a15c9bebc);
    store64(_sha512_K + 600, 0x431d67c49c100d4c);
    store64(_sha512_K + 608, 0x4cc5d4becb3e42b6);
    store64(_sha512_K + 616, 0x597f299cfc657e2a);
    store64(_sha512_K + 624, 0x5fcb6fab3ad6faec);
    store64(_sha512_K + 632, 0x6c44198c4a475817);

    _sha512_W = alloc(640);
    _sha512_inited = 1;
    return 0;
}

# ================================================================
# SHA-512 context (272 bytes)
# ================================================================
# Layout:
#   +0    h0..h7 (8 x 8 = 64 bytes) hash state
#   +64   buf    (128 bytes) partial block buffer
#   +192  buf_len (8 bytes)
#   +200  total_len (8 bytes)

fn sha512_init() {
    sha512_global_init();
    var ctx = fl_alloc(208);
    store64(ctx, 0x6a09e667f3bcc908);
    store64(ctx + 8, 0xbb67ae8584caa73b);
    store64(ctx + 16, 0x3c6ef372fe94f82b);
    store64(ctx + 24, 0xa54ff53a5f1d36f1);
    store64(ctx + 32, 0x510e527fade682d1);
    store64(ctx + 40, 0x9b05688c2b3e6c1f);
    store64(ctx + 48, 0x1f83d9abfb41bd6b);
    store64(ctx + 56, 0x5be0cd19137e2179);
    memset(ctx + 64, 0, 128);
    store64(ctx + 192, 0);
    store64(ctx + 200, 0);
    return ctx;
}

# ================================================================
# SHA-512 transform — globals for working state
# ================================================================

var _s5_a = 0;
var _s5_b = 0;
var _s5_c = 0;
var _s5_d = 0;
var _s5_e = 0;
var _s5_f = 0;
var _s5_g = 0;
var _s5_hv = 0;
var _s5_t1 = 0;
var _s5_t2 = 0;
var _s5_ctx = 0;
var _s5_i = 0;

fn sha512_transform(ctx) {
    _s5_ctx = ctx;
    var buf = ctx + 64;

    # Prepare message schedule W[0..15] from block (big-endian 64-bit words)
    _s5_i = 0;
    while (_s5_i < 16) {
        var off = _s5_i * 8;
        var w = ((load8(buf + off) & 0xFF) << 56)
        | ((load8(buf + off + 1) & 0xFF) << 48)
        | ((load8(buf + off + 2) & 0xFF) << 40)
        | ((load8(buf + off + 3) & 0xFF) << 32)
        | ((load8(buf + off + 4) & 0xFF) << 24)
        | ((load8(buf + off + 5) & 0xFF) << 16)
        | ((load8(buf + off + 6) & 0xFF) << 8)
        | (load8(buf + off + 7) & 0xFF);
        store64(_sha512_W + _s5_i * 8, w);
        _s5_i = _s5_i + 1;
    }

    # Extend W[16..79]
    _s5_i = 16;
    while (_s5_i < 80) {
        var w16 = load64(_sha512_W + (_s5_i - 16) * 8);
        var w15 = load64(_sha512_W + (_s5_i - 15) * 8);
        var w7 = load64(_sha512_W + (_s5_i - 7) * 8);
        var w2 = load64(_sha512_W + (_s5_i - 2) * 8);
        var s0 = sha512_ssig0(w15);
        var s1 = sha512_ssig1(w2);
        store64(_sha512_W + _s5_i * 8, w16 + s0 + w7 + s1);
        _s5_i = _s5_i + 1;
    }

    # Initialize working variables
    _s5_a = load64(_s5_ctx);
    _s5_b = load64(_s5_ctx + 8);
    _s5_c = load64(_s5_ctx + 16);
    _s5_d = load64(_s5_ctx + 24);
    _s5_e = load64(_s5_ctx + 32);
    _s5_f = load64(_s5_ctx + 40);
    _s5_g = load64(_s5_ctx + 48);
    _s5_hv = load64(_s5_ctx + 56);

    # 80 rounds
    _s5_i = 0;
    while (_s5_i < 80) {
        _s5_t1 = _s5_hv + sha512_bsig1(_s5_e) + sha512_ch(_s5_e, _s5_f, _s5_g);
        _s5_t1 = _s5_t1 + load64(_sha512_K + _s5_i * 8) + load64(_sha512_W + _s5_i * 8);
        _s5_t2 = sha512_bsig0(_s5_a) + sha512_maj(_s5_a, _s5_b, _s5_c);

        _s5_hv = _s5_g;
        _s5_g = _s5_f;
        _s5_f = _s5_e;
        _s5_e = _s5_d + _s5_t1;
        _s5_d = _s5_c;
        _s5_c = _s5_b;
        _s5_b = _s5_a;
        _s5_a = _s5_t1 + _s5_t2;
        _s5_i = _s5_i + 1;
    }

    # Add compressed chunk to current hash value
    store64(_s5_ctx, load64(_s5_ctx) + _s5_a);
    store64(_s5_ctx + 8, load64(_s5_ctx + 8) + _s5_b);
    store64(_s5_ctx + 16, load64(_s5_ctx + 16) + _s5_c);
    store64(_s5_ctx + 24, load64(_s5_ctx + 24) + _s5_d);
    store64(_s5_ctx + 32, load64(_s5_ctx + 32) + _s5_e);
    store64(_s5_ctx + 40, load64(_s5_ctx + 40) + _s5_f);
    store64(_s5_ctx + 48, load64(_s5_ctx + 48) + _s5_g);
    store64(_s5_ctx + 56, load64(_s5_ctx + 56) + _s5_hv);
    return 0;
}

# ================================================================
# SHA-512 update
# ================================================================

fn sha512_update(ctx, data, len) {
    var buf_len = load64(ctx + 192);
    var total = load64(ctx + 200);
    total = total + len;
    store64(ctx + 200, total);

    var pos = 0;

    if (buf_len > 0) {
        var need = 128 - buf_len;
        if (len < need) {
            memcpy(ctx + 64 + buf_len, data, len);
            store64(ctx + 192, buf_len + len);
            return 0;
        }
        memcpy(ctx + 64 + buf_len, data, need);
        sha512_transform(ctx);
        pos = need;
        buf_len = 0;
    }

    while (pos + 128 <= len) {
        memcpy(ctx + 64, data + pos, 128);
        sha512_transform(ctx);
        pos = pos + 128;
    }

    var remaining = len - pos;
    if (remaining > 0) {
        memcpy(ctx + 64, data + pos, remaining);
    }
    store64(ctx + 192, remaining);
    return 0;
}

# ================================================================
# SHA-512 finalize — produce 64-byte digest
# ================================================================

fn sha512_finalize(ctx, out) {
    var buf_len = load64(ctx + 192);
    var total_bits = load64(ctx + 200) * 8;

    store8(ctx + 64 + buf_len, 0x80);
    buf_len = buf_len + 1;

    if (buf_len > 112) {
        memset(ctx + 64 + buf_len, 0, 128 - buf_len);
        sha512_transform(ctx);
        buf_len = 0;
    }
    memset(ctx + 64 + buf_len, 0, 112 - buf_len);

    # Append total length as 128-bit big-endian (high 64 bits = 0 for < 2^64 bits)
    memset(ctx + 64 + 112, 0, 8);
    store8(ctx + 64 + 120, (total_bits >> 56) & 0xFF);
    store8(ctx + 64 + 121, (total_bits >> 48) & 0xFF);
    store8(ctx + 64 + 122, (total_bits >> 40) & 0xFF);
    store8(ctx + 64 + 123, (total_bits >> 32) & 0xFF);
    store8(ctx + 64 + 124, (total_bits >> 24) & 0xFF);
    store8(ctx + 64 + 125, (total_bits >> 16) & 0xFF);
    store8(ctx + 64 + 126, (total_bits >> 8) & 0xFF);
    store8(ctx + 64 + 127, total_bits & 0xFF);

    sha512_transform(ctx);

    # Write 64-byte digest in big-endian from h0-h7
    var di = 0;
    while (di < 8) {
        var word = load64(ctx + di * 8);
        store8(out + di * 8, (word >> 56) & 0xFF);
        store8(out + di * 8 + 1, (word >> 48) & 0xFF);
        store8(out + di * 8 + 2, (word >> 40) & 0xFF);
        store8(out + di * 8 + 3, (word >> 32) & 0xFF);
        store8(out + di * 8 + 4, (word >> 24) & 0xFF);
        store8(out + di * 8 + 5, (word >> 16) & 0xFF);
        store8(out + di * 8 + 6, (word >> 8) & 0xFF);
        store8(out + di * 8 + 7, word & 0xFF);
        di = di + 1;
    }
    return 0;
}

# ================================================================
# Convenience — hash data in one shot
# ================================================================

fn sha512(data, len, out) {
    var ctx = sha512_init();
    sha512_update(ctx, data, len);
    sha512_finalize(ctx, out);
    fl_free(ctx);
    return 0;
}

# --- bigint_ext.cyr ---

# bigint_ext.cyr — extended 256-bit arithmetic for Ed25519
# Adds: full 512-bit multiply, modular reduction for p=2^255-19,
# modular inversion, modular exponentiation.
# Builds on lib/bigint.cyr

# ================================================================
# 64×64 → 128-bit multiply (result in globals)
# ================================================================

var _m64_lo = 0;
var _m64_hi = 0;

fn _mul64_full(a, b) {
    var mask32 = 0xFFFFFFFF;
    var aL = a & mask32;
    var aH = (a >> 32) & mask32;
    var bL = b & mask32;
    var bH = (b >> 32) & mask32;
    var ll = aL * bL;
    var lh = aL * bH;
    var hl = aH * bL;
    var hh = aH * bH;
    var mid = lh + hl;
    var mid_carry = 0;
    if ((mid ^ (1 << 63)) < (lh ^ (1 << 63))) { mid_carry = 1; }
    var lo = ll + (mid << 32);
    var lo_carry = 0;
    if ((lo ^ (1 << 63)) < (ll ^ (1 << 63))) { lo_carry = 1; }
    _m64_lo = lo;
    _m64_hi = hh + (mid >> 32) + (mid_carry << 32) + lo_carry;
    return 0;
}

# ================================================================
# Full 256×256 → 512-bit multiply
# out: 64 bytes (8 limbs)
# ================================================================

# Unsigned add with carry detection: returns 1 if a+b overflows 64 bits
fn _uadd_overflow(a, b) {
    var sum = a + b;
    # Unsigned overflow: sum < a (when compared as unsigned)
    var sa = a ^ (1 << 63);
    var ss = sum ^ (1 << 63);
    if (ss < sa) { return 1; }
    return 0;
}

# Globals for mul_full inner loop (avoid local clobber across fn calls)
var _mf_s1 = 0;
var _mf_c1 = 0;
var _mf_carry = 0;
var _mf_hi = 0;

fn u256_mul_full(out, a, b) {
    memset(out, 0, 64);
    var i = 0;
    while (i < 4) {
        _mf_carry = 0;
        var j = 0;
        while (j < 4) {
            _mul64_full(load64(a + i * 8), load64(b + j * 8));
            var k = i + j;
            var prev = load64(out + k * 8);
            _mf_hi = _m64_hi;

            # s1 = prev + _m64_lo (save to global before fn call)
            _mf_s1 = prev + _m64_lo;
            _mf_c1 = _uadd_overflow(prev, _m64_lo);

            # s2 = s1 + carry
            var s2 = _mf_s1 + _mf_carry;
            var c2 = _uadd_overflow(_mf_s1, _mf_carry);

            store64(out + k * 8, s2);
            _mf_carry = _mf_hi + _mf_c1 + c2;
            j = j + 1;
        }
        if (i + 4 < 8) {
            store64(out + (i + 4) * 8, load64(out + (i + 4) * 8) + _mf_carry);
        }
        i = i + 1;
    }
    return 0;
}

# ================================================================
# Reduction mod p = 2^255 - 19
# Uses: 2^256 ≡ 38 (mod p), so for 512-bit val = aH*2^256 + aL:
#   val mod p ≡ aL + 38*aH (mod p)
# May need 1-2 further subtractions.
# ================================================================

# Global p = 2^255 - 19
var _ed_p = 0;
var _ed_p_inited = 0;
var _mod_prod = 0;
var _mod_aH = 0;
var _mod_aL = 0;
var _mod_38 = 0;
var _mod_lowp = 0;
var _mod_r = 0;
var _mod_extra = 0;

fn _init_ed_p() {
    if (_ed_p_inited == 1) { return 0; }
    _ed_p = u256_from_hex("7fffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffed");
    _mod_prod = alloc(64);
    _mod_aH = alloc(32);
    _mod_aL = alloc(32);
    _mod_38 = u256_from(38);
    _mod_lowp = alloc(32);
    _mod_r = alloc(32);
    _mod_extra = alloc(32);
    _ed_p_inited = 1;
    return 0;
}

fn u512_mod_p(out, val) {
    _init_ed_p();

    store64(_mod_aH, load64(val + 32));
    store64(_mod_aH + 8, load64(val + 40));
    store64(_mod_aH + 16, load64(val + 48));
    store64(_mod_aH + 24, load64(val + 56));

    store64(_mod_aL, load64(val));
    store64(_mod_aL + 8, load64(val + 8));
    store64(_mod_aL + 16, load64(val + 16));
    store64(_mod_aL + 24, load64(val + 24));

    u256_mul_full(_mod_prod, _mod_aH, _mod_38);

    store64(_mod_lowp, load64(_mod_prod));
    store64(_mod_lowp + 8, load64(_mod_prod + 8));
    store64(_mod_lowp + 16, load64(_mod_prod + 16));
    store64(_mod_lowp + 24, load64(_mod_prod + 24));

    var carry = u256_add(_mod_r, _mod_aL, _mod_lowp);
    var overflow = carry + load64(_mod_prod + 32);

    while (overflow > 0) {
        store64(_mod_extra, overflow * 38);
        store64(_mod_extra + 8, 0);
        store64(_mod_extra + 16, 0);
        store64(_mod_extra + 24, 0);
        overflow = u256_add(_mod_r, _mod_r, _mod_extra);
    }

    while (u256_cmp(_mod_r, _ed_p) >= 0) {
        u256_sub(_mod_r, _mod_r, _ed_p);
    }

    u256_copy(out, _mod_r);
    return 0;
}

# ================================================================
# Field arithmetic mod p
# ================================================================

fn fp_add(r, a, b) {
    _init_ed_p();
    u256_add(r, a, b);
    if (u256_cmp(r, _ed_p) >= 0) { u256_sub(r, r, _ed_p); }
    return 0;
}

fn fp_sub(r, a, b) {
    _init_ed_p();
    var borrow = u256_sub(r, a, b);
    if (borrow > 0) { u256_add(r, r, _ed_p); }
    return 0;
}

fn fp_neg(r, a) {
    _init_ed_p();
    if (u256_is_zero(a) == 1) {
        u256_copy(r, a);
        return 0;
    }
    u256_sub(r, _ed_p, a);
    return 0;
}

var _fp_mul_product = 0;

fn fp_mul(r, a, b) {
    if (_fp_mul_product == 0) { _fp_mul_product = alloc(64); }
    u256_mul_full(_fp_mul_product, a, b);
    u512_mod_p(r, _fp_mul_product);
    return 0;
}

fn fp_sq(r, a) {
    return fp_mul(r, a, a);
}

# ================================================================
# Modular exponentiation: r = base^exp mod p
# ================================================================

# Globals for fp_pow to survive nested calls (compiler clobber workaround)
var _fp_pow_tmp = 0;
var _fp_pow_result = 0;
var _fp_pow_base = 0;
var _fp_pow_exp = 0;
var _fp_pow_i = 0;
var _fp_pow_inited = 0;

fn fp_pow(r, base, exp) {
    _init_ed_p();
    if (_fp_pow_inited == 0) {
        _fp_pow_tmp = alloc(32);
        _fp_pow_result = alloc(32);
        _fp_pow_base = alloc(32);
        _fp_pow_inited = 1;
    }
    store64(_fp_pow_result, 1);
    store64(_fp_pow_result + 8, 0);
    store64(_fp_pow_result + 16, 0);
    store64(_fp_pow_result + 24, 0);
    u256_copy(_fp_pow_base, base);
    _fp_pow_exp = exp;
    _fp_pow_i = 0;
    while (_fp_pow_i < 256) {
        var limb_idx = _fp_pow_i / 64;
        var bit_idx = _fp_pow_i % 64;
        var bit = (load64(_fp_pow_exp + limb_idx * 8) >> bit_idx) & 1;
        if (bit == 1) {
            fp_mul(_fp_pow_tmp, _fp_pow_result, _fp_pow_base);
            u256_copy(_fp_pow_result, _fp_pow_tmp);
        }
        fp_mul(_fp_pow_tmp, _fp_pow_base, _fp_pow_base);
        u256_copy(_fp_pow_base, _fp_pow_tmp);
        _fp_pow_i = _fp_pow_i + 1;
    }
    u256_copy(r, _fp_pow_result);
    return 0;
}

# ================================================================
# Modular inversion: r = a^(p-2) mod p (Fermat's little theorem)
# ================================================================

var _fp_inv_pm2 = 0;

fn fp_inv(r, a) {
    _init_ed_p();
    if (_fp_inv_pm2 == 0) {
        _fp_inv_pm2 = alloc(32);
        u256_copy(_fp_inv_pm2, _ed_p);
        store64(_fp_inv_pm2, load64(_fp_inv_pm2) - 2);
    }
    fp_pow(r, a, _fp_inv_pm2);
    return 0;
}

# --- ed25519.cyr ---

# ed25519.cyr — Ed25519 signing and verification (RFC 8032)
# Built on bigint.cyr (u256) and bigint_ext.cyr (fp_* field ops)
#
# Curve: -x^2 + y^2 = 1 + d*x^2*y^2 (mod p)
# p = 2^255 - 19
# d = -121665/121666 mod p
# L = 2^252 + 27742317777372353535851937790883648493 (group order)
# B = base point (y = 4/5 mod p)
#
# Points: extended coordinates (X, Y, Z, T) where x=X/Z, y=Y/Z, T=X*Y/Z
# Each coordinate is a u256 (32 bytes), point = 128 bytes

# ================================================================
# Constants (allocated on init)
# ================================================================

var _ed_d = 0;
var _ed_2d = 0;
var _ed_B = 0;       # base point (128 bytes: X,Y,Z,T)
var _ed_L = 0;       # group order (32 bytes)
var _ed_sqrtm1 = 0;
var _ed25519_inited = 0;

# ================================================================
# Point layout: 128 bytes = 4 x u256
# ================================================================
# +0:   X (32 bytes)
# +32:  Y (32 bytes)
# +64:  Z (32 bytes)
# +96:  T (32 bytes)

fn ge_alloc() { return alloc(128); }

fn ge_x(p) { return p; }
fn ge_y(p) { return p + 32; }
fn ge_z(p) { return p + 64; }
fn ge_t(p) { return p + 96; }

fn ge_identity(p) {
    # Identity: (0, 1, 1, 0)
    var z = u256_from(0);
    var o = u256_from(1);
    u256_copy(p, z);
    u256_copy(p + 32, o);
    u256_copy(p + 64, o);
    u256_copy(p + 96, z);
    return 0;
}

fn ge_copy(dst, src) {
    memcpy(dst, src, 128);
    return 0;
}

# ================================================================
# Point addition (extended coordinates)
# From "Twisted Edwards Curves Revisited" — HWCD08
# Cost: 8M + 1D (D = multiply by 2d)
# ================================================================

var _ga_t1 = 0;
var _ga_t2 = 0;
var _ga_A = 0;
var _ga_B2 = 0;
var _ga_C = 0;
var _ga_D = 0;
var _ga_E = 0;
var _ga_F = 0;
var _ga_G = 0;
var _ga_H2 = 0;
var _ga_inited = 0;

fn _ge_init_temps() {
    if (_ga_inited == 1) { return 0; }
    _ga_t1 = alloc(32); _ga_t2 = alloc(32);
    _ga_A = alloc(32); _ga_B2 = alloc(32);
    _ga_C = alloc(32); _ga_D = alloc(32);
    _ga_E = alloc(32); _ga_F = alloc(32);
    _ga_G = alloc(32); _ga_H2 = alloc(32);
    _ga_inited = 1;
    return 0;
}

fn ge_add(r, p, q) {
    _ge_init_temps();
    # A = (Y1-X1)*(Y2-X2)
    fp_sub(_ga_t1, ge_y(p), ge_x(p));
    fp_sub(_ga_t2, ge_y(q), ge_x(q));
    fp_mul(_ga_A, _ga_t1, _ga_t2);

    # B = (Y1+X1)*(Y2+X2)
    fp_add(_ga_t1, ge_y(p), ge_x(p));
    fp_add(_ga_t2, ge_y(q), ge_x(q));
    fp_mul(_ga_B2, _ga_t1, _ga_t2);

    # C = T1*2d*T2
    fp_mul(_ga_C, ge_t(p), ge_t(q));
    fp_mul(_ga_C, _ga_C, _ed_2d);

    # D = Z1*2*Z2
    fp_mul(_ga_D, ge_z(p), ge_z(q));
    fp_add(_ga_D, _ga_D, _ga_D);

    # E=B-A, F=D-C, G=D+C, H=B+A
    fp_sub(_ga_E, _ga_B2, _ga_A);
    fp_sub(_ga_F, _ga_D, _ga_C);
    fp_add(_ga_G, _ga_D, _ga_C);
    fp_add(_ga_H2, _ga_B2, _ga_A);

    # X3=E*F, Y3=G*H, T3=E*H, Z3=F*G
    fp_mul(ge_x(r), _ga_E, _ga_F);
    fp_mul(ge_y(r), _ga_G, _ga_H2);
    fp_mul(ge_t(r), _ga_E, _ga_H2);
    fp_mul(ge_z(r), _ga_F, _ga_G);
    return 0;
}

# ================================================================
# Point doubling
# ================================================================

var _gd_A = 0;
var _gd_B = 0;
var _gd_C = 0;
var _gd_D = 0;
var _gd_E = 0;
var _gd_F = 0;
var _gd_G = 0;
var _gd_H = 0;
var _gd_t = 0;
var _gd_inited = 0;

fn _ge_init_dbl() {
    if (_gd_inited == 1) { return 0; }
    _gd_A = alloc(32); _gd_B = alloc(32);
    _gd_C = alloc(32); _gd_D = alloc(32);
    _gd_E = alloc(32); _gd_F = alloc(32);
    _gd_G = alloc(32); _gd_H = alloc(32);
    _gd_t = alloc(32);
    _gd_inited = 1;
    return 0;
}

fn ge_double(r, p) {
    _ge_init_dbl();
    fp_sq(_gd_A, ge_x(p));
    fp_sq(_gd_B, ge_y(p));
    fp_sq(_gd_C, ge_z(p));
    fp_add(_gd_C, _gd_C, _gd_C);
    fp_neg(_gd_D, _gd_A);  # a=-1 for ed25519

    fp_add(_gd_t, ge_x(p), ge_y(p));
    fp_sq(_gd_E, _gd_t);
    fp_sub(_gd_E, _gd_E, _gd_A);
    fp_sub(_gd_E, _gd_E, _gd_B);

    fp_add(_gd_G, _gd_D, _gd_B);
    fp_sub(_gd_F, _gd_G, _gd_C);
    fp_sub(_gd_H, _gd_D, _gd_B);

    fp_mul(ge_x(r), _gd_E, _gd_F);
    fp_mul(ge_y(r), _gd_G, _gd_H);
    fp_mul(ge_t(r), _gd_E, _gd_H);
    fp_mul(ge_z(r), _gd_F, _gd_G);
    return 0;
}

# ================================================================
# Scalar multiplication: R = [s]P (double-and-add)
# s is 32 bytes little-endian scalar
# ================================================================

var _gsm_q = 0;
var _gsm_tmp = 0;
var _gsm_i = 0;
var _gsm_r = 0;
var _gsm_s = 0;

fn ge_scalarmult(r, s, p) {
    if (_gsm_q == 0) { _gsm_q = alloc(128); _gsm_tmp = alloc(128); }
    _gsm_r = r;
    _gsm_s = s;
    ge_identity(_gsm_r);
    ge_copy(_gsm_q, p);

    _gsm_i = 0;
    while (_gsm_i < 256) {
        var byte_idx = _gsm_i / 8;
        var bit_idx = _gsm_i % 8;
        var bit = (load8(_gsm_s + byte_idx) >> bit_idx) & 1;
        if (bit == 1) {
            ge_add(_gsm_tmp, _gsm_r, _gsm_q);
            ge_copy(_gsm_r, _gsm_tmp);
        }
        ge_double(_gsm_tmp, _gsm_q);
        ge_copy(_gsm_q, _gsm_tmp);
        _gsm_i = _gsm_i + 1;
    }
    return 0;
}

# ================================================================
# Point compression: point -> 32 bytes
# Encode y with sign of x in high bit of last byte
# ================================================================

var _gcomp_recip = 0;
var _gcomp_x = 0;
var _gcomp_y = 0;

fn ge_to_bytes(out, p) {
    if (_gcomp_recip == 0) {
        _gcomp_recip = alloc(32);
        _gcomp_x = alloc(32);
        _gcomp_y = alloc(32);
    }
    fp_inv(_gcomp_recip, ge_z(p));
    fp_mul(_gcomp_x, ge_x(p), _gcomp_recip);
    fp_mul(_gcomp_y, ge_y(p), _gcomp_recip);

    # Encode y as 32 bytes little-endian
    var i = 0;
    while (i < 4) {
        var v = u256_limb(_gcomp_y, i);
        store8(out + i*8, v & 0xFF);
        store8(out + i*8 + 1, (v >> 8) & 0xFF);
        store8(out + i*8 + 2, (v >> 16) & 0xFF);
        store8(out + i*8 + 3, (v >> 24) & 0xFF);
        store8(out + i*8 + 4, (v >> 32) & 0xFF);
        store8(out + i*8 + 5, (v >> 40) & 0xFF);
        store8(out + i*8 + 6, (v >> 48) & 0xFF);
        store8(out + i*8 + 7, (v >> 56) & 0xFF);
        i = i + 1;
    }

    # Set high bit to sign of x (low bit of x)
    var x_sign = u256_limb(_gcomp_x, 0) & 1;
    store8(out + 31, (load8(out + 31) & 0xFF) | (x_sign << 7));
    return 0;
}

# ================================================================
# Point decompression: 32 bytes -> point
# Recover x from y using curve equation: x^2 = (y^2-1)/(dy^2+1)
# ================================================================

var _gdc_u = 0;
var _gdc_v = 0;
var _gdc_y2 = 0;
var _gdc_one = 0;
var _gdc_v3 = 0;
var _gdc_v7 = 0;
var _gdc_uv3 = 0;
var _gdc_uv7 = 0;
var _gdc_pow = 0;
var _gdc_x = 0;
var _gdc_check = 0;
var _gdc_vx2 = 0;
var _gdc_y = 0;
var _gdc_s_copy = 0;
var _gdc_x_sign = 0;
var _gdc_p_out = 0;
var _gdc_exp = 0;
var _gdc_inited = 0;

fn ge_from_bytes(p, s) {
    ed25519_init();
    if (_gdc_inited == 0) {
        _gdc_u = alloc(32); _gdc_v = alloc(32); _gdc_y2 = alloc(32);
        _gdc_one = u256_from(1); _gdc_v3 = alloc(32); _gdc_v7 = alloc(32);
        _gdc_uv3 = alloc(32); _gdc_uv7 = alloc(32); _gdc_pow = alloc(32);
        _gdc_x = alloc(32); _gdc_check = alloc(32); _gdc_vx2 = alloc(32);
        _gdc_y = alloc(32); _gdc_s_copy = alloc(32);
        _gdc_exp = u256_from_hex("0ffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffd");
        _gdc_inited = 1;
    }
    _gdc_p_out = p;

    # Decode y from bytes, clear sign bit
    _gdc_x_sign = (load8(s + 31) >> 7) & 1;
    memcpy(_gdc_s_copy, s, 32);
    store8(_gdc_s_copy + 31, load8(_gdc_s_copy + 31) & 0x7F);

    # Load y as u256 from little-endian bytes
    var li = 0;
    while (li < 4) {
        var v = (load8(_gdc_s_copy + li*8) & 0xFF)
        | ((load8(_gdc_s_copy + li*8+1) & 0xFF) << 8)
        | ((load8(_gdc_s_copy + li*8+2) & 0xFF) << 16)
        | ((load8(_gdc_s_copy + li*8+3) & 0xFF) << 24)
        | ((load8(_gdc_s_copy + li*8+4) & 0xFF) << 32)
        | ((load8(_gdc_s_copy + li*8+5) & 0xFF) << 40)
        | ((load8(_gdc_s_copy + li*8+6) & 0xFF) << 48)
        | ((load8(_gdc_s_copy + li*8+7) & 0xFF) << 56);
        u256_set_limb(_gdc_y, li, v);
        li = li + 1;
    }

    # u = y^2 - 1
    fp_sq(_gdc_y2, _gdc_y);
    fp_sub(_gdc_u, _gdc_y2, _gdc_one);

    # v = d*y^2 + 1
    fp_mul(_gdc_v, _ed_d, _gdc_y2);
    fp_add(_gdc_v, _gdc_v, _gdc_one);

    # candidate = u * v^3 * (u*v^7)^((p-5)/8)
    fp_sq(_gdc_v3, _gdc_v);
    fp_mul(_gdc_v3, _gdc_v3, _gdc_v);        # v^3
    fp_sq(_gdc_v7, _gdc_v3);
    fp_mul(_gdc_v7, _gdc_v7, _gdc_v);        # v^7
    fp_mul(_gdc_uv7, _gdc_u, _gdc_v7);       # u*v^7
    fp_mul(_gdc_uv3, _gdc_u, _gdc_v3);       # u*v^3

    fp_pow(_gdc_pow, _gdc_uv7, _gdc_exp);

    # x = u*v^3 * pow
    fp_mul(_gdc_x, _gdc_uv3, _gdc_pow);

    # Verify: v*x^2 == u?
    fp_sq(_gdc_vx2, _gdc_x);
    fp_mul(_gdc_check, _gdc_v, _gdc_vx2);

    # If check != u, try x * sqrt(-1)
    if (u256_eq(_gdc_check, _gdc_u) == 0) {
        fp_mul(_gdc_x, _gdc_x, _ed_sqrtm1);
    }

    # Adjust sign
    if ((u256_limb(_gdc_x, 0) & 1) != _gdc_x_sign) {
        fp_neg(_gdc_x, _gdc_x);
    }

    # Set point: X=x, Y=y, Z=1, T=x*y
    u256_copy(ge_x(_gdc_p_out), _gdc_x);
    u256_copy(ge_y(_gdc_p_out), _gdc_y);
    var one_z = u256_from(1);
    u256_copy(ge_z(_gdc_p_out), one_z);
    fp_mul(ge_t(_gdc_p_out), _gdc_x, _gdc_y);
    return 0;
}

# ================================================================
# Ed25519 initialization
# ================================================================

fn ed25519_init() {
    if (_ed25519_inited == 1) { return 0; }
    _init_ed_p();

    # Pre-computed constants (avoids expensive fp_pow at init)

    # d = -121665/121666 mod p
    # = 0x52036cee2b6ffe738cc740797779e89800700a4d4141d8ab75eb4dca135978a3
    _ed_d = u256_from_hex("52036cee2b6ffe738cc740797779e89800700a4d4141d8ab75eb4dca135978a3");

    # 2*d
    _ed_2d = alloc(32);
    fp_add(_ed_2d, _ed_d, _ed_d);

    # sqrt(-1) mod p
    # = 0x2b8324804fc1df0b2b4d00993dfbd7a72f431806ad2fe478c4ee1b274a0ea0b0
    _ed_sqrtm1 = u256_from_hex("2b8324804fc1df0b2b4d00993dfbd7a72f431806ad2fe478c4ee1b274a0ea0b0");

    # L (group order)
    _ed_L = u256_from_hex("1000000000000000000000000000000014def9dea2f79cd65812631a5cf5d3ed");

    # Base point B: pre-computed extended coordinates
    # B.y = 4/5 mod p = 0x6666...6658
    # B.x = recovered from curve equation
    # Encoded point (compressed): 5866666666666666666666666666666666666666666666666666666666666666
    # X = 0x216936d3cd6e53fec0a4e231fdd6dc5c692cc7609525a7b2c9562d608f25d51a
    # Y = 0x6666666666666666666666666666666666666666666666666666666666666658
    _ed_B = alloc(128);
    var Bx = u256_from_hex("216936d3cd6e53fec0a4e231fdd6dc5c692cc7609525a7b2c9562d608f25d51a");
    var By = u256_from_hex("6666666666666666666666666666666666666666666666666666666666666658");
    var Bz = u256_from(1);
    var Bt = alloc(32);
    fp_mul(Bt, Bx, By);
    u256_copy(ge_x(_ed_B), Bx);
    u256_copy(ge_y(_ed_B), By);
    u256_copy(ge_z(_ed_B), Bz);
    u256_copy(ge_t(_ed_B), Bt);

    _ed25519_inited = 1;
    return 0;
}

# ================================================================
# Scalar reduce: 64-byte hash -> 32-byte scalar mod L
# ================================================================

var _scr_lo = 0;
var _scr_hi = 0;
var _scr_prod = 0;
var _scr_r256 = 0;
var _scr_inited = 0;

fn sc_reduce(out, s64) {
    # Reduce 512-bit value mod L using: val = hi*2^256 + lo ≡ hi*R + lo (mod L)
    # where R = 2^256 mod L. Iterate until hi == 0.
    if (_scr_inited == 0) {
        _scr_lo = alloc(32);
        _scr_hi = alloc(32);
        _scr_prod = alloc(64);
        _scr_r256 = u256_from_hex("0ffffffffffffffffffffffffffffffec6ef5bf4737dcf70d6ec31748d98951d");
        _scr_inited = 1;
    }

    # Load 64-byte input as two u256 (little-endian)
    var li = 0;
    while (li < 4) {
        var v = (load8(s64 + li*8) & 0xFF)
        | ((load8(s64 + li*8+1) & 0xFF) << 8)
        | ((load8(s64 + li*8+2) & 0xFF) << 16)
        | ((load8(s64 + li*8+3) & 0xFF) << 24)
        | ((load8(s64 + li*8+4) & 0xFF) << 32)
        | ((load8(s64 + li*8+5) & 0xFF) << 40)
        | ((load8(s64 + li*8+6) & 0xFF) << 48)
        | ((load8(s64 + li*8+7) & 0xFF) << 56);
        u256_set_limb(_scr_lo, li, v);
        li = li + 1;
    }
    li = 0;
    while (li < 4) {
        var v = (load8(s64 + 32 + li*8) & 0xFF)
        | ((load8(s64 + 32 + li*8+1) & 0xFF) << 8)
        | ((load8(s64 + 32 + li*8+2) & 0xFF) << 16)
        | ((load8(s64 + 32 + li*8+3) & 0xFF) << 24)
        | ((load8(s64 + 32 + li*8+4) & 0xFF) << 32)
        | ((load8(s64 + 32 + li*8+5) & 0xFF) << 40)
        | ((load8(s64 + 32 + li*8+6) & 0xFF) << 48)
        | ((load8(s64 + 32 + li*8+7) & 0xFF) << 56);
        u256_set_limb(_scr_hi, li, v);
        li = li + 1;
    }

    # Iteratively reduce: lo = lo + hi*R, split result, repeat until hi == 0
    while (u256_is_zero(_scr_hi) == 0) {
        u256_mul_full(_scr_prod, _scr_hi, _scr_r256);
        # new_hi = product high 256 bits
        store64(_scr_hi, load64(_scr_prod + 32));
        store64(_scr_hi + 8, load64(_scr_prod + 40));
        store64(_scr_hi + 16, load64(_scr_prod + 48));
        store64(_scr_hi + 24, load64(_scr_prod + 56));
        # new_lo = old_lo + product_lo (carry propagates to hi)
        var carry = u256_add(_scr_lo, _scr_lo, _scr_prod);
        if (carry > 0) {
            # Add carry to hi limb 0, propagate manually
            var h0 = load64(_scr_hi) + 1;
            store64(_scr_hi, h0);
            if (h0 == 0) {
                var h1 = load64(_scr_hi + 8) + 1;
                store64(_scr_hi + 8, h1);
                if (h1 == 0) {
                    var h2 = load64(_scr_hi + 16) + 1;
                    store64(_scr_hi + 16, h2);
                    if (h2 == 0) {
                        store64(_scr_hi + 24, load64(_scr_hi + 24) + 1);
                    }
                }
            }
        }
    }

    # Final reduction mod L
    while (u256_cmp(_scr_lo, _ed_L) >= 0) {
        u256_sub(_scr_lo, _scr_lo, _ed_L);
    }

    u256_copy(out, _scr_lo);
    return 0;
}

# ================================================================
# sc_muladd: out = (a * b + c) mod L
# ================================================================

var _scma_prod = 0;

fn sc_muladd(out, a, b, c) {
    if (_scma_prod == 0) { _scma_prod = alloc(64); }
    u256_mul_full(_scma_prod, a, b);

    # Add c to the 512-bit product (low 256 bits, propagate carry to high)
    var carry = u256_add(_scma_prod, _scma_prod, c);
    if (carry > 0) {
        store64(_scma_prod + 32, load64(_scma_prod + 32) + carry);
    }

    sc_reduce(out, _scma_prod);
    return 0;
}

# ================================================================
# Ed25519 keypair: seed (32 bytes) -> sk (64 bytes), pk (32 bytes)
# ================================================================

var _kp_hash = 0;
var _kp_scalar = 0;

fn ed25519_keypair(seed, sk_out, pk_out) {
    ed25519_init();
    if (_kp_hash == 0) { _kp_hash = alloc(64); _kp_scalar = alloc(32); }
    sha512(seed, 32, _kp_hash);

    # Clamp scalar (first 32 bytes)
    store8(_kp_hash, load8(_kp_hash) & 0xF8);
    store8(_kp_hash + 31, (load8(_kp_hash + 31) & 0x7F) | 0x40);

    # Copy scalar to dedicated heap buffer (survives nested calls)
    memcpy(_kp_scalar, _kp_hash, 32);

    # A = [a]B
    var A = ge_alloc();
    ge_scalarmult(A, _kp_scalar, _ed_B);
    ge_to_bytes(pk_out, A);

    memcpy(sk_out, seed, 32);
    memcpy(sk_out + 32, pk_out, 32);

    # Zeroize secret scalar buffers. _kp_scalar holds the clamped
    # private scalar a; _kp_hash[0..32] is a copy of it.
    memset(_kp_hash, 0, 64);
    memset(_kp_scalar, 0, 32);
    return 0;
}

# ================================================================
# Ed25519 sign: sk (64b), msg, msg_len -> sig (64b)
# ================================================================

var _sign_az = 0;
var _sign_nhash = 0;
var _sign_hram = 0;
var _sign_sk = 0;
var _sign_msg = 0;
var _sign_msg_len = 0;
var _sign_sig_out = 0;
var _sign_r_scalar = 0;
var _sign_h_scalar = 0;
var _sign_a_scalar = 0;

fn ed25519_sign(sk, msg, msg_len, sig_out) {
    ed25519_init();
    if (_sign_az == 0) {
        _sign_az = alloc(64);
        _sign_nhash = alloc(64);
        _sign_hram = alloc(64);
        _sign_r_scalar = alloc(32);
        _sign_h_scalar = alloc(32);
        _sign_a_scalar = alloc(32);
    }
    _sign_sk = sk;
    _sign_msg = msg;
    _sign_msg_len = msg_len;
    _sign_sig_out = sig_out;

    sha512(_sign_sk, 32, _sign_az);
    store8(_sign_az, load8(_sign_az) & 0xF8);
    store8(_sign_az + 31, (load8(_sign_az + 31) & 0x7F) | 0x40);

    # r = SHA-512(az[32..64] || msg) mod L
    var nctx = sha512_init();
    sha512_update(nctx, _sign_az + 32, 32);
    sha512_update(nctx, _sign_msg, _sign_msg_len);
    sha512_finalize(nctx, _sign_nhash);
    fl_free(nctx);

    sc_reduce(_sign_r_scalar, _sign_nhash);

    # R = [r]B
    var R_point = ge_alloc();
    ge_scalarmult(R_point, _sign_r_scalar, _ed_B);
    ge_to_bytes(_sign_sig_out, R_point);

    # h = SHA-512(R || pk || msg) mod L
    var hctx = sha512_init();
    sha512_update(hctx, _sign_sig_out, 32);
    sha512_update(hctx, _sign_sk + 32, 32);
    sha512_update(hctx, _sign_msg, _sign_msg_len);
    sha512_finalize(hctx, _sign_hram);
    fl_free(hctx);

    sc_reduce(_sign_h_scalar, _sign_hram);

    # Load a from az[0..32] as u256
    var li = 0;
    while (li < 4) {
        var v = (load8(_sign_az + li*8) & 0xFF)
        | ((load8(_sign_az + li*8+1) & 0xFF) << 8)
        | ((load8(_sign_az + li*8+2) & 0xFF) << 16)
        | ((load8(_sign_az + li*8+3) & 0xFF) << 24)
        | ((load8(_sign_az + li*8+4) & 0xFF) << 32)
        | ((load8(_sign_az + li*8+5) & 0xFF) << 40)
        | ((load8(_sign_az + li*8+6) & 0xFF) << 48)
        | ((load8(_sign_az + li*8+7) & 0xFF) << 56);
        u256_set_limb(_sign_a_scalar, li, v);
        li = li + 1;
    }

    # S = (r + h*a) mod L
    var S_result = alloc(32);
    sc_muladd(S_result, _sign_h_scalar, _sign_a_scalar, _sign_r_scalar);

    # Write S as little-endian bytes to sig_out+32
    li = 0;
    while (li < 4) {
        var v = u256_limb(S_result, li);
        store8(_sign_sig_out + 32 + li*8, v & 0xFF);
        store8(_sign_sig_out + 32 + li*8 + 1, (v >> 8) & 0xFF);
        store8(_sign_sig_out + 32 + li*8 + 2, (v >> 16) & 0xFF);
        store8(_sign_sig_out + 32 + li*8 + 3, (v >> 24) & 0xFF);
        store8(_sign_sig_out + 32 + li*8 + 4, (v >> 32) & 0xFF);
        store8(_sign_sig_out + 32 + li*8 + 5, (v >> 40) & 0xFF);
        store8(_sign_sig_out + 32 + li*8 + 6, (v >> 48) & 0xFF);
        store8(_sign_sig_out + 32 + li*8 + 7, (v >> 56) & 0xFF);
        li = li + 1;
    }

    # Zeroize all secret/derived material. _sign_az holds H(sk)[0..64]
    # (the clamped scalar a and nonce seed). _sign_r_scalar is the
    # per-signature nonce; _sign_a_scalar is the long-term scalar a
    # re-loaded as u256. Leaking any one recovers the signing secret.
    memset(_sign_az, 0, 64);
    memset(_sign_nhash, 0, 64);
    memset(_sign_r_scalar, 0, 32);
    memset(_sign_a_scalar, 0, 32);
    return 0;
}

# ================================================================
# Ed25519 verify: pk (32b), msg, msg_len, sig (64b) -> 0/1
# ================================================================

var _ver_pk = 0;
var _ver_msg = 0;
var _ver_msg_len = 0;
var _ver_sig = 0;
var _ver_hram = 0;
var _ver_h_scalar = 0;
var _ver_S_scalar = 0;
var _ver_R_bytes = 0;

fn ed25519_verify(pk, msg, msg_len, sig) {
    ed25519_init();
    if (_ver_hram == 0) {
        _ver_hram = alloc(64);
        _ver_h_scalar = alloc(32);
        _ver_S_scalar = alloc(32);
        _ver_R_bytes = alloc(32);
    }
    _ver_pk = pk;
    _ver_msg = msg;
    _ver_msg_len = msg_len;
    _ver_sig = sig;

    var A = ge_alloc();
    ge_from_bytes(A, _ver_pk);

    # h = SHA-512(R || pk || msg) mod L
    var hctx = sha512_init();
    sha512_update(hctx, _ver_sig, 32);
    sha512_update(hctx, _ver_pk, 32);
    sha512_update(hctx, _ver_msg, _ver_msg_len);
    sha512_finalize(hctx, _ver_hram);
    fl_free(hctx);

    sc_reduce(_ver_h_scalar, _ver_hram);

    # Load S from sig[32..64] as scalar
    var li = 0;
    while (li < 4) {
        var v = (load8(_ver_sig + 32 + li*8) & 0xFF)
        | ((load8(_ver_sig + 32 + li*8+1) & 0xFF) << 8)
        | ((load8(_ver_sig + 32 + li*8+2) & 0xFF) << 16)
        | ((load8(_ver_sig + 32 + li*8+3) & 0xFF) << 24)
        | ((load8(_ver_sig + 32 + li*8+4) & 0xFF) << 32)
        | ((load8(_ver_sig + 32 + li*8+5) & 0xFF) << 40)
        | ((load8(_ver_sig + 32 + li*8+6) & 0xFF) << 48)
        | ((load8(_ver_sig + 32 + li*8+7) & 0xFF) << 56);
        u256_set_limb(_ver_S_scalar, li, v);
        li = li + 1;
    }

    # RFC 8032 §5.1.7 / §8.4: reject non-canonical S (S must be < L).
    # Prevents signature malleability — the same (pk, msg) must have
    # exactly one valid signature encoding.
    if (u256_cmp(_ver_S_scalar, _ed_L) >= 0) { return 0; }

    # [S]B
    var SB = ge_alloc();
    ge_scalarmult(SB, _ver_S_scalar, _ed_B);

    # [h]A
    var hA = ge_alloc();
    ge_scalarmult(hA, _ver_h_scalar, A);

    # R_check = [S]B - [h]A (negate hA: negate X and T)
    fp_neg(ge_x(hA), ge_x(hA));
    fp_neg(ge_t(hA), ge_t(hA));

    var R_check = ge_alloc();
    ge_add(R_check, SB, hA);

    ge_to_bytes(_ver_R_bytes, R_check);

    return ct_eq(_ver_R_bytes, 32, _ver_sig, 32);
}

# ================================================================
# Generate random keypair
# ================================================================

fn ed25519_generate_keypair(sk_out, pk_out) {
    var seed[32];
    var fd = file_open("/dev/urandom", 0, 0);
    file_read(fd, &seed, 32);
    file_close(fd);
    ed25519_keypair(&seed, sk_out, pk_out);
    memset(&seed, 0, 32);
    return 0;
}

# --- trust.cyr ---

# trust.cyr — signing, verification, key management
# Ed25519 (RFC 8032) for asymmetric signing, HMAC-SHA256 for symmetric.

# ================================================================
# KeyRole
# ================================================================

enum KeyRole {
    KEY_ROLE_ROOT = 0;
    KEY_ROLE_INTERMEDIATE = 1;
    KEY_ROLE_PUBLISHER = 2;
}

fn key_role_name(role) {
    if (role == KEY_ROLE_ROOT) { return "Root"; }
    if (role == KEY_ROLE_INTERMEDIATE) { return "Intermediate"; }
    if (role == KEY_ROLE_PUBLISHER) { return "Publisher"; }
    return "unknown";
}

# ================================================================
# KeyVersion (88 bytes)
# ================================================================
# Layout:
#   +0   key_id          (C-string ptr)
#   +8   valid_from      (epoch seconds)
#   +16  valid_until     (epoch seconds, 0 = no expiry)
#   +24  public_key_hex  (C-string ptr, 64-char hex)
#   +32  role            (i64 KEY_ROLE_*)
#   +40  issued_by       (C-string ptr, 0 = self-signed)
#   +48  issuer_sig      (ptr to raw bytes, 0 = none)
#   +56  issuer_sig_len  (i64)
#   +64  pub_name        (C-string ptr, 0 = none)
#   +72  pub_contact     (C-string ptr, 0 = none)
#   +80  secret_key      (ptr to 32 raw bytes, 0 = none, for HMAC signing)

fn key_version_new(key_id, public_key_hex) {
    var kv = fl_alloc(88);
    store64(kv, key_id);
    store64(kv + 8, clock_epoch_secs());
    store64(kv + 16, 0);
    store64(kv + 24, public_key_hex);
    store64(kv + 32, KEY_ROLE_PUBLISHER);
    store64(kv + 40, 0);
    store64(kv + 48, 0);
    store64(kv + 56, 0);
    store64(kv + 64, 0);
    store64(kv + 72, 0);
    store64(kv + 80, 0);
    return kv;
}

fn kv_key_id(kv) { return load64(kv); }
fn kv_valid_from(kv) { return load64(kv + 8); }
fn kv_valid_until(kv) { return load64(kv + 16); }
fn kv_public_key_hex(kv) { return load64(kv + 24); }
fn kv_role(kv) { return load64(kv + 32); }
fn kv_issued_by(kv) { return load64(kv + 40); }
fn kv_pub_name(kv) { return load64(kv + 64); }
fn kv_pub_contact(kv) { return load64(kv + 72); }
fn kv_secret_key(kv) { return load64(kv + 80); }

fn kv_set_valid_from(kv, v) { store64(kv + 8, v); return kv; }
fn kv_set_valid_until(kv, v) { store64(kv + 16, v); return kv; }
fn kv_set_role(kv, r) { store64(kv + 32, r); return kv; }
fn kv_set_issued_by(kv, v) { store64(kv + 40, v); return kv; }
fn kv_set_pub_name(kv, v) { store64(kv + 64, v); return kv; }
fn kv_set_pub_contact(kv, v) { store64(kv + 72, v); return kv; }
fn kv_set_secret_key(kv, sk) { store64(kv + 80, sk); return kv; }

fn kv_is_valid_at(kv, when) {
    if (when < load64(kv + 8)) { return 0; }
    var until = load64(kv + 16);
    if (until != 0) {
        if (when > until) { return 0; }
    }
    return 1;
}

# ================================================================
# PublisherKeyring (16 bytes)
# ================================================================
# Layout:
#   +0   keys_map   (hashmap: key_id -> vec of KeyVersion)
#   +8   keys_dir   (C-string ptr)

fn keyring_new(keys_dir) {
    var kr = fl_alloc(16);
    store64(kr, map_new());
    store64(kr + 8, keys_dir);
    return kr;
}

fn keyring_add_key(kr, kv) {
    var m = load64(kr);
    var kid = kv_key_id(kv);
    var existing = map_get(m, kid);
    if (existing == 0) {
        var v = vec_new();
        vec_push(v, kv);
        map_set(m, kid, v);
    } else {
        vec_push(existing, kv);
    }
    return kr;
}

fn keyring_get_current(kr, key_id) {
    var m = load64(kr);
    var versions = map_get(m, key_id);
    if (versions == 0) { return 0; }
    var now = clock_epoch_secs();
    var vlen = vec_len(versions);
    # Return last valid key
    var i = vlen - 1;
    while (i >= 0) {
        var kv = vec_get(versions, i);
        if (kv_is_valid_at(kv, now) == 1) { return kv; }
        i = i - 1;
    }
    return 0;
}

fn keyring_get_all_versions(kr, key_id) {
    var m = load64(kr);
    var versions = map_get(m, key_id);
    return versions;
}

fn keyring_len(kr) {
    var m = load64(kr);
    return map_count(m);
}

fn keyring_find_by_role(kr, role) {
    var result = vec_new();
    var m = load64(kr);
    var keys = map_keys(m);
    var klen = vec_len(keys);
    var i = 0;
    while (i < klen) {
        var kid = vec_get(keys, i);
        var versions = map_get(m, kid);
        var vlen = vec_len(versions);
        var j = 0;
        while (j < vlen) {
            var kv = vec_get(versions, j);
            if (kv_role(kv) == role) {
                vec_push(result, kv);
            }
            j = j + 1;
        }
        i = i + 1;
    }
    return result;
}

fn keyring_is_empty(kr) {
    if (keyring_len(kr) == 0) { return 1; }
    return 0;
}

# Get key valid at a specific time
fn keyring_get_key_valid_at(kr, key_id, when) {
    var m = load64(kr);
    var versions = map_get(m, key_id);
    if (versions == 0) { return 0; }
    var vlen = vec_len(versions);
    var i = vlen - 1;
    while (i >= 0) {
        var kv = vec_get(versions, i);
        if (kv_is_valid_at(kv, when) == 1) { return kv; }
        i = i - 1;
    }
    return 0;
}

# Get all key IDs in the keyring
fn keyring_key_ids(kr) {
    var m = load64(kr);
    return map_keys(m);
}

# Find keys by publisher name (case-sensitive substring match)
fn keyring_find_by_publisher(kr, name) {
    var result = vec_new();
    var m = load64(kr);
    var keys = map_keys(m);
    var klen = vec_len(keys);
    var nlen = strlen(name);
    var i = 0;
    while (i < klen) {
        var kid = vec_get(keys, i);
        var versions = map_get(m, kid);
        var vlen = vec_len(versions);
        var j = 0;
        while (j < vlen) {
            var kv = vec_get(versions, j);
            var pname = kv_pub_name(kv);
            if (pname != 0) {
                # Simple substring search
                var plen = strlen(pname);
                var k = 0;
                while (k + nlen <= plen) {
                    if (memeq(pname + k, name, nlen) == 1) {
                        vec_push(result, kv);
                        k = plen;  # break
                    }
                    k = k + 1;
                }
            }
            j = j + 1;
        }
        i = i + 1;
    }
    return result;
}

# Rotate key: create new version with overlap period
fn keyring_rotate_key(kr, key_id, new_pk_hex, overlap_until) {
    var new_kv = key_version_new(key_id, new_pk_hex);
    # Set the old key's valid_until to overlap_until
    var m = load64(kr);
    var versions = map_get(m, key_id);
    if (versions != 0) {
        var vlen = vec_len(versions);
        if (vlen > 0) {
            var old_kv = vec_get(versions, vlen - 1);
            kv_set_valid_until(old_kv, overlap_until);
        }
    }
    keyring_add_key(kr, new_kv);
    return new_kv;
}

# Get trust chain from key to root (following issued_by links)
fn keyring_get_chain(kr, key_id) {
    var chain = vec_new();
    var current_id = key_id;
    var max_depth = 10;
    var depth = 0;
    while (current_id != 0) {
        if (depth >= max_depth) { return chain; }
        var kv = keyring_get_current(kr, current_id);
        if (kv == 0) { return chain; }
        vec_push(chain, kv);
        current_id = kv_issued_by(kv);
        if (current_id == 0) { return chain; }
        # Check for self-signed (root)
        if (streq(current_id, key_id) == 1) { return chain; }
        depth = depth + 1;
    }
    return chain;
}

# Validate chain: verify each key was issued by its parent
fn keyring_validate_chain(kr, key_id) {
    var chain = keyring_get_chain(kr, key_id);
    var clen = vec_len(chain);
    if (clen == 0) { return 0; }
    # Last key in chain should be root
    var root = vec_get(chain, clen - 1);
    if (kv_role(root) != KEY_ROLE_ROOT) { return 0; }
    return 1;
}

# Validate key_id as a safe filename:
#   - non-empty, max 64 chars
#   - only [A-Za-z0-9_-] (no '/', '.', or control bytes)
# Returns 1 if safe, 0 otherwise. Prevents path traversal in keyring_save.
fn _is_safe_key_id(kid) {
    if (kid == 0) { return 0; }
    var klen = strlen(kid);
    if (klen == 0) { return 0; }
    if (klen > 64) { return 0; }
    var i = 0;
    while (i < klen) {
        var c = load8(kid + i) & 0xFF;
        var ok = 0;
        if (c >= 48) { if (c <= 57) { ok = 1; } }       # 0-9
        if (c >= 65) { if (c <= 90) { ok = 1; } }       # A-Z
        if (c >= 97) { if (c <= 122) { ok = 1; } }      # a-z
        if (c == 95) { ok = 1; }                        # _
        if (c == 45) { ok = 1; }                        # -
        if (ok == 0) { return 0; }
        i = i + 1;
    }
    return 1;
}

# Save keyring to JSON files in keys_dir.
# Returns count of key versions written. Skips any key_id that
# fails _is_safe_key_id or whose full path exceeds 255 bytes.
fn keyring_save(kr) {
    var keys_dir = load64(kr + 8);
    if (keys_dir == 0) { return 0; }
    var m = load64(kr);
    var kids = map_keys(m);
    var klen = vec_len(kids);
    var count = 0;
    var i = 0;
    while (i < klen) {
        var kid = vec_get(kids, i);
        var versions = map_get(m, kid);
        var vlen = vec_len(versions);
        # Validate key_id — reject path traversal or oversized names
        if (_is_safe_key_id(kid) == 0) { i = i + 1; }
        else {
            var dlen = strlen(keys_dir);
            var kidlen = strlen(kid);
            # dlen + "/" + kidlen + ".json" + NUL
            var need = dlen + 1 + kidlen + 5 + 1;
            if (need > 256) { i = i + 1; }
            else {
                # Write JSON file: keys_dir/key_id.json
                var path = alloc(256);
                var pos = 0;
                memcpy(path, keys_dir, dlen);
                pos = pos + dlen;
                store8(path + pos, 47);  # /
                pos = pos + 1;
                memcpy(path + pos, kid, kidlen);
                pos = pos + kidlen;
                memcpy(path + pos, ".json", 5);
                pos = pos + 5;
                store8(path + pos, 0);

                var fd = file_open(path, 577, 420);  # O_WRONLY|O_CREAT|O_TRUNC, 0644
                if (fd >= 0) {
                    file_write(fd, "[", 1);
                    var j = 0;
                    while (j < vlen) {
                        var kv = vec_get(versions, j);
                        if (j > 0) { file_write(fd, ",", 1); }
                        file_write(fd, "{\"key_id\":\"", 11);
                            json_write_escaped(fd, kv_key_id(kv), strlen(kv_key_id(kv)));
                            file_write(fd, "\",\"public_key_hex\":\"", 20);
                            json_write_escaped(fd, kv_public_key_hex(kv), strlen(kv_public_key_hex(kv)));
                            file_write(fd, "\",\"role\":\"", 10);
                            var rn = key_role_name(kv_role(kv));
                            json_write_escaped(fd, rn, strlen(rn));
                            file_write(fd, "\"}", 2);
                        j = j + 1;
                    }
                    file_write(fd, "]", 1);
                    file_close(fd);
                    count = count + vlen;
                }
                i = i + 1;
            }
        }
    }
    return count;
}

# ================================================================
# JSON string escaping
# ================================================================
# Write `s` (length `slen`) to `fd`, escaping the minimal RFC 8259 set:
# `"`, `\`, and control bytes < 0x20. Non-ASCII bytes pass through
# verbatim (sigil stores UTF-8 path/hex content). Used by persistence
# paths to prevent JSON injection from tampered field values.
fn json_write_escaped(fd, s, slen) {
    if (s == 0) { return 0; }
    var i = 0;
    var chunk_start = 0;
    while (i < slen) {
        var c = load8(s + i) & 0xFF;
        var needs_escape = 0;
        if (c == 34) { needs_escape = 1; }       # "
        elif (c == 92) { needs_escape = 1; }     # \
        elif (c < 32) { needs_escape = 1; }      # control
        if (needs_escape == 1) {
            if (i > chunk_start) {
                file_write(fd, s + chunk_start, i - chunk_start);
            }
            if (c == 34) { file_write(fd, "\\\"", 2); }
            elif (c == 92) { file_write(fd, "\\\\", 2); }
            elif (c == 8) { file_write(fd, "\\b", 2); }
            elif (c == 9) { file_write(fd, "\\t", 2); }
            elif (c == 10) { file_write(fd, "\\n", 2); }
            elif (c == 12) { file_write(fd, "\\f", 2); }
            elif (c == 13) { file_write(fd, "\\r", 2); }
            else {
                # \u00XX for other control bytes
                var hex_buf[6];
                store8(&hex_buf, 92);   # \
                store8(&hex_buf + 1, 117); # u
                store8(&hex_buf + 2, 48);  # 0
                store8(&hex_buf + 3, 48);  # 0
                var hi = (c >> 4) & 0xF;
                var lo = c & 0xF;
                if (hi < 10) { store8(&hex_buf + 4, 48 + hi); }
                else { store8(&hex_buf + 4, 87 + hi); }
                if (lo < 10) { store8(&hex_buf + 5, 48 + lo); }
                else { store8(&hex_buf + 5, 87 + lo); }
                file_write(fd, &hex_buf, 6);
            }
            chunk_start = i + 1;
        }
        i = i + 1;
    }
    if (slen > chunk_start) {
        file_write(fd, s + chunk_start, slen - chunk_start);
    }
    return 0;
}

# ================================================================
# Hash functions
# ================================================================

fn hash_data(data, len) {
    return sha256_hex(data, len);
}

fn hash_file(path) {
    var fd = file_open(path, 0, 0);
    if (fd < 0) { return 0; }
    var ctx = sha256_init();
    var buf[4096];
    var n = file_read(fd, &buf, 4096);
    while (n > 0) {
        sha256_update(ctx, &buf, n);
        n = file_read(fd, &buf, 4096);
    }
    file_close(fd);
    var digest[32];
    sha256_finalize(ctx, &digest);
    fl_free(ctx);
    return hex_encode(&digest, 32);
}

# ================================================================
# Signing / verification (Ed25519)
# ================================================================

fn sign_data(data, len, secret_key) {
    # secret_key is 64 bytes (seed || pk) from ed25519_keypair
    var sig = alloc(64);
    ed25519_sign(secret_key, data, len, sig);
    return sig;
}

fn verify_data(data, len, sig, public_key) {
    # public_key is 32 bytes
    return ed25519_verify(public_key, data, len, sig);
}

# ================================================================
# Key generation (Ed25519)
# ================================================================

fn generate_keypair(sk_out, pk_out) {
    # sk_out: 64 bytes (seed || pk), pk_out: 32 bytes
    # Returns key_id (C-string) on success, 0 on entropy failure.
    var seed[32];
    memset(&seed, 0, 32);
    var fd = file_open("/dev/urandom", 0, 0);
    if (fd < 0) { return 0; }
    var got = 0;
    while (got < 32) {
        var n = file_read(fd, (&seed) + got, 32 - got);
        if (n <= 0) {
            file_close(fd);
            memset(&seed, 0, 32);
            return 0;
        }
        got = got + n;
    }
    file_close(fd);
    ed25519_keypair(&seed, sk_out, pk_out);
    memset(&seed, 0, 32);

    # key_id = first 16 hex chars of public key
    var hex = hex_encode(pk_out, 32);
    var kid = alloc(17);
    memcpy(kid, hex, 16);
    store8(kid + 16, 0);
    return kid;
}

fn key_id_from_public_hex(pk_hex) {
    var kid = alloc(17);
    memcpy(kid, pk_hex, 16);
    store8(kid + 16, 0);
    return kid;
}

# ================================================================
# Key zeroization
# ================================================================

fn zeroize_key(key_buf, len) {
    memset(key_buf, 0, len);
    return 0;
}

# --- integrity.cyr ---

# integrity.cyr — file integrity measurement and verification

# ================================================================
# MeasurementStatus
# ================================================================

enum MeasurementStatus {
    MSTATUS_PENDING = 0;
    MSTATUS_VERIFIED = 1;
    MSTATUS_MISMATCH = 2;
    MSTATUS_FILE_NOT_FOUND = 3;
    MSTATUS_ERROR = 4;
}

fn mstatus_name(s) {
    if (s == MSTATUS_PENDING) { return "Pending"; }
    if (s == MSTATUS_VERIFIED) { return "Verified"; }
    if (s == MSTATUS_MISMATCH) { return "Mismatch"; }
    if (s == MSTATUS_FILE_NOT_FOUND) { return "FileNotFound"; }
    if (s == MSTATUS_ERROR) { return "Error"; }
    return "unknown";
}

# ================================================================
# IntegrityMeasurement (48 bytes)
# ================================================================
# Layout:
#   +0   path          (C-string ptr)
#   +8   expected_hash (C-string ptr)
#   +16  actual_hash   (C-string ptr, 0 = not yet measured)
#   +24  measured_at   (epoch seconds)
#   +32  status        (i64 MSTATUS_*)
#   +40  error_msg     (C-string ptr, 0 = none)

fn measurement_new(path, expected_hash) {
    var m = fl_alloc(48);
    store64(m, path);
    store64(m + 8, expected_hash);
    store64(m + 16, 0);
    store64(m + 24, clock_epoch_secs());
    store64(m + 32, MSTATUS_PENDING);
    store64(m + 40, 0);
    return m;
}

fn meas_path(m) { return load64(m); }
fn meas_expected(m) { return load64(m + 8); }
fn meas_actual(m) { return load64(m + 16); }
fn meas_at(m) { return load64(m + 24); }
fn meas_status(m) { return load64(m + 32); }
fn meas_error(m) { return load64(m + 40); }

# ================================================================
# IntegrityPolicy (24 bytes)
# ================================================================
# Layout:
#   +0   measurements   (vec of measurement pointers)
#   +8   check_interval (seconds)
#   +16  enforce        (i64, 0 or 1)

fn integrity_policy_new() {
    var p = fl_alloc(24);
    store64(p, vec_new());
    store64(p + 8, 300);
    store64(p + 16, 0);
    return p;
}

fn ipolicy_measurements(p) { return load64(p); }
fn ipolicy_check_interval(p) { return load64(p + 8); }
fn ipolicy_enforce(p) { return load64(p + 16); }

fn ipolicy_set_enforce(p, v) { store64(p + 16, v); return p; }
fn ipolicy_set_interval(p, v) { store64(p + 8, v); return p; }

fn ipolicy_add(p, path, expected_hash) {
    var m = measurement_new(path, expected_hash);
    vec_push(load64(p), m);
    return p;
}

fn ipolicy_remove(p, path) {
    var measurements = load64(p);
    var mlen = vec_len(measurements);
    var i = 0;
    while (i < mlen) {
        var m = vec_get(measurements, i);
        if (streq(load64(m), path) == 1) {
            vec_remove(measurements, i);
            return 1;
        }
        i = i + 1;
    }
    return 0;
}

fn ipolicy_count(p) {
    return vec_len(load64(p));
}

# ================================================================
# IntegrityReport (40 bytes)
# ================================================================
# Layout:
#   +0   total       (i64)
#   +8   verified    (i64)
#   +16  mismatches  (vec)
#   +24  errors      (vec)
#   +32  checked_at  (epoch seconds)

fn integrity_report_new() {
    var r = fl_alloc(40);
    store64(r, 0);
    store64(r + 8, 0);
    store64(r + 16, vec_new());
    store64(r + 24, vec_new());
    store64(r + 32, clock_epoch_secs());
    return r;
}

fn ireport_total(r) { return load64(r); }
fn ireport_verified(r) { return load64(r + 8); }
fn ireport_mismatches(r) { return load64(r + 16); }
fn ireport_errors(r) { return load64(r + 24); }
fn ireport_checked_at(r) { return load64(r + 32); }

fn ireport_is_clean(r) {
    if (vec_len(load64(r + 16)) == 0) {
        if (vec_len(load64(r + 24)) == 0) {
            return 1;
        }
    }
    return 0;
}

# ================================================================
# IntegrityVerifier (24 bytes)
# ================================================================
# Layout:
#   +0   policy       (IntegrityPolicy ptr)
#   +8   last_report  (IntegrityReport ptr, 0 = none)
#   +16  callback     (fn ptr, 0 = none)

fn integrity_verifier_new(policy) {
    var v = fl_alloc(24);
    store64(v, policy);
    store64(v + 8, 0);
    store64(v + 16, 0);
    return v;
}

fn iv_policy(v) { return load64(v); }
fn iv_last_report(v) { return load64(v + 8); }

fn iv_set_callback(v, cb) { store64(v + 16, cb); return v; }
fn iv_clear_callback(v) { store64(v + 16, 0); return v; }

fn iv_set_policy(v, policy) {
    store64(v, policy);
    store64(v + 8, 0);
    return v;
}

# Compute hash of file contents
fn compute_file_hash(path) {
    return hash_file(path);
}

# Verify a single file against policy
fn iv_verify_file(v, path) {
    var policy = load64(v);
    var measurements = load64(policy);
    var mlen = vec_len(measurements);
    var i = 0;
    while (i < mlen) {
        var m = vec_get(measurements, i);
        if (streq(load64(m), path) == 1) {
            var h = hash_file(path);
            if (h == 0) { return MSTATUS_FILE_NOT_FOUND; }
            var expected = load64(m + 8);
            if (ct_eq(h, strlen(h), expected, strlen(expected)) == 1) {
                return MSTATUS_VERIFIED;
            }
            return MSTATUS_MISMATCH;
        }
        i = i + 1;
    }
    return MSTATUS_ERROR;
}

# Verify all files in policy
fn iv_verify_all(v) {
    var policy = load64(v);
    var measurements = load64(policy);
    var mlen = vec_len(measurements);
    var report = integrity_report_new();
    store64(report, mlen);

    var verified = 0;
    var i = 0;
    while (i < mlen) {
        var m = vec_get(measurements, i);
        var path = load64(m);
        var h = hash_file(path);
        var now = clock_epoch_secs();

        if (h == 0) {
            # File not found or error
            var rm = measurement_new(path, load64(m + 8));
            store64(rm + 24, now);
            store64(rm + 32, MSTATUS_FILE_NOT_FOUND);
            vec_push(load64(report + 24), rm);
        } else {
            var expected = load64(m + 8);
            if (ct_eq(h, strlen(h), expected, strlen(expected)) == 1) {
                verified = verified + 1;
                store64(m + 16, h);
                store64(m + 24, now);
                store64(m + 32, MSTATUS_VERIFIED);
            } else {
                var rm = measurement_new(path, expected);
                store64(rm + 16, h);
                store64(rm + 24, now);
                store64(rm + 32, MSTATUS_MISMATCH);
                vec_push(load64(report + 16), rm);
            }
        }
        i = i + 1;
    }
    store64(report + 8, verified);
    store64(v + 8, report);
    return report;
}

# Add baseline: hash file and add to policy
fn iv_add_baseline(v, path) {
    var h = hash_file(path);
    if (h == 0) { return 0; }
    var policy = load64(v);
    ipolicy_add(policy, path, h);
    store64(v + 8, 0);
    return h;
}

# Remove baseline
fn iv_remove_baseline(v, path) {
    var policy = load64(v);
    var removed = ipolicy_remove(policy, path);
    if (removed == 1) { store64(v + 8, 0); }
    return removed;
}

# Get tampered files from last report
fn iv_tampered_files(v) {
    var report = load64(v + 8);
    if (report == 0) { return vec_new(); }
    return load64(report + 16);
}

# ================================================================
# IntegritySnapshot — serializable baseline
# ================================================================
# Layout (16 bytes):
#   +0  entries      (vec of {path, hash} pairs)
#   +8  exported_at  (epoch seconds)

fn integrity_snapshot_new() {
    var s = fl_alloc(16);
    store64(s, vec_new());
    store64(s + 8, clock_epoch_secs());
    return s;
}

fn isnap_entries(s) { return load64(s); }
fn isnap_exported_at(s) { return load64(s + 8); }

# BaselineEntry (16 bytes): path + expected_hash
fn baseline_entry_new(path, expected_hash) {
    var e = fl_alloc(16);
    store64(e, path);
    store64(e + 8, expected_hash);
    return e;
}

fn bentry_path(e) { return load64(e); }
fn bentry_hash(e) { return load64(e + 8); }

# Export current baseline as snapshot
fn iv_export_baseline(v) {
    var policy = load64(v);
    var measurements = load64(policy);
    var snap = integrity_snapshot_new();
    var entries = load64(snap);
    var mlen = vec_len(measurements);
    var i = 0;
    while (i < mlen) {
        var m = vec_get(measurements, i);
        var be = baseline_entry_new(meas_path(m), meas_expected(m));
        vec_push(entries, be);
        i = i + 1;
    }
    return snap;
}

# Import snapshot, replacing current policy measurements
fn iv_import_baseline(v, snap) {
    var policy = load64(v);
    var interval = ipolicy_check_interval(policy);
    var enforce = ipolicy_enforce(policy);

    var new_policy = integrity_policy_new();
    ipolicy_set_interval(new_policy, interval);
    ipolicy_set_enforce(new_policy, enforce);

    var entries = isnap_entries(snap);
    var elen = vec_len(entries);
    var i = 0;
    while (i < elen) {
        var be = vec_get(entries, i);
        ipolicy_add(new_policy, bentry_path(be), bentry_hash(be));
        i = i + 1;
    }
    store64(v, new_policy);
    store64(v + 8, 0);
    return elen;
}

# Report summary string
fn ireport_summary(r) {
    # Returns: "Integrity: N/M verified, X mismatches, Y errors"
    # Worst case: 4 × 19-digit i64 + fixed text ≈ 120 bytes.
    # Size 192 gives defense-in-depth headroom for any future text changes.
    var buf = alloc(192);
    var pos = 0;
    memcpy(buf, "Integrity: ", 11);
    pos = 11;
    var vs = fmt_int(ireport_verified(r));
    var vsl = strlen(vs);
    memcpy(buf + pos, vs, vsl);
    pos = pos + vsl;
    store8(buf + pos, 47); # /
    pos = pos + 1;
    var ts = fmt_int(ireport_total(r));
    var tsl = strlen(ts);
    memcpy(buf + pos, ts, tsl);
    pos = pos + tsl;
    memcpy(buf + pos, " verified, ", 11);
    pos = pos + 11;
    var ms = fmt_int(vec_len(ireport_mismatches(r)));
    var msl = strlen(ms);
    memcpy(buf + pos, ms, msl);
    pos = pos + msl;
    memcpy(buf + pos, " mismatches, ", 13);
    pos = pos + 13;
    var es = fmt_int(vec_len(ireport_errors(r)));
    var esl = strlen(es);
    memcpy(buf + pos, es, esl);
    pos = pos + esl;
    memcpy(buf + pos, " errors", 7);
    pos = pos + 7;
    store8(buf + pos, 0);
    return buf;
}

# --- policy.cyr ---

# policy.cyr — revocation list management

# ================================================================
# RevocationEntry (48 bytes)
# ================================================================
# Layout:
#   +0   key_id        (C-string ptr, 0 = none)
#   +8   content_hash  (C-string ptr, 0 = none)
#   +16  reason        (C-string ptr)
#   +24  revoked_at    (epoch seconds)
#   +32  revoked_by    (C-string ptr)
#   +40  revoked_after (epoch seconds, 0 = unconditional)

fn revocation_entry_new(key_id, content_hash, reason, revoked_by) {
    var e = fl_alloc(48);
    store64(e, key_id);
    store64(e + 8, content_hash);
    store64(e + 16, reason);
    store64(e + 24, clock_epoch_secs());
    store64(e + 32, revoked_by);
    store64(e + 40, 0);
    return e;
}

fn rev_key_id(e) { return load64(e); }
fn rev_content_hash(e) { return load64(e + 8); }
fn rev_reason(e) { return load64(e + 16); }
fn rev_at(e) { return load64(e + 24); }
fn rev_by(e) { return load64(e + 32); }
fn rev_after(e) { return load64(e + 40); }
fn rev_set_after(e, v) { store64(e + 40, v); return e; }

# ================================================================
# RevocationList (24 bytes)
# ================================================================
# Layout:
#   +0   entries       (vec of RevocationEntry ptrs)
#   +8   revoked_keys  (hashmap key_id -> 1)
#   +16  revoked_hashes (hashmap content_hash -> 1)

fn revocation_list_new() {
    var rl = fl_alloc(24);
    store64(rl, vec_new());
    store64(rl + 8, map_new());
    store64(rl + 16, map_new());
    return rl;
}

fn rl_add(rl, entry) {
    var kid = load64(entry);
    var chash = load64(entry + 8);
    if (kid == 0) {
        if (chash == 0) { return ERR_INVALID_INPUT; }
    }
    if (kid != 0) {
        map_set(load64(rl + 8), kid, 1);
    }
    if (chash != 0) {
        map_set(load64(rl + 16), chash, 1);
    }
    vec_push(load64(rl), entry);
    return ERR_NONE;
}

fn rl_is_key_revoked(rl, key_id) {
    return rl_is_key_revoked_at(rl, key_id, 0);
}

fn rl_is_key_revoked_at(rl, key_id, at) {
    var keys = load64(rl + 8);
    if (map_get(keys, key_id) == 0) { return 0; }
    if (at == 0) { return 1; }
    # Check entries for revoked_after semantics
    var entries = load64(rl);
    var elen = vec_len(entries);
    var i = 0;
    while (i < elen) {
        var e = vec_get(entries, i);
        var ekid = load64(e);
        if (ekid != 0) {
            if (streq(ekid, key_id) == 1) {
                var after = load64(e + 40);
                if (after == 0) { return 1; }
                if (at >= after) { return 1; }
            }
        }
        i = i + 1;
    }
    return 0;
}

fn rl_is_artifact_revoked(rl, content_hash) {
    return rl_is_artifact_revoked_at(rl, content_hash, 0);
}

fn rl_is_artifact_revoked_at(rl, content_hash, at) {
    var hashes = load64(rl + 16);
    if (map_get(hashes, content_hash) == 0) { return 0; }
    if (at == 0) { return 1; }
    var entries = load64(rl);
    var elen = vec_len(entries);
    var i = 0;
    while (i < elen) {
        var e = vec_get(entries, i);
        var ehash = load64(e + 8);
        if (ehash != 0) {
            if (streq(ehash, content_hash) == 1) {
                var after = load64(e + 40);
                if (after == 0) { return 1; }
                if (at >= after) { return 1; }
            }
        }
        i = i + 1;
    }
    return 0;
}

fn rl_len(rl) { return vec_len(load64(rl)); }
fn rl_is_empty(rl) { if (rl_len(rl) == 0) { return 1; } return 0; }

fn rl_merge(rl, other) {
    var other_entries = load64(other);
    var olen = vec_len(other_entries);
    var added = 0;
    var i = 0;
    while (i < olen) {
        var e = vec_get(other_entries, i);
        # Check for duplicate
        var dup = 0;
        var our_entries = load64(rl);
        var ulen = vec_len(our_entries);
        var j = 0;
        while (j < ulen) {
            var oe = vec_get(our_entries, j);
            var kid_match = 0;
            var hash_match = 0;
            if (load64(e) == 0) { if (load64(oe) == 0) { kid_match = 1; } }
            else { if (load64(oe) != 0) { if (streq(load64(e), load64(oe)) == 1) { kid_match = 1; } } }
            if (load64(e + 8) == 0) { if (load64(oe + 8) == 0) { hash_match = 1; } }
            else { if (load64(oe + 8) != 0) { if (streq(load64(e + 8), load64(oe + 8)) == 1) { hash_match = 1; } } }
            if (kid_match == 1) { if (hash_match == 1) { dup = 1; } }
            j = j + 1;
        }
        if (dup == 0) {
            rl_add(rl, e);
            added = added + 1;
        }
        i = i + 1;
    }
    return added;
}

# ================================================================
# CRL — Certificate Revocation List (40 bytes)
# ================================================================
# Layout:
#   +0   version     (i64)
#   +8   issuer      (C-string ptr)
#   +16  issued_at   (epoch seconds)
#   +24  next_update (epoch seconds, 0 = none)
#   +32  entries     (vec of RevocationEntry ptrs)

fn crl_new(version, issuer) {
    var c = fl_alloc(40);
    store64(c, version);
    store64(c + 8, issuer);
    store64(c + 16, clock_epoch_secs());
    store64(c + 24, 0);
    store64(c + 32, vec_new());
    return c;
}

fn crl_version(c) { return load64(c); }
fn crl_issuer(c) { return load64(c + 8); }
fn crl_issued_at(c) { return load64(c + 16); }
fn crl_next_update(c) { return load64(c + 24); }
fn crl_entries(c) { return load64(c + 32); }

fn crl_set_next_update(c, v) { store64(c + 24, v); return c; }

fn crl_add_entry(c, entry) {
    vec_push(load64(c + 32), entry);
    return c;
}

fn crl_is_stale(c) {
    var next = load64(c + 24);
    if (next == 0) { return 0; }
    if (clock_epoch_secs() > next) { return 1; }
    return 0;
}

fn crl_apply_to(c, rl) {
    var entries = load64(c + 32);
    var elen = vec_len(entries);
    var added = 0;
    var i = 0;
    while (i < elen) {
        var e = vec_get(entries, i);
        var result = rl_add(rl, e);
        if (result == ERR_NONE) { added = added + 1; }
        i = i + 1;
    }
    return added;
}

# --- audit.cyr ---

# audit.cyr — structured audit event logging

# ================================================================
# AuditEvent types
# ================================================================

enum AuditEventType {
    AUDIT_ARTIFACT_VERIFIED = 0;
    AUDIT_ARTIFACT_SIGNED = 1;
    AUDIT_REVOCATION_ADDED = 2;
    AUDIT_KEY_ROTATED = 3;
    AUDIT_CHAIN_VALIDATED = 4;
}

fn audit_event_name(t) {
    if (t == AUDIT_ARTIFACT_VERIFIED) { return "artifact_verified"; }
    if (t == AUDIT_ARTIFACT_SIGNED) { return "artifact_signed"; }
    if (t == AUDIT_REVOCATION_ADDED) { return "revocation_added"; }
    if (t == AUDIT_KEY_ROTATED) { return "key_rotated"; }
    if (t == AUDIT_CHAIN_VALIDATED) { return "chain_validated"; }
    return "unknown";
}

# ================================================================
# AuditEvent (64 bytes)
# ================================================================
# Generic event struct that holds all possible fields.
# Layout:
#   +0   event_type    (i64 AUDIT_*)
#   +8   path          (C-string ptr, 0 = n/a)
#   +16  artifact_type (i64, -1 = n/a)
#   +24  trust_level   (i64, -1 = n/a)
#   +32  passed        (i64, -1 = n/a)
#   +40  content_hash  (C-string ptr, 0 = n/a)
#   +48  key_id        (C-string ptr, 0 = n/a)
#   +56  timestamp     (epoch seconds)

fn audit_event_new(event_type) {
    var e = fl_alloc(64);
    store64(e, event_type);
    store64(e + 8, 0);
    store64(e + 16, 0 - 1);
    store64(e + 24, 0 - 1);
    store64(e + 32, 0 - 1);
    store64(e + 40, 0);
    store64(e + 48, 0);
    store64(e + 56, clock_epoch_secs());
    return e;
}

fn ae_type(e) { return load64(e); }
fn ae_path(e) { return load64(e + 8); }
fn ae_artifact_type(e) { return load64(e + 16); }
fn ae_trust_level(e) { return load64(e + 24); }
fn ae_passed(e) { return load64(e + 32); }
fn ae_content_hash(e) { return load64(e + 40); }
fn ae_key_id(e) { return load64(e + 48); }
fn ae_timestamp(e) { return load64(e + 56); }

fn ae_set_path(e, v) { store64(e + 8, v); return e; }
fn ae_set_artifact_type(e, v) { store64(e + 16, v); return e; }
fn ae_set_trust_level(e, v) { store64(e + 24, v); return e; }
fn ae_set_passed(e, v) { store64(e + 32, v); return e; }
fn ae_set_content_hash(e, v) { store64(e + 40, v); return e; }
fn ae_set_key_id(e, v) { store64(e + 48, v); return e; }

# ================================================================
# Convenience constructors
# ================================================================

fn audit_artifact_verified(path, atype, tlevel, passed, chash) {
    var e = audit_event_new(AUDIT_ARTIFACT_VERIFIED);
    ae_set_path(e, path);
    ae_set_artifact_type(e, atype);
    ae_set_trust_level(e, tlevel);
    ae_set_passed(e, passed);
    ae_set_content_hash(e, chash);
    return e;
}

fn audit_artifact_signed(path, atype, key_id, chash) {
    var e = audit_event_new(AUDIT_ARTIFACT_SIGNED);
    ae_set_path(e, path);
    ae_set_artifact_type(e, atype);
    ae_set_key_id(e, key_id);
    ae_set_content_hash(e, chash);
    return e;
}

fn audit_revocation_added(key_id, chash, reason) {
    var e = audit_event_new(AUDIT_REVOCATION_ADDED);
    ae_set_key_id(e, key_id);
    ae_set_content_hash(e, chash);
    return e;
}

fn audit_key_rotated(old_kid, new_kid) {
    var e = audit_event_new(AUDIT_KEY_ROTATED);
    ae_set_key_id(e, old_kid);
    ae_set_content_hash(e, new_kid);  # reuse field for new key id
    return e;
}

# ================================================================
# AuditLog (8 bytes)
# ================================================================
# Layout:
#   +0   events  (vec of AuditEvent ptrs)

fn audit_log_new() {
    var log = fl_alloc(8);
    store64(log, vec_new());
    return log;
}

fn alog_record(log, event) {
    vec_push(load64(log), event);
    return log;
}

fn alog_events(log) { return load64(log); }
fn alog_len(log) { return vec_len(load64(log)); }
fn alog_is_empty(log) { if (alog_len(log) == 0) { return 1; } return 0; }

fn alog_clear(log) {
    store64(log, vec_new());
    return log;
}

# Append audit events to file (one JSON line per event)
fn alog_append_to_file(log, path) {
    var fd = file_open(path, 1089, 420);  # O_WRONLY|O_CREAT|O_APPEND, 0644
    if (fd < 0) { return ERR_IO; }
    var events = load64(log);
    var elen = vec_len(events);
    var i = 0;
    while (i < elen) {
        var e = vec_get(events, i);
        # Simple JSON line: {"type":"...","timestamp":...}
        var line = alloc(512);
        var pos = 0;
        pos = pos + _alog_write_str(line + pos, "{\"type\":\"");
            pos = pos + _alog_write_str(line + pos, audit_event_name(ae_type(e)));
            pos = pos + _alog_write_str(line + pos, "\",\"timestamp\":");
            pos = pos + _alog_write_int(line + pos, ae_timestamp(e));
            if (ae_path(e) != 0) {
                pos = pos + _alog_write_str(line + pos, ",\"path\":\"");
                pos = pos + _alog_write_str(line + pos, ae_path(e));
                pos = pos + _alog_write_str(line + pos, "\"");
            }
            if (ae_key_id(e) != 0) {
                pos = pos + _alog_write_str(line + pos, ",\"key_id\":\"");
                pos = pos + _alog_write_str(line + pos, ae_key_id(e));
                pos = pos + _alog_write_str(line + pos, "\"");
            }
            if (ae_content_hash(e) != 0) {
                pos = pos + _alog_write_str(line + pos, ",\"content_hash\":\"");
                pos = pos + _alog_write_str(line + pos, ae_content_hash(e));
                pos = pos + _alog_write_str(line + pos, "\"");
            }
            if (ae_passed(e) != (0 - 1)) {
                pos = pos + _alog_write_str(line + pos, ",\"passed\":");
                if (ae_passed(e) == 1) { pos = pos + _alog_write_str(line + pos, "true"); }
                else { pos = pos + _alog_write_str(line + pos, "false"); }
            }
            pos = pos + _alog_write_str(line + pos, "}\n");
        store8(line + pos, 0);
        file_write(fd, line, pos);
        i = i + 1;
    }
    file_close(fd);
    return ERR_NONE;
}

fn _alog_write_str(dst, src) {
    var len = strlen(src);
    memcpy(dst, src, len);
    return len;
}

# Global to survive nested calls
var _alog_int_buf = 0;

fn _alog_write_int(dst, val) {
    if (_alog_int_buf == 0) { _alog_int_buf = alloc(24); }
    # Manual int-to-string into global buffer
    var v = val;
    var pos = 23;
    store8(_alog_int_buf + pos, 0);
    pos = pos - 1;
    if (v == 0) {
        store8(_alog_int_buf + pos, 48);
        pos = pos - 1;
    } else {
        while (v > 0) {
            store8(_alog_int_buf + pos, 48 + (v % 10));
            v = v / 10;
            pos = pos - 1;
        }
    }
    pos = pos + 1;
    var len = 23 - pos;
    memcpy(dst, _alog_int_buf + pos, len);
    return len;
}

# --- tpm.cyr ---

# tpm.cyr — TPM integration for sigil trust verification
# Uses agnosys TPM exports (tpm_detect, tpm_read_pcr, tpm_extend_pcr,
# tpm_verify_measured_boot, tpm_seal/unseal, tpm_get_random)
#
# Runtime feature detection: tpm_available() checks device presence.

# ================================================================
# PcrMeasurement (24 bytes)
# ================================================================
# Layout:
#   +0   index           (i64, PCR index 0-23)
#   +8   expected_digest (C-string ptr, hex)
#   +16  actual_digest   (C-string ptr, hex, 0 = not yet read)

fn pcr_measurement_new(index, expected_digest) {
    var m = fl_alloc(24);
    store64(m, index);
    store64(m + 8, expected_digest);
    store64(m + 16, 0);
    return m;
}

fn pcr_index(m) { return load64(m); }
fn pcr_expected(m) { return load64(m + 8); }
fn pcr_actual(m) { return load64(m + 16); }
fn pcr_set_actual(m, v) { store64(m + 16, v); return m; }

# ================================================================
# AttestationResult (24 bytes)
# ================================================================
# Layout:
#   +0   passed          (i64, 0 or 1)
#   +8   measurements    (vec of PcrMeasurement)
#   +16  quote_signature (ptr, 0 = none)

fn attestation_result_new(passed) {
    var r = fl_alloc(24);
    store64(r, passed);
    store64(r + 8, vec_new());
    store64(r + 16, 0);
    return r;
}

fn attest_passed(r) { return load64(r); }
fn attest_measurements(r) { return load64(r + 8); }
fn attest_quote_sig(r) { return load64(r + 16); }
fn attest_set_quote_sig(r, v) { store64(r + 16, v); return r; }

# ================================================================
# TPM availability (runtime detection)
# ================================================================

fn tpm_available() {
    # Check for /dev/tpm0 or /dev/tpmrm0
    var fd = file_open("/dev/tpmrm0", 0, 0);
    if (fd >= 0) {
        file_close(fd);
        return 1;
    }
    fd = file_open("/dev/tpm0", 0, 0);
    if (fd >= 0) {
        file_close(fd);
        return 1;
    }
    return 0;
}

# ================================================================
# Measure a system component: hash file and extend into PCR
# ================================================================

fn measure_system_component(path, pcr_index_val) {
    var h = hash_file(path);
    if (h == 0) { return 0; }
    var m = pcr_measurement_new(pcr_index_val, h);
    pcr_set_actual(m, h);
    return m;
}

# ================================================================
# Verify PCR measurements against expected baselines
# ================================================================

fn verify_pcr_measurements(expected_measurements) {
    var mlen = vec_len(expected_measurements);
    var all_pass = 1;
    var result = attestation_result_new(0);
    var result_measurements = attest_measurements(result);

    var i = 0;
    while (i < mlen) {
        var m = vec_get(expected_measurements, i);
        var idx = pcr_index(m);
        var expected = pcr_expected(m);

        # Try to read actual PCR value
        # In production this would call agnosys tpm_read_pcr()
        # For now, just record the expected value for the measurement
        var actual = pcr_actual(m);
        if (actual != 0) {
            if (ct_eq(actual, strlen(actual), expected, strlen(expected)) == 0) {
                all_pass = 0;
            }
        } else {
            # No actual value available — can't verify
            all_pass = 0;
        }

        vec_push(result_measurements, m);
        i = i + 1;
    }

    store64(result, all_pass);
    return result;
}

# ================================================================
# TPM-backed sealing (wraps agnosys tpm_seal when available)
# ================================================================

fn tpm_seal_data(data, data_len, pcr_indices) {
    if (tpm_available() == 0) { return 0; }
    # Seal data to current PCR state
    # In production: calls agnosys tpm_seal(TPM_SHA256, pcr_indices, data, data_len, output_dir)
    # Returns sealed blob pointer or 0 on failure
    return 0;  # Stub until agnosys integration
}

fn tpm_unseal_data(sealed_blob, buf, buf_len) {
    if (tpm_available() == 0) { return 0; }
    # Unseal data — succeeds only if PCR state matches seal policy
    # In production: calls agnosys tpm_unseal(sealed, buf, buflen)
    return 0;  # Stub until agnosys integration
}

# ================================================================
# TPM random number generation
# ================================================================

fn tpm_random(buf, count) {
    # Returns count on full success, 0 on any failure or short read.
    # Caller MUST treat any non-count return as entropy failure.
    if (count <= 0) { return 0; }
    var fd = file_open("/dev/urandom", 0, 0);
    if (fd < 0) { return 0; }
    var got = 0;
    while (got < count) {
        var n = file_read(fd, buf + got, count - got);
        if (n <= 0) {
            file_close(fd);
            return 0;
        }
        got = got + n;
    }
    file_close(fd);
    return count;
}

# --- verify.cyr ---

# verify.cyr — SigilVerifier: the main trust engine
# Combines signing, keyring, integrity, revocation, key pinning, audit.

# ================================================================
# KeyPin (16 bytes)
# ================================================================
# Layout:
#   +0   key_id       (C-string ptr)
#   +8   path_prefix  (C-string ptr)

fn key_pin_new(key_id, path_prefix) {
    var kp = fl_alloc(16);
    store64(kp, key_id);
    store64(kp + 8, path_prefix);
    return kp;
}

fn kpin_key_id(kp) { return load64(kp); }
fn kpin_prefix(kp) { return load64(kp + 8); }

# ================================================================
# ComplianceReport (56 bytes)
# ================================================================
# Layout:
#   +0   total            (i64)
#   +8   compliant_count  (i64)
#   +16  compliant        (vec)
#   +24  below_minimum    (vec)
#   +32  unsigned_list    (vec)
#   +40  revoked_list     (vec)
#   +48  pin_violations   (vec)

fn compliance_report_new() {
    var cr = fl_alloc(56);
    store64(cr, 0);
    store64(cr + 8, 0);
    store64(cr + 16, vec_new());
    store64(cr + 24, vec_new());
    store64(cr + 32, vec_new());
    store64(cr + 40, vec_new());
    store64(cr + 48, vec_new());
    return cr;
}

fn creport_total(cr) { return load64(cr); }
fn creport_compliant_count(cr) { return load64(cr + 8); }
fn creport_is_compliant(cr) {
    if (load64(cr + 8) == load64(cr)) { return 1; }
    return 0;
}
fn creport_violation_count(cr) {
    return load64(cr) - load64(cr + 8);
}

# ================================================================
# SigilVerifier (72 bytes)
# ================================================================
# Layout:
#   +0   keyring       (PublisherKeyring ptr)
#   +8   policy        (TrustPolicy ptr)
#   +16  revocations   (RevocationList ptr)
#   +24  integrity     (IntegrityVerifier ptr)
#   +32  trust_store   (hashmap: content_hash -> TrustedArtifact)
#   +40  key_pins      (vec of KeyPin)
#   +48  cache_enabled (i64)
#   +56  audit_log     (AuditLog ptr)
#   +64  cache         (hashmap: path -> cached result hash, 0=disabled)

fn sigil_verifier_new(keyring, policy) {
    var sv = fl_alloc(72);
    store64(sv, keyring);
    store64(sv + 8, policy);
    store64(sv + 16, revocation_list_new());
    store64(sv + 24, integrity_verifier_new(integrity_policy_new()));
    store64(sv + 32, map_new());
    store64(sv + 40, vec_new());
    store64(sv + 48, 0);
    store64(sv + 56, audit_log_new());
    store64(sv + 64, 0);
    return sv;
}

fn sv_keyring(sv) { return load64(sv); }
fn sv_policy(sv) { return load64(sv + 8); }
fn sv_revocations(sv) { return load64(sv + 16); }
fn sv_integrity(sv) { return load64(sv + 24); }
fn sv_trust_store(sv) { return load64(sv + 32); }
fn sv_key_pins(sv) { return load64(sv + 40); }
fn sv_audit_log(sv) { return load64(sv + 56); }

# Cache is currently a stub: these setters write to fields at +48 and
# +64 but no read path consults them. Kept for API stability through
# the 2.x line; candidate for removal or wiring up in 2.2.0.
fn sv_set_cache_enabled(sv, enabled) {
    store64(sv + 48, enabled);
    return sv;
}

fn sv_clear_cache(sv) {
    store64(sv + 64, 0);
    return sv;
}

# ================================================================
# Key pin management
# ================================================================

fn sv_add_key_pin(sv, pin) {
    vec_push(load64(sv + 40), pin);
    return sv;
}

fn sv_remove_key_pins(sv, path_prefix) {
    var pins = load64(sv + 40);
    var plen = vec_len(pins);
    var removed = 0;
    var i = plen - 1;
    while (i >= 0) {
        var pin = vec_get(pins, i);
        if (streq(kpin_prefix(pin), path_prefix) == 1) {
            vec_remove(pins, i);
            removed = removed + 1;
        }
        i = i - 1;
    }
    return removed;
}

# Check if key is authorized for path (no pin = any key OK)
fn _sv_key_authorized(sv, path, signer_key_id) {
    var pins = load64(sv + 40);
    var plen = vec_len(pins);
    var has_matching_pin = 0;
    var path_len = 0;
    if (path != 0) { path_len = strlen(path); }
    var i = 0;
    while (i < plen) {
        var pin = vec_get(pins, i);
        var prefix = kpin_prefix(pin);
        var plen2 = strlen(prefix);
        # Guard against OOB read: memeq reads plen2 bytes from path,
        # so path must be at least that long.
        if (path_len >= plen2) {
            if (memeq(path, prefix, plen2) == 1) {
                has_matching_pin = 1;
                if (signer_key_id != 0) {
                    if (streq(kpin_key_id(pin), signer_key_id) == 1) {
                        return 1;
                    }
                }
            }
        }
        i = i + 1;
    }
    if (has_matching_pin == 0) { return 1; }
    return 0;
}

# ================================================================
# Register artifacts in trust store
# ================================================================

fn sv_register_trusted(sv, artifact) {
    # Downgrade SystemCore to Verified (only register_system_core allows SystemCore)
    if (artifact_trust_level(artifact) == TRUST_SYSTEM_CORE) {
        artifact_set_trust_level(artifact, TRUST_VERIFIED);
    }
    var chash = artifact_content_hash(artifact);
    map_set(load64(sv + 32), chash, artifact);
    return sv;
}

fn sv_register_system_core(sv, artifact) {
    artifact_set_trust_level(artifact, TRUST_SYSTEM_CORE);
    var chash = artifact_content_hash(artifact);
    map_set(load64(sv + 32), chash, artifact);
    return sv;
}

# ================================================================
# Sign an artifact and register it
# ================================================================

fn sv_sign_artifact(sv, path, secret_key, key_id, artifact_type) {
    var chash = hash_file(path);
    if (chash == 0) { return 0; }

    var sig = sign_data(chash, strlen(chash), secret_key);
    var artifact = trusted_artifact_new(path, artifact_type, chash);
    artifact_set_signature(artifact, sig, 64);
    artifact_set_signer(artifact, key_id);
    artifact_set_trust_level(artifact, TRUST_VERIFIED);
    artifact_set_verified_at(artifact, clock_epoch_secs());

    map_set(load64(sv + 32), chash, artifact);

    # Audit
    var ae = audit_artifact_signed(path, artifact_type, key_id, chash);
    alog_record(load64(sv + 56), ae);

    return artifact;
}

# ================================================================
# Verify an artifact
# ================================================================

fn sv_verify_artifact(sv, path, artifact_type) {
    var policy = load64(sv + 8);
    var chash = hash_file(path);
    if (chash == 0) {
        return verification_result_new(
        trusted_artifact_new(path, artifact_type, ""),
        0, clock_epoch_secs()
        );
    }

    var trust_level = TRUST_UNVERIFIED;
    var vr = verification_result_new(
    trusted_artifact_new(path, artifact_type, chash),
    1, clock_epoch_secs()
    );

    # Check: file readable
    vresult_add_check(vr, trust_check_new("file_readable", 1, "File read successfully"));

    # Check: trust store lookup
    var store = load64(sv + 32);
    var stored = map_get(store, chash);
    if (stored != 0) {
        trust_level = artifact_trust_level(stored);
        vresult_add_check(vr, trust_check_new("trust_store", 1, "Found in trust store"));
    } else {
        vresult_add_check(vr, trust_check_new("trust_store", 0, "Not in trust store"));
    }

    # Check: signature verification
    if (stored != 0) {
        var sig = artifact_signature(stored);
        var signer = artifact_signer_key_id(stored);
        if (sig != 0) {
            if (signer != 0) {
                var kr = load64(sv);
                var kv = keyring_get_current(kr, signer);
                if (kv != 0) {
                    var pk = kv_public_key_hex(kv);
                    if (pk != 0) {
                        if (strlen(pk) != 64) {
                            trust_level = TRUST_UNVERIFIED;
                            vresult_add_check(vr, trust_check_new("signature", 0, "Public key hex wrong length"));
                        } else {
                            var pk_bytes = hex_decode(pk, 64);
                            if (pk_bytes == 0) {
                                trust_level = TRUST_UNVERIFIED;
                                vresult_add_check(vr, trust_check_new("signature", 0, "Public key hex invalid"));
                            } else {
                                var valid = verify_data(chash, strlen(chash), sig, pk_bytes);
                                if (valid == 1) {
                                    if (trust_level_rank(trust_level) < trust_level_rank(TRUST_VERIFIED)) {
                                        trust_level = TRUST_VERIFIED;
                                    }
                                    vresult_add_check(vr, trust_check_new("signature", 1, "Signature valid"));
                                } else {
                                    trust_level = TRUST_UNVERIFIED;
                                    vresult_add_check(vr, trust_check_new("signature", 0, "Signature invalid"));
                                }
                            }
                        }
                    } else {
                        vresult_add_check(vr, trust_check_new("signature", 0, "No public key for verification"));
                    }
                } else {
                    vresult_add_check(vr, trust_check_new("signature", 0, "Signer key not in keyring"));
                }
            } else {
                vresult_add_check(vr, trust_check_new("signature", 0, "No signer key ID"));
            }
        } else {
            vresult_add_check(vr, trust_check_new("signature", 0, "No signature"));
        }
    } else {
        vresult_add_check(vr, trust_check_new("signature", 0, "Not in trust store"));
    }

    # Check: revocation
    var rl = load64(sv + 16);
    var key_revoked = 0;
    var hash_revoked = rl_is_artifact_revoked(rl, chash);
    if (stored != 0) {
        var signer = artifact_signer_key_id(stored);
        if (signer != 0) {
            key_revoked = rl_is_key_revoked(rl, signer);
        }
    }
    if (key_revoked == 1) {
        trust_level = TRUST_REVOKED;
        vresult_add_check(vr, trust_check_new("revocation", 0, "Signer key revoked"));
    } elif (hash_revoked == 1) {
        trust_level = TRUST_REVOKED;
        vresult_add_check(vr, trust_check_new("revocation", 0, "Content hash revoked"));
    } else {
        vresult_add_check(vr, trust_check_new("revocation", 1, "Not revoked"));
    }

    # Check: key pinning
    if (stored != 0) {
        var signer = artifact_signer_key_id(stored);
        var authorized = _sv_key_authorized(sv, path, signer);
        if (authorized == 1) {
            vresult_add_check(vr, trust_check_new("key_pin", 1, "Key authorized"));
        } else {
            vresult_add_check(vr, trust_check_new("key_pin", 0, "Key not authorized for path"));
            trust_level = TRUST_UNVERIFIED;
        }
    }

    # Check: policy compliance
    var min_trust = policy_min_trust(policy);
    var enforcement = policy_enforcement(policy);
    var meets_min = trust_level_ge(trust_level, min_trust);
    if (meets_min == 1) {
        vresult_add_check(vr, trust_check_new("policy", 1, "Meets minimum trust level"));
    } else {
        if (enforcement == ENFORCE_STRICT) {
            vresult_add_check(vr, trust_check_new("policy", 0, "Below minimum trust level"));
            vresult_set_passed(vr, 0);
        } elif (enforcement == ENFORCE_PERMISSIVE) {
            vresult_add_check(vr, trust_check_new("policy", 0, "Below minimum (permissive)"));
        } else {
            vresult_add_check(vr, trust_check_new("policy", 0, "Below minimum (audit only)"));
        }
    }

    # Update artifact trust level
    artifact_set_trust_level(vresult_artifact(vr), trust_level);

    # Audit
    var passed = vresult_passed(vr);
    var ae = audit_artifact_verified(path, artifact_type, trust_level, passed, chash);
    alog_record(load64(sv + 56), ae);

    return vr;
}

# ================================================================
# Convenience: verify agent binary
# ================================================================

fn sv_verify_agent(sv, path) {
    var policy = load64(sv + 8);
    var vr = sv_verify_artifact(sv, path, ARTIFACT_AGENT_BINARY);

    # Additional check: unsigned agents
    if (policy_allow_unsigned(policy) == 0) {
        var checks = vresult_checks(vr);
        var clen = vec_len(checks);
        var has_sig = 0;
        var i = 0;
        while (i < clen) {
            var tc = vec_get(checks, i);
            if (streq(check_name(tc), "signature") == 1) {
                if (check_passed(tc) == 1) { has_sig = 1; }
            }
            i = i + 1;
        }
        if (has_sig == 0) {
            vresult_add_check(vr, trust_check_new("unsigned_agent", 0, "Unsigned agents not allowed"));
            vresult_set_passed(vr, 0);
        }
    }
    return vr;
}

# ================================================================
# Revocation management
# ================================================================

fn sv_add_revocation(sv, entry) {
    var rl = load64(sv + 16);
    var result = rl_add(rl, entry);
    if (result == ERR_NONE) {
        var ae = audit_revocation_added(rev_key_id(entry), rev_content_hash(entry), rev_reason(entry));
        alog_record(load64(sv + 56), ae);
    }
    return result;
}

fn sv_check_revocation(sv, key_id, content_hash) {
    var rl = load64(sv + 16);
    if (key_id != 0) {
        if (rl_is_key_revoked(rl, key_id) == 1) { return 1; }
    }
    if (content_hash != 0) {
        if (rl_is_artifact_revoked(rl, content_hash) == 1) { return 1; }
    }
    return 0;
}

fn sv_revocation_count(sv) {
    return rl_len(load64(sv + 16));
}

# ================================================================
# Trust store queries
# ================================================================

fn sv_trust_level_for(sv, content_hash) {
    var store = load64(sv + 32);
    var artifact = map_get(store, content_hash);
    if (artifact == 0) { return TRUST_UNVERIFIED; }
    return artifact_trust_level(artifact);
}

fn sv_stats(sv) {
    var store = load64(sv + 32);
    var s = sigil_stats_new();
    var keys = map_keys(store);
    var total = vec_len(keys);
    store64(s, total);
    var verified = 0;
    var revoked = 0;
    var i = 0;
    while (i < total) {
        var chash = vec_get(keys, i);
        var artifact = map_get(store, chash);
        var tl = artifact_trust_level(artifact);
        if (trust_level_ge(tl, TRUST_VERIFIED) == 1) { verified = verified + 1; }
        if (tl == TRUST_REVOKED) { revoked = revoked + 1; }
        i = i + 1;
    }
    store64(s + 8, verified);
    store64(s + 16, revoked);
    return s;
}

# ================================================================
# Boot chain verification
# ================================================================

# ================================================================
# Compliance report
# ================================================================

fn sv_compliance_report(sv) {
    var cr = compliance_report_new();
    var store = load64(sv + 32);
    var policy = load64(sv + 8);
    var min_trust = policy_min_trust(policy);
    var keys = map_keys(store);
    var total = vec_len(keys);
    store64(cr, total);

    var compliant = 0;
    var i = 0;
    while (i < total) {
        var chash = vec_get(keys, i);
        var artifact = map_get(store, chash);
        var tl = artifact_trust_level(artifact);
        var path = artifact_path(artifact);

        if (tl == TRUST_REVOKED) {
            vec_push(load64(cr + 40), artifact);
        } elif (trust_level_ge(tl, min_trust) == 0) {
            vec_push(load64(cr + 24), artifact);
        } else {
            # Check key pin
            var signer = artifact_signer_key_id(artifact);
            if (_sv_key_authorized(sv, path, signer) == 0) {
                vec_push(load64(cr + 48), artifact);
            } else {
                if (artifact_signature(artifact) == 0) {
                    if (policy_allow_unsigned(policy) == 0) {
                        vec_push(load64(cr + 32), artifact);
                    } else {
                        vec_push(load64(cr + 16), artifact);
                        compliant = compliant + 1;
                    }
                } else {
                    vec_push(load64(cr + 16), artifact);
                    compliant = compliant + 1;
                }
            }
        }
        i = i + 1;
    }
    store64(cr + 8, compliant);
    return cr;
}

# ================================================================
# Trust store snapshot and diff
# ================================================================

fn sv_snapshot_trust_store(sv) {
    var store = load64(sv + 32);
    var keys = map_keys(store);
    var snap = map_new();
    var klen = vec_len(keys);
    var i = 0;
    while (i < klen) {
        var chash = vec_get(keys, i);
        var artifact = map_get(store, chash);
        map_set(snap, chash, artifact);
        i = i + 1;
    }
    return snap;
}

# TrustStoreDiff (24 bytes): added, removed, changed (all vecs)
fn trust_store_diff_new() {
    var d = fl_alloc(24);
    store64(d, vec_new());     # added
    store64(d + 8, vec_new()); # removed
    store64(d + 16, vec_new()); # changed
    return d;
}

fn tsdiff_added(d) { return load64(d); }
fn tsdiff_removed(d) { return load64(d + 8); }
fn tsdiff_changed(d) { return load64(d + 16); }
fn tsdiff_is_empty(d) {
    if (vec_len(load64(d)) == 0) {
        if (vec_len(load64(d + 8)) == 0) {
            if (vec_len(load64(d + 16)) == 0) { return 1; }
        }
    }
    return 0;
}

fn sv_diff_trust_store(sv, old_snap) {
    var diff = trust_store_diff_new();
    var store = load64(sv + 32);
    var current_keys = map_keys(store);
    var old_keys = map_keys(old_snap);

    # Find added and changed
    var cklen = vec_len(current_keys);
    var i = 0;
    while (i < cklen) {
        var chash = vec_get(current_keys, i);
        var old_art = map_get(old_snap, chash);
        if (old_art == 0) {
            vec_push(load64(diff), map_get(store, chash));
        } else {
            var new_art = map_get(store, chash);
            if (artifact_trust_level(new_art) != artifact_trust_level(old_art)) {
                vec_push(load64(diff + 16), new_art);
            }
        }
        i = i + 1;
    }

    # Find removed
    var oklen = vec_len(old_keys);
    i = 0;
    while (i < oklen) {
        var chash = vec_get(old_keys, i);
        if (map_get(store, chash) == 0) {
            vec_push(load64(diff + 8), map_get(old_snap, chash));
        }
        i = i + 1;
    }
    return diff;
}

# ================================================================
# Trust store persistence
# ================================================================

fn sv_save_trust_store(sv, path) {
    var store = load64(sv + 32);
    var keys = map_keys(store);
    var klen = vec_len(keys);
    var fd = file_open(path, 577, 420);
    if (fd < 0) { return ERR_IO; }
    file_write(fd, "[", 1);
    var i = 0;
    var nbuf[24];
    while (i < klen) {
        var chash = vec_get(keys, i);
        var art = map_get(store, chash);
        if (i > 0) { file_write(fd, ",", 1); }
        file_write(fd, "{\"hash\":\"", 9);
            json_write_escaped(fd, chash, strlen(chash));
            file_write(fd, "\",\"path\":\"", 10);
            var ap = artifact_path(art);
            json_write_escaped(fd, ap, strlen(ap));
            file_write(fd, "\",\"type\":", 9);
            # fmt_int prints to stdout — use fmt_int_buf for file output.
            memset(&nbuf, 0, 24);
            var nlen = fmt_int_buf(artifact_type(art), &nbuf);
            file_write(fd, &nbuf, nlen);
            file_write(fd, ",\"trust\":", 9);
            memset(&nbuf, 0, 24);
            nlen = fmt_int_buf(artifact_trust_level(art), &nbuf);
            file_write(fd, &nbuf, nlen);
            file_write(fd, "}", 1);
        i = i + 1;
    }
    file_write(fd, "]", 1);
    file_close(fd);
    return ERR_NONE;
}

# Batch verification
fn sv_verify_batch(sv, artifacts, count) {
    var results = vec_new();
    var i = 0;
    while (i < count) {
        # Each artifact entry: {path, type} packed as 16 bytes
        var path = load64(artifacts + i * 16);
        var atype = load64(artifacts + i * 16 + 8);
        var vr = sv_verify_artifact(sv, path, atype);
        vec_push(results, vr);
        i = i + 1;
    }
    return results;
}

# ================================================================
# Boot chain verification
# ================================================================

fn sv_verify_boot_chain(sv, components) {
    var policy = load64(sv + 8);
    if (policy_verify_on_boot(policy) == 0) {
        return integrity_report_new();
    }

    var iv = load64(sv + 24);
    var ipol = integrity_policy_new();

    var clen = vec_len(components);
    var i = 0;
    while (i < clen) {
        var path = vec_get(components, i);
        var store = load64(sv + 32);
        # Look for artifact by path in trust store
        var keys = map_keys(store);
        var klen = vec_len(keys);
        var j = 0;
        while (j < klen) {
            var chash = vec_get(keys, j);
            var artifact = map_get(store, chash);
            if (streq(artifact_path(artifact), path) == 1) {
                ipolicy_add(ipol, path, chash);
            }
            j = j + 1;
        }
        i = i + 1;
    }

    iv_set_policy(iv, ipol);
    return iv_verify_all(iv);
}
